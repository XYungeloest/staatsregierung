{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ostrecht-portal",
  "compatibility_date": "2026-04-15",
  "workers_dev": true,
  "assets": {
    "directory": "./dist"
  },

  // Platzhalter für spätere Ausbaustufen:
