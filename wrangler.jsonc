  //     "binding": "DB",
  //     "database_name": "ostrecht-portal",
  //     "database_id": "<D1_DATABASE_ID>"
  //   }
  // ],
  // "r2_buckets": [
  //   {
  //     "binding": "MEDIA",
  //     "bucket_name": "ostrecht-portal-media"
  //   }
  // ],

  "env": {
    "staging": {
      "name": "ostrecht-portal-staging",
      "workers_dev": true
    }
  }
}
