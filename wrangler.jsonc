{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ostrecht-portal",
  "compatibility_date": "2026-04-15",
  "workers_dev": true,
  "vars": {
    "APP_ENV": "production"
  },
  "assets": {
    "directory": "./dist"
  },

  "env": {
    "staging": {
      "name": "ostrecht-portal-staging",
      "workers_dev": true,
      "vars": {
        "APP_ENV": "staging"
      }
    }
  }
}
