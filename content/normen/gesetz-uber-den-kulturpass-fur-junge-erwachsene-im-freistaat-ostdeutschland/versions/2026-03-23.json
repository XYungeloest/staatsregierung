  "citation": "Gesetz vom 23. März 2026 (OGVBl. 2026 Nr. 30)",
  "changeNote": "Stammfassung.",
  "body": [
    {
      "type": "paragraphText",
      "text": "Der Ostdeutsche Landtag hat am 23. März 2026 das folgende Gesetz beschlossen:"
    },
    {
      "type": "article",
      "label": "Artikel 1",
      "title": "Einführung eines Ostdeutschen Kulturpassgesetzes",
      "children": [
        {
          "type": "paragraphText",
          "text": "Das nachstehende wird Gesetz:"
        },
        {
          "type": "paragraphText",
          "text": "Gesetz über den Kulturpass für junge Erwachsene im Freistaat Ostdeutschland (Ostdeutsches Kulturpassgesetz – OstKulturPassG)"
        }
      ]
    },
    {
      "type": "article",
      "label": "Artikel 2",
      "title": "Inkrafttreten",
      "children": [
        {
          "type": "paragraphText",
          "text": "Dieses Gesetz tritt am zehnten Tage nach der Verkündung in Kraft."
        }
      ]
    }
  ]
}
