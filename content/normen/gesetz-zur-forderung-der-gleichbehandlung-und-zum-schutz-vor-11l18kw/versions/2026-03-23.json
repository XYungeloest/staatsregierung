  "citation": "Gesetz vom 23. März 2026 (OGVBl. 2026 Nr. 25)",
  "changeNote": "Stammfassung.",
  "body": [
    {
      "type": "paragraphText",
      "text": "Der Ostdeutsche Landtag hat am 23. März 2026 das folgende Gesetz beschlossen:"
    },
    {
      "type": "article",
      "label": "Artikel 1",
      "title": "Einführung eines Ostdeutschen Landesantidiskriminierungsgesetzes",
      "children": [
        {
          "type": "paragraphText",
          "text": "Das nachstehende wird Gesetz:"
        },
        {
          "type": "paragraphText",
          "text": "Gesetz zur Förderung der Gleichbehandlung und zum Schutz vor Diskriminierung im öffentlich-rechtlichen Handeln (Ostdeutsches Landesantidiskriminierungsgesetz – OLADG)"
        }
      ]
    },
    {
      "type": "article",
      "label": "Artikel 2",
      "title": "Inkrafttreten",
      "children": [
        {
          "type": "paragraphText",
          "text": "Dieses Gesetz tritt am Tage nach der Verkündung in Kraft."
        }
      ]
    }
  ]
}
