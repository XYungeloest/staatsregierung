  "citation": "Versammlungskoordinierungsgesetz vom 1. Juni 2025 (GVBl. FOD 2025 S. 77)",
  "changeNote": "Stammfassung.",
  "body": [
    {
      "type": "part",
      "label": "Teil 1",
      "title": "Anzeige und Koordinierung",
      "children": [
        {
          "type": "section",
          "label": "Abschnitt 1",
          "title": "Anzeigepflichten",
          "children": [
            {
              "type": "paragraph",
              "label": "§ 1",
              "title": "Anzeige einer Versammlung",
              "children": [
                {
                  "type": "paragraphText",
                  "text": "Wer eine oeffentliche Versammlung unter freiem Himmel veranstalten will, zeigt dies der zustaendigen Koordinierungsstelle spaetestens 72 Stunden vor der Bekanntgabe an."
                }
              ]
            },
            {
              "type": "paragraph",
              "label": "§ 2",
              "title": "Koordinierungsgespraech",
              "children": [
                {
                  "type": "paragraphText",
                  "text": "Die zustaendige Behoerde kann zur Abstimmung von Route, Schutzbedarf und kommunalen Belangen ein Koordinierungsgespraech anbieten."
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
