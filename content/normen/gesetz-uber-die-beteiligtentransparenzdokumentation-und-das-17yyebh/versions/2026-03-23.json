  "citation": "Gesetz vom 23. März 2026 (OGVBl. 2026 Nr. 31)",
  "changeNote": "Stammfassung.",
  "body": [
    {
      "type": "paragraphText",
      "text": "Der Ostdeutsche Landtag hat am 23. März 2026 das folgende Gesetz beschlossen:"
    },
    {
      "type": "article",
      "label": "Artikel 1",
      "title": "Einführung eines Ostdeutschen Beteiligtendokumentationsund Lobbyregistergesetzes",
      "children": [
        {
          "type": "paragraphText",
          "text": "Das nachstehende wird Gesetz:"
        },
        {
          "type": "paragraphText",
          "text": "Gesetz über die Beteiligtentransparenzdokumentation und das Lobbyregister beim Ostdeutschen Landtag (Ostdeutsches Beteiligtendokumentationsund Lobbyregistergesetz – OstBetdokLobregG)"
        }
      ]
    },
    {
      "type": "article",
      "label": "Artikel 2",
      "title": "Inkrafttreten",
      "children": [
        {
          "type": "paragraphText",
          "text": "Dieses Gesetz tritt am 1. Juli 2026 in Kraft."
        }
      ]
    }
  ]
}
