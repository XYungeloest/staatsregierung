---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MinistryCard from '../../components/portal/MinistryCard.astro';
import { siteConfig } from '../../config/site.ts';
import { getHomeUrl, loadMinistries } from '../../lib/portal/index.ts';

const ministries = await loadMinistries();
const currentGovernment = siteConfig.currentGovernment;
---

<BaseLayout title="Ministerien" description="Übersicht der Ministerien der Staatsregierung.">
  <Breadcrumbs items={[{ label: 'Start', href: getHomeUrl() }, { label: 'Ministerien' }]} />

  <section class="section page-header">
    <p class="eyebrow">Ressorts</p>
    <h1>Ministerien</h1>
    <p class="lead">
      Die Ressortseiten zeigen Leitung, Aufgaben, Kontakt und thematische Schwerpunkte der
      Ministerien des {currentGovernment.cabinetName}.
    </p>
  </section>

  <div class="content-grid">
    <section class="section">
      <div class="section-header">
        <h2>Ressortstruktur</h2>
      </div>
      <div class="body-copy">
        <p>
          Die Ministerien der Staatsregierung decken klassische Verwaltungsbereiche ebenso ab wie
          spezifische Politikfelder des Ostdeutschen Freistaates. Dazu gehören der institutionelle
          Aufbau des Landes, soziale Daseinsvorsorge, Infrastruktur sowie Kultur-, Umwelt- und
          Küstenpolitik.
        </p>
        <p>
          Alle Seiten bleiben bewusst kompakt und statisch: Zuständigkeiten, Kontaktangaben und
          thematische Schwerpunkte sind direkt in dateibasierten Inhalten abgelegt.
        </p>
      </div>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Auf einen Blick</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Ministerien</dt>
          <dd>{ministries.length}</dd>
        </div>
        <div>
          <dt>Kabinett</dt>
          <dd>{currentGovernment.cabinetName}</dd>
        </div>
        <div>
          <dt>Gebildet</dt>
          <dd>{siteConfig.date.formatLong(currentGovernment.formedOn)}</dd>
        </div>
      </dl>
    </aside>
  </div>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Alle Ministerien</h2>
      <p>Jedes Ressort ist mit einer eigenen Unterseite und stabiler URL erreichbar.</p>
    </div>
    <div class="card-grid card-grid--two">
      {ministries.map((ministry) => (
        <MinistryCard ministry={ministry} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Gemeinsame Linien der Ressorts</h2>
      <p>Die Ressortstruktur folgt den erkennbaren politischen Schwerpunkten des aktuellen Kabinetts.</p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Staatsorganisation</h3>
        <p>
          Staatskanzlei, Inneres und Rechtsstaatlichkeit prägen den institutionellen Rahmen des
          jungen Freistaates.
        </p>
      </article>
      <article class="panel">
        <h3>Daseinsvorsorge</h3>
        <p>
          Soziale Fürsorge, Bildung, Kultur und Wirtschaft richten sich auf Versorgung, Teilhabe
          und öffentliche Infrastruktur aus.
        </p>
      </article>
      <article class="panel">
        <h3>Regionale Vielfalt</h3>
        <p>
          Mobilität, Umwelt, Küsten- und Landwirtschaftspolitik greifen die große räumliche
          Vielfalt des Landes auf.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
