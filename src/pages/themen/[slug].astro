---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InlineEditTrigger from '../../components/editorial/InlineEditTrigger.astro';
import InlineEditorPanel from '../../components/editorial/InlineEditorPanel.astro';
import PageTools from '../../components/editorial/PageTools.astro';
import FaqAccordion from '../../components/portal/FaqAccordion.astro';
import MinistryCard from '../../components/portal/MinistryCard.astro';
import StatusBadge from '../../components/portal/StatusBadge.astro';
import { getDatabase } from '../../lib/dynamic/env.ts';
import {
  getHomeUrl,
  getMinistryUrl,
  getTopicUrl,
  getTopicsUrl,
} from '../../lib/portal/index.ts';
import {
  getRuntimeNormLookup,
  loadRuntimeMinistries,
  loadRuntimeTopicBySlug,
  loadRuntimeTopics,
} from '../../lib/runtime-content/index.ts';
import { getLawPortalUrl, getNormUrl } from '../../lib/norms/index.ts';
import {
  resolveTopicPageContent,
  shouldRenderEditorialUi,
} from '../../lib/editorial/live.ts';
import { getEditorialSessionLogoutHref } from '../../lib/editorial/session.ts';
import {
  buildInlineEditHref,
  buildInlineSectionState,
  getInlineBaseDraft,
  getInlineFieldDefinition,
  getInlinePanelState,
  getInlineSectionStatusLabel,
} from '../../lib/editorial/inline.ts';
import type { EditorialInlineSectionState } from '../../lib/editorial/inline.ts';

const slug = Astro.params.slug ?? '';
const fallbackTopic = slug ? loadRuntimeTopicBySlug(slug) : undefined;
const { topic, editorial } = await resolveTopicPageContent(slug, fallbackTopic);

if (!topic) {
  Astro.response.status = 404;
}

const topics = loadRuntimeTopics();
const ministries = loadRuntimeMinistries();
const ministryLookup = new Map(ministries.map((ministry) => [ministry.slug, ministry]));
const normLookup = getRuntimeNormLookup();
const leadMinistry = topic ? ministryLookup.get(topic.federfuehrendesRessort) : undefined;
const coMinistries = (topic?.mitzeichnungsressorts ?? [])
  .map((entrySlug) => ministryLookup.get(entrySlug))
  .filter((entry): entry is NonNullable<typeof entry> => Boolean(entry));
const legalReferences = (topic?.rechtsgrundlagen ?? []).map((entry) => ({
  ...entry,
  norm: entry.normSlug ? normLookup.get(entry.normSlug) : undefined,
}));
const relatedTopics = topic
  ? topics
      .filter((entry) => entry.slug !== topic.slug)
      .filter(
        (entry) =>
          entry.federfuehrendesRessort === topic.federfuehrendesRessort ||
          (entry.mitzeichnungsressorts ?? []).includes(topic.federfuehrendesRessort),
      )
      .slice(0, 3)
  : [];
const showEditorialUi = await shouldRenderEditorialUi(Astro.request, Astro.url);
const editorialSessionLogoutHref = getEditorialSessionLogoutHref(Astro.url.pathname);
const database = showEditorialUi ? getDatabase() : undefined;
const inlineBase = showEditorialUi && database && slug
  ? await getInlineBaseDraft(database, 'themenseite', slug)
  : undefined;

function getInlineState(fieldKey: string): EditorialInlineSectionState | undefined {
  if (!inlineBase) {
    return undefined;
  }

  const definition = getInlineFieldDefinition('themenseite', fieldKey);
  return definition
    ? buildInlineSectionState(
        'themenseite',
        definition,
        inlineBase.sourceOrigin,
        inlineBase.fallbackDraft,
        inlineBase.currentDraft,
        inlineBase.publishedDraft,
      )
    : undefined;
}

const heroInline = getInlineState('hero');
const beschlossenInline = getInlineState('beschlossen');
const umgesetztInline = getInlineState('umgesetzt');
const stepsInline = getInlineState('naechste-schritte');
const faqInline = getInlineState('faq');
const inlinePanel =
  showEditorialUi && database && slug && Astro.url.searchParams.get('editor')
    ? await getInlinePanelState(database, Astro.url, 'themenseite', slug, Astro.url.searchParams.get('editor') ?? '')
    : undefined;
const editorMessage = Astro.url.searchParams.get('message') ?? undefined;
const editorError = Astro.url.searchParams.get('error') ?? undefined;
---

{topic ? (
  <BaseLayout
    title={topic.title}
    description={topic.teaser}
    breadcrumbs={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Themen & Projekte', href: getTopicsUrl() },
      { label: topic.title },
    ]}
    scripts={['portal-modules']}
  >
    <Breadcrumbs
      items={[
        { label: 'Startseite', href: getHomeUrl() },
        { label: 'Themen & Projekte', href: getTopicsUrl() },
        { label: topic.title },
      ]}
    />

    <section class="section page-header">
      <p class="eyebrow">Themen & Projekte</p>
      <h1>{topic.title}</h1>
      <div class="topic-card__header">
        <StatusBadge status={topic.status} />
        {leadMinistry ? (
          <p class="topic-card__meta">
            Federführend:{' '}
            <a class="inline-link" href={getMinistryUrl(leadMinistry.slug)}>{leadMinistry.kurzname}</a>
          </p>
        ) : null}
      </div>
      <p class="lead">{topic.hero ?? topic.teaser}</p>
      <nav class="hero-actions" aria-label="Direkteinstiege">
        {leadMinistry ? (
          <a class="button-link" href={getMinistryUrl(leadMinistry.slug)}>Zum zuständigen Ressort</a>
        ) : null}
        <a class="button-link button-link--secondary" href={getLawPortalUrl()}>Zum Rechtsbereich</a>
      </nav>
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(heroInline)}
        href={buildInlineEditHref(Astro.url, 'hero')}
        label="Hero"
        statusLabel={heroInline ? getInlineSectionStatusLabel(heroInline) : 'Ausgangsstand'}
      />
    </section>

    <section class="section">
      <PageTools
        visible={showEditorialUi}
        studioHref={editorial.studioHref}
        sourceLabel={editorial.sourceLabel}
        liveLabel={editorial.liveLabel}
        hasPendingChanges={editorial.entryState.hasPendingChanges}
        sessionDisableHref={editorialSessionLogoutHref}
      />
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Was ist beschlossen?</h2>
        <p>{topic.teaser}</p>
      </div>
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(beschlossenInline)}
        href={buildInlineEditHref(Astro.url, 'beschlossen')}
        label="Beschlossen"
        statusLabel={beschlossenInline ? getInlineSectionStatusLabel(beschlossenInline) : 'Ausgangsstand'}
      />
      <ul class="record-list">
        {topic.beschlossen.map((entry) => (
          <li class="record-list__item"><span>{entry}</span></li>
        ))}
      </ul>
    </section>

    <section class="section section-muted">
      <div class="section-header">
        <h2>Was ist umgesetzt?</h2>
        <p>Der Stand bildet bereits erreichte und rechtlich abgesicherte Schritte des Vorhabens ab.</p>
      </div>
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(umgesetztInline)}
        href={buildInlineEditHref(Astro.url, 'umgesetzt')}
        label="Umgesetzt"
        statusLabel={umgesetztInline ? getInlineSectionStatusLabel(umgesetztInline) : 'Ausgangsstand'}
      />
      <ul class="record-list">
        {topic.umgesetzt.map((entry) => (
          <li class="record-list__item"><span>{entry}</span></li>
        ))}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Nächste Schritte</h2>
        <p>Diese Punkte kennzeichnen laufende oder vorbereitete Ausbauschritte innerhalb des Themas.</p>
      </div>
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(stepsInline)}
        href={buildInlineEditHref(Astro.url, 'naechste-schritte')}
        label="Nächste Schritte"
        statusLabel={stepsInline ? getInlineSectionStatusLabel(stepsInline) : 'Ausgangsstand'}
      />
      <ul class="record-list">
        {topic.naechsteSchritte.map((entry) => (
          <li class="record-list__item"><span>{entry}</span></li>
        ))}
      </ul>
    </section>

    <section class="section section-muted">
      <div class="section-header">
        <h2>Rechtsgrundlagen</h2>
        <p>Die Themenseite verlinkt, soweit möglich, direkt in den vorhandenen Normenbestand des Rechtsportals.</p>
      </div>
      <ul class="record-list">
        {legalReferences.map((entry) => (
          <li class="record-list__item">
            {entry.norm ? (
              <strong><a class="inline-link" href={getNormUrl(entry.norm.slug)}>{entry.label}</a></strong>
            ) : (
              <strong>{entry.label}</strong>
            )}
            {entry.note ? <span>{entry.note}</span> : null}
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>FAQ</h2>
        <p>Kurze Hinweise zur politischen Einordnung und zum Umsetzungsstand des Themas.</p>
      </div>
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(faqInline)}
        href={buildInlineEditHref(Astro.url, 'faq')}
        label="FAQ"
        statusLabel={faqInline ? getInlineSectionStatusLabel(faqInline) : 'Ausgangsstand'}
      />
      <FaqAccordion items={topic.faq} />
    </section>

    <section class="section section-muted">
      <div class="section-header">
        <h2>Zuständiges Ressort</h2>
        <p>Federführung und Mitzeichnung werden als Teil der staatlichen Aufgabenordnung des Freistaates dargestellt.</p>
      </div>
      {leadMinistry ? <MinistryCard ministry={leadMinistry} /> : null}
      {coMinistries.length > 0 ? (
        <>
          <p class="detail-line">Mitzeichnende Ressorts</p>
          <div class="tag-list">
            {coMinistries.map((ministry) => (
              <a class="tag" href={getMinistryUrl(ministry.slug)}>{ministry.kurzname}</a>
            ))}
          </div>
        </>
      ) : null}
    </section>

    {relatedTopics.length > 0 ? (
      <section class="section">
        <div class="section-header">
          <h2>Verwandte Themen</h2>
        </div>
        <ul class="record-list">
          {relatedTopics.map((entry) => (
            <li class="record-list__item">
              <a class="inline-link" href={getTopicUrl(entry.slug)}>{entry.title}</a>
              <span>{entry.teaser}</span>
            </li>
          ))}
        </ul>
      </section>
    ) : null}

    <InlineEditorPanel
      visible={showEditorialUi && Boolean(inlinePanel)}
      currentUrl={Astro.url}
      panel={inlinePanel}
      message={editorMessage}
      errorMessage={editorError}
    />
  </BaseLayout>
) : (
  <BaseLayout
    title="Thema nicht gefunden"
    description="Die angeforderte Themenseite konnte nicht geladen werden."
    breadcrumbs={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Themen & Projekte', href: getTopicsUrl() },
      { label: 'Nicht gefunden' },
    ]}
  >
    <Breadcrumbs
      items={[
        { label: 'Startseite', href: getHomeUrl() },
        { label: 'Themen & Projekte', href: getTopicsUrl() },
        { label: 'Nicht gefunden' },
      ]}
    />

    <section class="section">
      <div class="status-notice status-notice--warning">
        <h1>Themenseite nicht gefunden</h1>
        <p>Der angeforderte Inhalt konnte nicht gefunden werden. Bitte nutzen Sie die Themenübersicht.</p>
      </div>
    </section>
  </BaseLayout>
)}
