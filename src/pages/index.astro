---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import GovernmentMemberCard from '../components/portal/GovernmentMemberCard.astro';
import MinistryCard from '../components/portal/MinistryCard.astro';
import { siteConfig } from '../config/site.ts';
import {
  getBudgetUrl,
  getCabinetUrl,
  getCareerUrl,
  getFreestateUrl,
  getGovernmentMembersUrl,
  getGovernmentUrl,
  getJobUrl,
  getLawHomeUrl,
  getMinistriesUrl,
  getPressReleaseIndexUrl,
  getPressReleaseUrl,
  getPressUrl,
  getServiceUrl,
  getTopicsUrl,
  loadCurrentJobOffers,
  loadFeaturedPressReleases,
  loadGovernmentMembers,
  loadMinistries,
} from '../lib/portal/index.ts';
import { getCurrentVersion, loadAllNorms } from '../lib/norms/index.ts';

const [members, ministries, pressReleases, jobOffers, norms] = await Promise.all([
  loadGovernmentMembers(),
  loadMinistries(),
  loadFeaturedPressReleases(2),
  loadCurrentJobOffers(2),
  loadAllNorms(),
]);

const latestNorms = [...norms]
  .sort((left, right) =>
    getCurrentVersion(right).validFrom.localeCompare(getCurrentVersion(left).validFrom),
  )
  .slice(0, 2);

const currentGovernment = siteConfig.currentGovernment;
const headOfGovernment = members[0];
const deputyHead = members[1];
const spotlightMinistries = [
  'staatskanzlei',
  'inneres-bau-und-kommunale-angelegenheiten',
  'soziale-und-gesundheitliche-fuersorge',
  'mobilitaet-infrastruktur-und-landesentwicklung',
].flatMap((slug) => {
  const ministry = ministries.find((entry) => entry.slug === slug);
  return ministry ? [ministry] : [];
});
---

<BaseLayout
  title="Startseite"
  description="Statisches Regierungsportal des Ostdeutschen Freistaates mit integriertem Rechtsbereich."
>
  <Breadcrumbs items={[{ label: 'Start' }]} />

  <section class="hero hero--portal">
    <p class="eyebrow">Staatsregierung des Ostdeutschen Freistaates</p>
    <h1>{siteConfig.authorityName}</h1>
    <p class="lead">
      Das Portal bündelt die Arbeit der Staatsregierung, Themen und Projekte, Presse, Haushalt,
      Service und den integrierten Rechtsbereich in einer vollständig statischen und
      GitHub-Pages-kompatiblen Website. Es bildet die fiktive Politiksimulation des Ostdeutschen
      Freistaates bewusst behördennah ab.
    </p>
    <div class="meta-grid" aria-label="Portalüberblick">
      <div class="meta-card">
        <span class="meta-label">Kabinett gebildet</span>
        <strong>{siteConfig.date.formatLong(currentGovernment.formedOn)}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Ministerien</span>
        <strong>{ministries.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Regierungsmitglieder</span>
        <strong>{members.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Normen im Rechtsbereich</span>
        <strong>{norms.length}</strong>
      </div>
    </div>
    <nav class="hero-actions" aria-label="Schnelleinstiege">
      <a class="button-link" href={getGovernmentUrl()}>Zur Staatsregierung</a>
      <a class="button-link button-link--secondary" href={getTopicsUrl()}>Zu Themen & Projekte</a>
      <a class="button-link button-link--secondary" href={getLawHomeUrl()}>Zum Rechtsbereich</a>
    </nav>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Freistaat auf einen Blick</h2>
      <p>
        Die Website verbindet Regierungsinformationen mit Grunddaten zum Land und mit dem
        integrierten Rechtsbereich.
      </p>
    </div>
    <div class="fact-grid">
      <article class="fact-card">
        <span class="meta-label">Landeshauptstadt</span>
        <strong>Dresden</strong>
        <p>Berlin gehört mit Sonderstellung zum Freistaat und bleibt Bundeshauptstadt.</p>
      </article>
      <article class="fact-card">
        <span class="meta-label">Gründung</span>
        <strong>1. Dezember 2023</strong>
        <p>Der Freistaat entstand aus einer staatlichen Neuordnung der ostdeutschen Länder.</p>
      </article>
      <article class="fact-card">
        <span class="meta-label">Verwaltungsgliederung</span>
        <strong>Acht Bezirke</strong>
        <p>Die Bezirke verbinden Landesebene und kommunale Ebene in einer mehrstufigen Struktur.</p>
      </article>
      <article class="fact-card">
        <span class="meta-label">Sprachen</span>
        <strong>Deutsch und Sorbisch</strong>
        <p>Die sprachliche und regionale Vielfalt prägt Verwaltung, Kultur und öffentliche Ordnung.</p>
      </article>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Aktuelle Staatsregierung</h2>
      <p>
        Die aktuelle Staatsregierung ist das <strong>{currentGovernment.cabinetName}</strong>. Sie
        wurde am {siteConfig.date.formatLong(currentGovernment.formedOn)} gebildet und wird von
        einer Koalition aus {currentGovernment.coalition} getragen.
      </p>
    </div>
    <div class="spotlight-grid">
      {headOfGovernment ? <GovernmentMemberCard member={headOfGovernment} /> : null}
      {deputyHead ? <GovernmentMemberCard member={deputyHead} /> : null}
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Regierungsarbeit</h3>
        <p>
          Die Staatsregierung koordiniert Kabinettsverfahren, ressortübergreifende Vorhaben und die
          politische Führung des Landes.
        </p>
        <p><a class="inline-link" href={getGovernmentUrl()}>Zur Regierungsübersicht</a></p>
      </article>
      <article class="panel">
        <h3>Kabinett Honecker</h3>
        <p>
          Das Kabinett bildet die achte Staatsregierung des Freistaates und legt die politischen
          Schwerpunkte der laufenden Legislaturperiode fest.
        </p>
        <p><a class="inline-link" href={getCabinetUrl()}>Zum Kabinett</a></p>
      </article>
      <article class="panel">
        <h3>Mitglieder der Regierung</h3>
        <p>
          Profile, Ämter und Ressortzuständigkeiten der aktuellen Regierungsmitglieder werden
          dateibasiert gepflegt.
        </p>
        <p><a class="inline-link" href={getGovernmentMembersUrl()}>Zu den Regierungsmitgliedern</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Portalbereiche</h2>
      <p>
        Die Hauptbereiche sind als eigenständige Module angelegt und behalten zugleich ein
        gemeinsames Erscheinungsbild des Regierungsportals.
      </p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Staatsregierung</h3>
        <p>
          Übersicht zur Staatsregierung, zum Kabinett Honecker und zu allen aktuellen
          Regierungsmitgliedern.
        </p>
        <p class="detail-line">Leitung: {currentGovernment.headOfGovernment}</p>
        <p><a class="inline-link" href={getGovernmentUrl()}>Zur Staatsregierung</a></p>
      </article>
      <article class="panel">
        <h3>Themen & Projekte</h3>
        <p>
          Themenbereiche und Regierungsprojekte werden als eigener Hauptbereich des Portals
          vorbereitet.
        </p>
        <p class="detail-line">Politische Vorhaben und Rechtsgrundlagen</p>
        <p><a class="inline-link" href={getTopicsUrl()}>Zu Themen & Projekte</a></p>
      </article>
      <article class="panel">
        <h3>Presse & Aktuelles</h3>
        <p>
          {pressReleases[0]?.teaser ??
            'Aktuelle Pressemitteilungen der Staatsregierung und ihrer Ressorts.'}
        </p>
        <p class="detail-line">
          {pressReleases[0]
            ? siteConfig.date.formatLong(pressReleases[0].date)
            : 'Redaktioneller Bereich'}
        </p>
        <p><a class="inline-link" href={getPressUrl()}>Zum Pressebereich</a></p>
      </article>
      <article class="panel">
        <h3>Haushalt</h3>
        <p>
          Der Haushaltsbereich wird als eigener Hauptbereich der Staatsregierung in das
          Gesamtportal eingebunden.
        </p>
        <p class="detail-line">Gesamtplan, Einzelpläne und Sondervermögen</p>
        <p><a class="inline-link" href={getBudgetUrl()}>Zum Haushalt</a></p>
      </article>
      <article class="panel">
        <h3>Recht</h3>
        <p>
          Das bestehende Rechtsportal bleibt als eigenständiger Bereich erhalten und ist nun unter
          <code>/recht/</code> eingebunden.
        </p>
        <p class="detail-line">Aktuelle Fassungen, Historie, Suche und Sachgebiete</p>
        <p><a class="inline-link" href={getLawHomeUrl()}>Zum Rechtsbereich</a></p>
      </article>
      <article class="panel">
        <h3>Über den Freistaat</h3>
        <p>
          Grundinformationen zur Staatsordnung, zu Hoheitszeichen, Bezirken und zur Geschichte des
          Freistaates werden in einem eigenen Bereich gebündelt.
        </p>
        <p class="detail-line">Staatsziele, Bezirke und Symbolik</p>
        <p><a class="inline-link" href={getFreestateUrl()}>Zum Bereich Freistaat</a></p>
      </article>
      <article class="panel">
        <h3>Service</h3>
        <p>
          Service, Kontakt, Karriere, Datenschutz und Barrierefreiheit liegen künftig an einer
          gemeinsamen Stelle.
        </p>
        <p class="detail-line">Kontakt, FAQ, Karriere und Hilfeseiten</p>
        <p><a class="inline-link" href={getServiceUrl()}>Zum Service</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Ministerien im Überblick</h2>
      <p>
        Die Ressorts greifen die politischen Schwerpunkte des Landes auf: Staatsaufbau,
        Daseinsvorsorge, Infrastruktur und ein eigenständiges ostdeutsches Regierungsprofil.
      </p>
    </div>
    <div class="card-grid card-grid--two">
      {spotlightMinistries.map((ministry) => (
        <MinistryCard ministry={ministry} />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getMinistriesUrl()}>Alle Ministerien anzeigen</a>
    </p>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Aus aktuellen Bereichen</h2>
      <p>
        Die Startseite verzahnt Presse, Karriere und den Rechtsbereich mit den Kerninformationen
        der Staatsregierung.
      </p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Presse</h3>
        {pressReleases[0] ? (
          <>
            <p>
              <a class="inline-link" href={getPressReleaseUrl(pressReleases[0].slug)}>
                {pressReleases[0].title}
              </a>
            </p>
            <p class="detail-line">{siteConfig.date.formatLong(pressReleases[0].date)}</p>
            <p><a class="inline-link" href={getPressReleaseIndexUrl()}>Alle Pressemitteilungen</a></p>
          </>
        ) : (
          <p>Der Pressebereich ist angebunden und kann redaktionell weiter ausgebaut werden.</p>
        )}
      </article>
      <article class="panel">
        <h3>Service & Karriere</h3>
        {jobOffers[0] ? (
          <>
            <p>
              <a class="inline-link" href={getJobUrl(jobOffers[0].slug)}>
                {jobOffers[0].title}
              </a>
            </p>
            <p class="detail-line">
              Bewerbungsfrist: {siteConfig.date.formatLong(jobOffers[0].applicationDeadline)}
            </p>
            <p><a class="inline-link" href={getCareerUrl()}>Zur Karriere</a></p>
          </>
        ) : (
          <p>
            Der Karrierebereich ist vorbereitet und kann mit weiteren Stellenangeboten ergänzt
            werden.
          </p>
        )}
      </article>
      <article class="panel">
        <h3>Recht</h3>
        {latestNorms[0] ? (
          <>
            <p>
              <a class="inline-link" href={`${getLawHomeUrl()}norm/${latestNorms[0].meta.slug}/`}>
                {latestNorms[0].meta.title}
              </a>
            </p>
            <p class="detail-line">
              Aktuelle Fassung seit{' '}
              {siteConfig.date.formatLong(getCurrentVersion(latestNorms[0]).validFrom)}
            </p>
          </>
        ) : (
          <p>
            Die Rechtsportal-Logik bleibt vollständig erhalten und ist weiterhin such- und
            zitierbar.
          </p>
        )}
      </article>
    </div>
  </section>
</BaseLayout>
