---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ProjectTimeline from '../components/portal/ProjectTimeline.astro';
import GovernmentMemberCard from '../components/portal/GovernmentMemberCard.astro';
import MinistryCard from '../components/portal/MinistryCard.astro';
import TopicCard from '../components/portal/TopicCard.astro';
import { timelineEntries } from '../data/dashboard/timeline.ts';
import { siteConfig } from '../config/site.ts';
import { buildOrganizationJsonLd, buildWebSiteJsonLd } from '../lib/seo/index.ts';
import {
  getActionPlanUrl,
  getBudgetUrl,
  getCareerUrl,
  getFreestateUrl,
  getGovernmentMembersUrl,
  getHomeUrl,
  getGovernmentUrl,
  getJobUrl,
  getLawHomeUrl,
  getPressReleaseIndexUrl,
  getPressReleaseUrl,
  getPressUrl,
  getServiceUrl,
  getTopicsUrl,
} from '../lib/portal/index.ts';
import {
  loadCurrentJobOffers,
  loadFeaturedPressReleases,
  loadGovernmentMembers,
  loadMinistries,
  loadTopics,
} from '../lib/portal/content.ts';
import { getCurrentVersion, loadAllNorms } from '../lib/norms/content.ts';
import { getNormUrl } from '../lib/norms/index.ts';
import SocializationCounter from '../components/portal/SocializationCounter.astro';

const [members, ministries, topics, pressReleases, jobOffers, norms] = await Promise.all([
  loadGovernmentMembers(),
  loadMinistries(),
  loadTopics(),
  loadFeaturedPressReleases(2),
  loadCurrentJobOffers(2),
  loadAllNorms(),
]);

const latestNorms = [...norms]
  .sort((left, right) =>
    getCurrentVersion(right).validFrom.localeCompare(getCurrentVersion(left).validFrom),
  )
  .slice(0, 2);

const currentGovernment = siteConfig.currentGovernment;
const headOfGovernment = members[0];
const deputyHead = members[1];
const featuredTopics = [
  'wohnen-und-vergesellschaftung',
  'bildungsreform',
  'demokratie-und-sicherheit',
  'haushalt-und-finanzen',
].flatMap((slug) => {
  const topic = topics.find((entry) => entry.slug === slug);
  return topic ? [topic] : [];
});
const spotlightMinistries = [
  'staatskanzlei',
  'inneres-bau-und-kommunale-angelegenheiten',
  'soziale-und-gesundheitliche-fuersorge',
  'mobilitaet-infrastruktur-und-landesentwicklung',
].flatMap((slug) => {
  const ministry = ministries.find((entry) => entry.slug === slug);
  return ministry ? [ministry] : [];
});
const ministryLookup = new Map(ministries.map((ministry) => [ministry.slug, ministry]));
---

<BaseLayout
  title="Freistaat Ostdeutschland"
  description="Staatsregierung des Freistaates Ostdeutschland mit Themen, Rechtsportal, Presse, Haushalt und Service. Dresden ist Sitz der Staatsregierung innerhalb dieser fiktiven Politiksimulation."
  breadcrumbs={[{ label: 'Startseite', href: getHomeUrl() }]}
  structuredData={[buildWebSiteJsonLd(Astro.site), buildOrganizationJsonLd(Astro.site)]}
  scripts={['portal-modules']}
>
  <Breadcrumbs items={[{ label: 'Startseite' }]} />

  <section class="hero hero--portal">
    <p class="eyebrow">Staatsregierung des Ostdeutschen Freistaates</p>
    <h1>{siteConfig.authorityName}</h1>
    <p class="lead">
      Die Website bündelt Staatsregierung, Themen und Projekte, Recht, Presse, Haushalt und
      Service in einer ruhigen, behördennahen Struktur. Politischer Bezugspunkt der
      Regierungsarbeit ist Dresden als Sitz der Staatsregierung.
    </p>
    <div class="meta-grid" aria-label="Portalüberblick">
      <div class="meta-card">
        <span class="meta-label">Regierungssitz</span>
        <strong>{currentGovernment.seatOfGovernment}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Kabinett gebildet</span>
        <strong>{siteConfig.date.formatLong(currentGovernment.formedOn)}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Themenseiten</span>
        <strong>{topics.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Normen im Rechtsbereich</span>
        <strong>{norms.length}</strong>
      </div>
    </div>
    <nav class="hero-actions" aria-label="Schnelleinstiege">
      <a class="button-link" href={getGovernmentUrl()}>Zur Staatsregierung</a>
      <a class="button-link button-link--secondary" href={getTopicsUrl()}>Zu Themen & Projekte</a>
      <a class="button-link button-link--secondary" href={getLawHomeUrl()}>Zum Rechtsbereich</a>
    </nav>
  </section>

  <section class="section section-muted">
    <SocializationCounter
      baseValue={638382}
      baseTimestamp="2026-04-18T12:00:00+02:00"
      ratePerHour={3635}
    />
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Portalbereiche</h2>
      <p>
        Die Startseite führt in die zentralen Arbeitsbereiche der Staatsregierung ein und bindet
        den Rechtsbereich als festen Bestandteil der Website ein.
      </p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Staatsregierung</h3>
        <p>
          Leitung, Kabinett, Koalition und 15-Punkte-Plan sind unter einer gemeinsamen staatlichen
          Struktur gebündelt.
        </p>
        <p class="detail-line">Leitung: {currentGovernment.headOfGovernment}</p>
        <p><a class="inline-link" href={getGovernmentUrl()}>Zur Staatsregierung</a></p>
      </article>
      <article class="panel">
        <h3>Themen & Projekte</h3>
        <p>
          Themenseiten zeigen Beschlüsse, Umsetzungsstände, nächste Schritte, Zuständigkeiten und
          Rechtsgrundlagen.
        </p>
        <p class="detail-line">Direkte Verknüpfung zum Rechtsportal</p>
        <p><a class="inline-link" href={getTopicsUrl()}>Zu Themen & Projekte</a></p>
      </article>
      <article class="panel">
        <h3>Recht</h3>
        <p>
          Das Rechtsportal bleibt funktional eigenständig und ist dauerhaft unter
          <code> /recht/ </code>
          eingebunden.
        </p>
        <p class="detail-line">Aktuelle Fassungen, Historie und Suche</p>
        <p><a class="inline-link" href={getLawHomeUrl()}>Zum Rechtsbereich</a></p>
      </article>
      <article class="panel">
        <h3>Presse & Aktuelles</h3>
        <p>
          Pressemitteilungen und aktuelle Kommunikation der Staatsregierung sind als eigener
          Hauptbereich vorbereitet.
        </p>
        <p class="detail-line">Regierungsnahe Informationslage</p>
        <p><a class="inline-link" href={getPressUrl()}>Zum Pressebereich</a></p>
      </article>
      <article class="panel">
        <h3>Haushalt</h3>
        <p>
          Haushaltsinformationen und finanzpolitische Grundlagen werden in einem eigenen Bereich
          zusammengeführt.
        </p>
        <p class="detail-line">Gesamtplan, Einzelpläne und Fonds</p>
        <p><a class="inline-link" href={getBudgetUrl()}>Zum Haushalt</a></p>
      </article>
      <article class="panel">
        <h3>Service</h3>
        <p>
          Kontakt, Karriere, Hilfeseiten und formale Informationsseiten liegen gebündelt unter
          einem gemeinsamen Service-Einstieg.
        </p>
        <p class="detail-line">Kontakt, Karriere, Datenschutz und Hilfe</p>
        <p><a class="inline-link" href={getServiceUrl()}>Zum Service</a></p>
      </article>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Regierungsmaßnahmen im Überblick</h2>
      <p>
        Diese kompakte Zeitachse zeigt zentrale Kabinettsentscheidungen, Reformgesetze,
        Presseereignisse und Haushaltsmaßnahmen seit Dezember 2025.
      </p>
    </div>
    <ProjectTimeline entries={timelineEntries.slice(-6)} />
    <p class="section-link-row">
      <a class="inline-link" href={getActionPlanUrl()}>Zum 15-Punkte-Plan mit vollständiger Timeline</a>
    </p>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Aktuelle Staatsregierung</h2>
      <p>
        Das <strong>{currentGovernment.cabinetName}</strong> wurde am{' '}
        {siteConfig.date.formatLong(currentGovernment.formedOn)} gebildet und wird von einer
        Koalition aus {currentGovernment.coalition} getragen.
      </p>
    </div>
    <div class="spotlight-grid">
      {headOfGovernment ? <GovernmentMemberCard member={headOfGovernment} /> : null}
      {deputyHead ? <GovernmentMemberCard member={deputyHead} /> : null}
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Regierungsleitung</h3>
        <p>
          Die Staatsregierung steuert Kabinettsverfahren, ressortübergreifende Projekte und die
          öffentliche Kommunikation des Landes.
        </p>
        <p><a class="inline-link" href={getGovernmentMembersUrl()}>Zu den Regierungsmitgliedern</a></p>
      </article>
      <article class="panel">
        <h3>Ressorts</h3>
        <p>
          Die Ressortseiten verbinden Leitung, Aufgaben, Kontakt und Themenbezug in einer kompakten
          Darstellung.
        </p>
        <p><a class="inline-link" href={getGovernmentUrl()}>Zur Regierungsübersicht</a></p>
      </article>
      <article class="panel">
        <h3>15-Punkte-Plan</h3>
        <p>
          Das Regierungsprogramm ist mit Statusindikatoren und direkten Verweisen auf Themen- und
          Rechtsseiten eingebunden.
        </p>
        <p><a class="inline-link" href={getActionPlanUrl()}>Zum 15-Punkte-Plan</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Schwerpunkte der Landespolitik</h2>
      <p>
        Diese Themenseiten tragen das Regierungsportal inhaltlich und verknüpfen politische
        Vorhaben direkt mit Ressorts und Rechtsgrundlagen.
      </p>
    </div>
    <div class="card-grid card-grid--two">
      {featuredTopics.map((topic) => (
        <TopicCard
          topic={topic}
          ministryName={ministryLookup.get(topic.federfuehrendesRessort)?.kurzname}
        />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getTopicsUrl()}>Alle Themenseiten anzeigen</a>
    </p>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Ministerien im Überblick</h2>
      <p>
        Die Ressorts greifen die politischen Schwerpunkte des Landes auf und verorten Aufgaben,
        Zuständigkeiten und Kontaktinformationen in einer einheitlichen Portalstruktur.
      </p>
    </div>
    <div class="card-grid card-grid--two">
      {spotlightMinistries.map((ministry) => (
        <MinistryCard ministry={ministry} />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getGovernmentUrl()}>Alle Ressorts über die Staatsregierung anzeigen</a>
    </p>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Freistaat auf einen Blick</h2>
      <p>
        Grunddaten zum Land und zum Portalrahmen bleiben knapp, sachlich und in enger Verbindung
        zur politischen Simulation.
      </p>
    </div>
    <div class="fact-grid">
      <article class="fact-card">
        <span class="meta-label">Landeshauptstadt</span>
        <strong>Dresden</strong>
        <p>Von hier aus werden Staatsregierung, Kabinett und ressortübergreifende Vorhaben koordiniert.</p>
      </article>
      <article class="fact-card">
        <span class="meta-label">Bundeshauptstadt</span>
        <strong>Berlin</strong>
        <p>Berlin behält als Bundeshauptstadt eine Sonderstellung innerhalb des Freistaates.</p>
      </article>
      <article class="fact-card">
        <span class="meta-label">Verwaltungsgliederung</span>
        <strong>Acht Bezirke</strong>
        <p>Die Bezirksstruktur verbindet Landesebene, regionale Aufgabenwahrnehmung und kommunale Ordnung.</p>
      </article>
      <article class="fact-card">
        <span class="meta-label">Sprachen</span>
        <strong>Deutsch und Sorbisch</strong>
        <p>Sprachliche Vielfalt prägt Verwaltung, Kultur und öffentliche Kommunikation des Landes.</p>
      </article>
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getFreestateUrl()}>Mehr zum Freistaat</a>
    </p>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Aus aktuellen Bereichen</h2>
      <p>
        Die Startseite verzahnt Presse, Karriere und den Rechtsbereich mit den Kerninformationen
        der Staatsregierung.
      </p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Presse</h3>
        {pressReleases[0] ? (
          <>
            <p>
              <a class="inline-link" href={getPressReleaseUrl(pressReleases[0].slug)}>
                {pressReleases[0].title}
              </a>
            </p>
            <p class="detail-line">{siteConfig.date.formatLong(pressReleases[0].date)}</p>
            <p><a class="inline-link" href={getPressReleaseIndexUrl()}>Alle Pressemitteilungen</a></p>
          </>
        ) : (
          <p>Der Pressebereich ist angebunden und kann inhaltlich weiter ausgebaut werden.</p>
        )}
      </article>
      <article class="panel">
        <h3>Service & Karriere</h3>
        {jobOffers[0] ? (
          <>
            <p>
              <a class="inline-link" href={getJobUrl(jobOffers[0].slug)}>
                {jobOffers[0].title}
              </a>
            </p>
            <p class="detail-line">
              Bewerbungsfrist: {siteConfig.date.formatLong(jobOffers[0].applicationDeadline)}
            </p>
            <p><a class="inline-link" href={getCareerUrl()}>Zur Karriere</a></p>
          </>
        ) : (
          <p>
            Der Karrierebereich ist vorbereitet und kann mit weiteren Stellenangeboten ergänzt
            werden.
          </p>
        )}
      </article>
      <article class="panel">
        <h3>Recht</h3>
        {latestNorms[0] ? (
          <>
            <p>
              <a class="inline-link" href={getNormUrl(latestNorms[0].meta.slug)}>
                {latestNorms[0].meta.title}
              </a>
            </p>
            <p class="detail-line">
              Aktuelle Fassung seit {siteConfig.date.formatLong(getCurrentVersion(latestNorms[0]).validFrom)}
            </p>
            <p><a class="inline-link" href={getLawHomeUrl()}>Zum Rechtsbereich</a></p>
          </>
        ) : (
          <p>
            Die Rechtsportal-Logik bleibt vollständig erhalten und ist weiterhin such- und
            zitierbar.
          </p>
        )}
      </article>
    </div>
  </section>
</BaseLayout>
