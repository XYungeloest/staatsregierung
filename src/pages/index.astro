---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import {
  formatDate,
  getCurrentVersion,
  getIndexUrl,
  getNormUrl,
  getSearchUrl,
  getSubjectGroups,
  getSubjectsUrl,
  loadAllNorms,
  toDisplayText,
} from '../lib/norms/index.ts';

const base = import.meta.env.BASE_URL;

const norms = await loadAllNorms();
const subjectGroups = getSubjectGroups(norms);
const recentNorms = [...norms]
  .sort((left, right) => getCurrentVersion(right).validFrom.localeCompare(getCurrentVersion(left).validFrom))
  .slice(0, 3);
---

<BaseLayout
  title="Ostrecht-Portal"
  description="Statisches Rechtsportal des Freistaats Ostdeutschland innerhalb einer politischen Simulation."
>
  <Breadcrumbs items={[{ label: 'Start' }]} />

  <section class="hero">
    <p class="eyebrow">Rechtsinformationssystem</p>
    <h1>Ostrecht-Portal</h1>
    <p class="lead">
      Das Portal bildet aktuelle Fassungen, historische Fassungen und Normenhistorien des Freistaats
      Ostdeutschland in einer rein statisch generierten Website ab.
    </p>
    <div class="meta-grid" aria-label="Projektstatus">
      <div class="meta-card">
        <span class="meta-label">Normenbestand</span>
        <strong>{norms.length} Normen</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Sachgebiete</span>
        <strong>{subjectGroups.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Ausgabe</span>
        <strong>statisch</strong>
      </div>
    </div>
    <nav class="hero-actions" aria-label="Schnelleinstiege">
      <a class="button-link" href={getSearchUrl()}>Zur Suche</a>
      <a class="button-link button-link--secondary" href={getIndexUrl()}>Zum Index</a>
      <a class="button-link button-link--secondary" href={getSubjectsUrl()}>Zu den Sachgebieten</a>
    </nav>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Einstiege</h2>
      <p>
        Der Einstieg erfolgt über aktuelle Fassungen, die clientseitige Suche, den alphabetischen
        Index und die Sachgebietsseiten.
      </p>
    </div>

    <div class="card-grid">
      <article class="panel">
        <h3>Suche</h3>
        <p>Clientseitige Volltext- und Metadatensuche über aktuelle und historische Fassungen.</p>
        <p><a class="inline-link" href={getSearchUrl()}>Zur Suche</a></p>
      </article>
      <article class="panel">
        <h3>Alphabetischer Index</h3>
        <p>Alle Normen alphabetisch mit direktem Einstieg in die aktuelle Fassung.</p>
        <p><a class="inline-link" href={`${base}index/`}>Zum Index</a></p>
      </article>
      <article class="panel">
        <h3>Sachgebiete</h3>
        <p>Übersicht über alle geführten Sachgebiete und zugeordnete Normen.</p>
        <p><a class="inline-link" href={`${base}subjects/`}>Zu den Sachgebieten</a></p>
      </article>
      <article class="panel">
        <h3>Portalhinweis</h3>
        <p>Dieses Rechtsportal ist Teil einer politischen Simulation und bildet fiktive, aber plausibel gestaltete Normdaten ab.</p>
      </article>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Letzte Fassungen</h2>
      <p>
        Die folgenden aktuellen Fassungen sind nach ihrem Geltungsbeginn sortiert.
      </p>
    </div>
    <div class="card-grid">
      {recentNorms.map((norm) => {
        const currentVersion = getCurrentVersion(norm);

        return (
          <article class="panel">
            <h3><a class="inline-link" href={getNormUrl(norm.meta.slug)}>{toDisplayText(norm.meta.title)}</a></h3>
            <p>{toDisplayText(norm.meta.summary)}</p>
            <p class="detail-line">Rechtsstand seit {formatDate(currentVersion.validFrom)}</p>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
