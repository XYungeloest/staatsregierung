---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import StudioNav from '../../../components/editorial/StudioNav.astro';
import { getDatabase, getRuntimeBindingState } from '../../../lib/dynamic/env.ts';
import { getEditorialAccessInfo } from '../../../lib/editorial/access.ts';
import { listMediaAssets } from '../../../lib/editorial/repository.ts';
import { buildMediaUrl } from '../../../lib/dynamic/media.ts';
import { getEditorialUrl, getHomeUrl, withBase } from '../../../lib/portal/routes.ts';

const accessInfo = getEditorialAccessInfo(Astro.request, Astro.url);
const runtime = getRuntimeBindingState(Astro.url);
const database = runtime.hasDatabase ? getDatabase() : undefined;
const mediaAssets = database ? await listMediaAssets(database) : [];
const errorMessage = Astro.url.searchParams.get('error') ?? undefined;
const message = Astro.url.searchParams.get('message') ?? undefined;
---

<BaseLayout
  title="Redaktionsmedien"
  description="Upload und Referenzierung von Medienobjekten in Cloudflare R2 für das Redaktionsstudio."
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Redaktion', href: getEditorialUrl() },
    { label: 'Medien' },
  ]}
  noindex={true}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Redaktion', href: getEditorialUrl() },
      { label: 'Medien' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">R2-Medien</p>
    <h1>Medienverwaltung</h1>
    <p class="lead">
      Uploads landen direkt im gebundenen R2-Bucket und werden zusätzlich mit Alt-Text, Titel und
      optionalem Credit in D1 referenziert.
    </p>
    <p class="detail-line">
      Bearbeiter: {accessInfo.displayName}
      {' · '}
      Umgebung: {runtime.environment}
      {' · '}
      R2: {runtime.hasMediaBucket ? 'aktiv' : 'fehlt'}
    </p>
  </section>

  <section class="section">
    <StudioNav current="media" />
  </section>

  {message ? (
    <section class="section">
      <div class="editorial-feedback editorial-feedback--success">{message}</div>
    </section>
  ) : null}
  {errorMessage ? (
    <section class="section">
      <div class="editorial-feedback editorial-feedback--error">{errorMessage}</div>
    </section>
  ) : null}

  <section class="section studio-workspace">
    <div class="studio-workspace__main">
      <div class="section-header">
        <h2>Neues Medium hochladen</h2>
        <p>Einfacher Upload für Bilder und Dokumente. Die erzeugte <code>mediaKey</code> kann danach in Redaktionsformularen verwendet werden.</p>
      </div>

      <form
        class="editorial-form studio-form"
        method="post"
        enctype="multipart/form-data"
        action={withBase('/redaktion/api/medien/upload')}
      >
        <div class="editorial-grid editorial-grid--two">
          <label class="search-field editorial-grid__full">
            <span>Datei</span>
            <input type="file" name="file" required />
          </label>
          <label class="search-field">
            <span>Titel</span>
            <input type="text" name="title" />
          </label>
          <label class="search-field">
            <span>Alt-Text</span>
            <input type="text" name="altText" required />
          </label>
          <label class="search-field">
            <span>Credit</span>
            <input type="text" name="credit" />
          </label>
        </div>
        <div class="editorial-actions">
          <button class="button-link" type="submit">Medium hochladen</button>
        </div>
      </form>
    </div>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Hinweis</h2>
      </div>
      <p>
        Für Produktion und Staging sollte auch der Zugriff auf <code>/redaktion/medien/</code>
        ausschließlich über Cloudflare Access erfolgen.
      </p>
      <p>
        Uploads landen immer im R2-Bucket der aktuell angezeigten Umgebung. Prüfen Sie diese
        Anzeige vor jedem Remote-Test.
      </p>
    </aside>
  </section>

  <section class="section section-muted">
      <div class="section-header">
        <h2>Bereits verfügbare Medien</h2>
        <p>Referenzieren Sie diese Keys in den Feldern <code>mediaKey</code> der Redaktionsformulare.</p>
      </div>
      <form class="search-form" data-role="media-library-filter">
        <label class="search-field">
          <span>Filter</span>
          <input type="search" name="query" placeholder="Titel, Key oder Alt-Text filtern" />
        </label>
      </form>
      {mediaAssets.length > 0 ? (
        <div class="studio-table-wrapper">
          <table class="studio-table">
          <thead>
            <tr>
              <th>Titel</th>
              <th>mediaKey</th>
              <th>Alt-Text</th>
              <th>Vorschau</th>
            </tr>
          </thead>
          <tbody>
            {mediaAssets.map((asset) => (
              <tr
                data-media-row
                data-media-search={`${asset.title} ${asset.key} ${asset.altText} ${asset.credit ?? ''}`.toLowerCase()}
              >
                <td>
                  <strong>{asset.title}</strong>
                  <br />
                  <span>{asset.credit ?? 'ohne Credit'}</span>
                </td>
                <td><code>{asset.key}</code></td>
                <td>{asset.altText}</td>
                <td>
                  <a class="inline-link" href={buildMediaUrl(asset.key)} target="_blank" rel="noreferrer">
                    öffnen
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <p>Der R2-Bestand ist derzeit leer.</p>
    )}
  </section>

  <script is:inline>
    document.querySelectorAll('[data-role="media-library-filter"]').forEach((form) => {
      const input = form.querySelector('input[name="query"]');
      if (!(input instanceof HTMLInputElement)) return;

      input.addEventListener('input', () => {
        const query = input.value.trim().toLowerCase();
        document.querySelectorAll('[data-media-row]').forEach((row) => {
          const haystack = row.getAttribute('data-media-search') || '';
          row.toggleAttribute('hidden', query.length > 0 && !haystack.includes(query));
        });
      });
    });
  </script>
</BaseLayout>
