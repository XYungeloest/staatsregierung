---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import StudioNav from '../../../components/editorial/StudioNav.astro';
import StatusBadge from '../../../components/editorial/StatusBadge.astro';
import { getDatabase } from '../../../lib/dynamic/env.ts';
import { listEditorialEntries } from '../../../lib/editorial/repository.ts';
import { getEditorialTypeDefinition } from '../../../lib/editorial/studio.ts';
import { getEditorialUrl, getHomeUrl } from '../../../lib/portal/routes.ts';

const allEntries = await listEditorialEntries(getDatabase());
const entries = allEntries.filter(
  (entry) =>
    entry.status === 'draft' ||
    entry.status === 'export_ready' ||
    Boolean(
      entry.publishedVersionId &&
        entry.currentVersionId &&
        entry.currentVersionId !== entry.publishedVersionId,
    ),
);
---

<BaseLayout
  title="Entwürfe und offene Stände"
  description="Aktuelle Entwürfe, nicht live geschaltete Inhalte und offene Änderungen."
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Redaktion', href: getEditorialUrl() },
    { label: 'Offene Stände' },
  ]}
  noindex={true}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Redaktion', href: getEditorialUrl() },
      { label: 'Offene Stände' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Arbeitsstände</p>
    <h1>Entwürfe und offene Stände</h1>
    <p class="lead">
      Diese Ansicht bündelt Entwürfe sowie bereits live geschaltete Einträge mit weiteren, noch
      nicht veröffentlichten Änderungen.
    </p>
  </section>

  <section class="section">
    <StudioNav current="drafts" />
  </section>

  <section class="section">
    {entries.length > 0 ? (
      <ul class="record-list">
        {entries.map((entry) => (
          <li class="record-list__item studio-record">
            <strong>
              <a class="inline-link" href={`${getEditorialUrl()}inhalte/${entry.type}/${entry.id}/`}>
                {entry.title}
              </a>
            </strong>
            <span>{getEditorialTypeDefinition(entry.type).label}</span>
            <span><StatusBadge status={entry.status} /></span>
            <span>Version {entry.currentVersionNumber}</span>
            {entry.publishedVersionId && entry.currentVersionId !== entry.publishedVersionId ? (
              <span>Live-Override aktiv, Entwurf offen</span>
            ) : null}
          </li>
        ))}
      </ul>
    ) : (
      <div class="status-notice status-notice--current">
        <h2>Keine offenen Entwürfe</h2>
        <p>Derzeit liegen keine offenen Entwürfe oder ausstehenden Änderungen in D1 vor.</p>
      </div>
    )}
  </section>
</BaseLayout>
