---
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { featureFlags, isEditorialToolsEnabled } from '../../../config/features.ts';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  formatNormStatus,
  formatNormType,
  getEditorialUrl,
  getHomeUrl,
  NORM_STATUSES,
  NORM_TYPES,
} from '../../../lib/norms/index.ts';
import { loadAllNorms } from '../../../lib/norms/content.ts';

const editorialEnabled = isEditorialToolsEnabled();
const existingNorms = editorialEnabled ? await loadAllNorms() : [];

const bootstrapData = {
  norms: existingNorms.map((record) => ({
    meta: record.meta,
    history: record.history,
    versions: record.versions,
  })),
};

function serializeForScript(value: unknown): string {
  return JSON.stringify(value).replace(/</g, '\\u003c');
}
---

<BaseLayout
  title="Rechtswerkzeug"
  description="Clientseitige Werkzeuge zum Erzeugen neuer Normdateien und neuer Fassungen für die manuelle Übernahme ins Repository."
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Redaktion', href: getEditorialUrl() },
    { label: 'Rechtswerkzeug' },
  ]}
  noindex={true}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Redaktion', href: getEditorialUrl() },
      { label: 'Rechtswerkzeug' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Rechtsredaktion</p>
    <h1>Werkzeug für Normdateien</h1>
    <p class="lead">
      Dieses Werkzeug erzeugt aus Eingaben neue JSON-Dateien im bestehenden Content-Format. Die
      Seite bleibt vollständig dateibasiert und speichert auch auf der neuen Cloudflare-Zielplattform
      nichts serverseitig.
    </p>
    <p class="status-line">
      Feature-Flag: <strong>{featureFlags.enableEditorialTools ? 'aktiviert' : 'deaktiviert'}</strong>
    </p>
  </section>

  {!editorialEnabled ? (
    <section class="section section-muted editorial-disabled">
      <div class="section-header">
        <h2>Werkzeug derzeit deaktiviert</h2>
        <p>
          Die Redaktionsmaske ist per zentraler Konfiguration ausgeschaltet. Setzen Sie
          <code>enableEditorialTools</code> in <code>src/config/features.ts</code> auf
          <code>true</code>, um die Eingabeseite zu aktivieren.
        </p>
      </div>
    </section>
  ) : (
    <Fragment>
      <section class="section editorial-shell" data-editorial-root>
        <div class="section-header">
          <h2>Arbeitsmodus</h2>
          <p>
            Wählen Sie, ob eine neue Norm mit erster Fassung oder eine neue Fassung zu einer
            bestehenden Norm erzeugt werden soll.
          </p>
        </div>

        <div class="editorial-mode-switch" role="radiogroup" aria-label="Redaktionsmodus">
          <label class="editorial-choice">
            <input type="radio" name="editorial-mode" value="new-norm" checked data-editorial-mode />
            <span>Neue Norm anlegen</span>
          </label>
          <label class="editorial-choice">
            <input type="radio" name="editorial-mode" value="new-version" data-editorial-mode />
            <span>Neue Fassung bestehender Norm anlegen</span>
          </label>
        </div>

        <div class="editorial-feedback" aria-live="polite" data-editorial-feedback>
          Die Eingabemaske ist bereit. Änderungen bleiben lokal im Browser, bis Sie JSON-Dateien
          kopieren oder herunterladen.
        </div>

        <section class="editorial-panel" data-editorial-panel="new-norm">
          <div class="section-header section-header--compact">
            <h2>Neue Norm</h2>
            <p>
              Es werden <code>meta.json</code>, <code>history.json</code> und die erste
              Versionsdatei erzeugt.
            </p>
          </div>

          <form class="editorial-form" data-editorial-form="new-norm">
            <div class="editorial-grid editorial-grid--two">
              <label class="search-field">
                <span>ID</span>
                <input type="text" name="id" required placeholder="z. B. ost-schulordnung" />
              </label>
              <label class="search-field">
                <span>Slug</span>
                <input type="text" name="slug" required placeholder="z. B. schulordnung" />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Amtlicher Titel</span>
                <input
                  type="text"
                  name="title"
                  required
                  placeholder="z. B. Schulordnung des Freistaates Ostdeutschland"
                />
              </label>
              <label class="search-field">
                <span>Kurztitel</span>
                <input type="text" name="shortTitle" required placeholder="z. B. Schulordnung" />
              </label>
              <label class="search-field">
                <span>Abkürzung</span>
                <input type="text" name="abbr" required placeholder="z. B. SchulO" />
              </label>
              <label class="search-field">
                <span>Normtyp</span>
                <select name="type" required>
                  {NORM_TYPES.map((type) => (
                    <option value={type}>{formatNormType(type)}</option>
                  ))}
                </select>
              </label>
              <label class="search-field">
                <span>Status</span>
                <select name="status" required>
                  {NORM_STATUSES.map((status) => (
                    <option value={status}>{formatNormStatus(status)}</option>
                  ))}
                </select>
              </label>
              <label class="search-field editorial-grid__full">
                <span>Ressort</span>
                <input
                  type="text"
                  name="ministry"
                  required
                  placeholder="z. B. Staatsministerium für Bildung und Kultur"
                />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Sachgebiete</span>
                <input type="text" name="subjectsText" required placeholder="Bildung, Schulrecht" />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Schlagwörter</span>
                <input type="text" name="keywordsText" required placeholder="Schule, Unterricht, Ordnung" />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Stammfundstelle</span>
                <input
                  type="text"
                  name="initialCitation"
                  required
                  placeholder="z. B. OGVBl. 2026 Nr. 12"
                />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Kurzbeschreibung</span>
                <textarea
                  name="summary"
                  rows="3"
                  required
                  placeholder="Kurze redaktionelle Zusammenfassung der Norm."
                ></textarea>
              </label>
            </div>

            <div class="section-header section-header--compact">
              <h3>Erste Fassung</h3>
              <p>Die erste Fassung wird automatisch als Stammfassung in die Historie aufgenommen.</p>
            </div>

            <div class="editorial-grid editorial-grid--two">
              <label class="search-field">
                <span>versionId</span>
                <input type="text" name="versionId" required placeholder="2026-09-01" />
              </label>
              <label class="search-field">
                <span>Gültig ab</span>
                <input type="date" name="validFrom" required />
              </label>
              <label class="search-field">
                <span>Gültig bis</span>
                <input type="date" name="validTo" />
              </label>
              <label class="editorial-checkbox">
                <input type="checkbox" name="isCurrent" checked />
                <span>Als aktuelle Fassung anlegen</span>
              </label>
              <label class="search-field editorial-grid__full">
                <span>Fundstelle der Fassung</span>
                <input type="text" name="citation" required placeholder="z. B. OGVBl. 2026 Nr. 12" />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Änderungshinweis</span>
                <input type="text" name="changeNote" required placeholder="z. B. Stammfassung." />
              </label>
            </div>

            <div class="section-header section-header--compact">
              <h3>Strukturierter Norminhalt</h3>
              <p>
                Der Norminhalt wird als JSON-Array im bestehenden <code>body</code>-Format erfasst.
              </p>
            </div>

            <div class="editorial-actions">
              <button class="button-link button-link--secondary" type="button" data-editorial-template="new-norm-law">
                Gesetzesvorlage einsetzen
              </button>
              <button class="button-link button-link--secondary" type="button" data-editorial-template="new-norm-directive">
                Richtlinienvorlage einsetzen
              </button>
              <button class="button-link button-link--secondary" type="button" data-editorial-template="new-norm-empty">
                Leere Liste einsetzen
              </button>
            </div>

            <label class="search-field">
              <span>Norminhalt (JSON)</span>
              <textarea
                name="bodyText"
                rows="16"
                required
                placeholder='[
  {
    "type": "section",
    "label": "Abschnitt 1",
    "title": "Allgemeine Bestimmungen",
    "children": []
  }
]'
              ></textarea>
            </label>

            <details class="editorial-help">
              <summary>Beispiel und Hinweise zum body-Format</summary>
              <p>
                Zulässige Blocktypen sind unter anderem <code>section</code>, <code>paragraph</code>,
                <code>article</code>, <code>paragraphText</code>, <code>item</code> und
                <code>subitem</code>. Die Maske verwendet dieselbe Validierung wie der Build.
              </p>
            </details>

            <div class="editorial-actions">
              <button class="button-link" type="submit">JSON-Dateien erzeugen</button>
              <button class="button-link button-link--secondary" type="reset">Formular zurücksetzen</button>
            </div>
          </form>
        </section>

        <section class="editorial-panel" data-editorial-panel="new-version" hidden>
          <div class="section-header section-header--compact">
            <h2>Neue Fassung einer bestehenden Norm</h2>
            <p>
              Erzeugt mindestens eine neue Versionsdatei; bei aktueller Fassung zusätzlich eine
              aktualisierte Vorgängerfassung und auf Wunsch eine neue <code>history.json</code>.
            </p>
          </div>

          <form class="editorial-form" data-editorial-form="new-version">
            <div class="editorial-grid editorial-grid--two">
              <label class="search-field editorial-grid__full">
                <span>Bestehende Norm</span>
                <select name="normSlug" required data-editorial-existing-norm>
                  <option value="">Bitte wählen</option>
                  {existingNorms.map((record) => (
                    <option value={record.meta.slug}>
                      {record.meta.title} ({record.meta.abbr})
                    </option>
                  ))}
                </select>
              </label>
              <div class="editorial-summary-card editorial-grid__full" data-editorial-existing-summary>
                Wählen Sie eine bestehende Norm, um die vorhandenen Fassungen anzuzeigen.
              </div>
              <label class="search-field">
                <span>versionId</span>
                <input type="text" name="versionId" required placeholder="2026-10-01" />
              </label>
              <label class="search-field">
                <span>Gültig ab</span>
                <input type="date" name="validFrom" required />
              </label>
              <label class="search-field">
                <span>Gültig bis</span>
                <input type="date" name="validTo" />
              </label>
              <label class="editorial-checkbox">
                <input type="checkbox" name="isCurrent" checked />
                <span>Als aktuelle Fassung anlegen</span>
              </label>
              <label class="search-field editorial-grid__full">
                <span>Fundstelle der Fassung</span>
                <input type="text" name="citation" required placeholder="z. B. OGVBl. 2026 Nr. 33" />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Änderungshinweis</span>
                <input type="text" name="changeNote" required placeholder="z. B. § 3 neu gefasst." />
              </label>
            </div>

            <div class="editorial-actions">
              <button class="button-link button-link--secondary" type="button" data-editorial-template="existing-current">
                Aktuelle Fassung als Vorlage übernehmen
              </button>
              <button class="button-link button-link--secondary" type="button" data-editorial-template="existing-law">
                Gesetzesvorlage einsetzen
              </button>
              <button class="button-link button-link--secondary" type="button" data-editorial-template="existing-directive">
                Richtlinienvorlage einsetzen
              </button>
            </div>

            <label class="search-field">
              <span>Norminhalt (JSON)</span>
              <textarea
                name="bodyText"
                rows="16"
                required
                placeholder='[
  {
    "type": "section",
    "label": "Abschnitt 1",
    "title": "Allgemeine Bestimmungen",
    "children": []
  }
]'
              ></textarea>
            </label>

            <div class="editorial-grid editorial-grid--two">
              <label class="editorial-checkbox editorial-grid__full">
                <input type="checkbox" name="createHistoryEntry" checked />
                <span>Aktualisierte Historie mit neuem Historieneintrag erzeugen</span>
              </label>
              <label class="search-field editorial-grid__full">
                <span>Titel des Historieneintrags</span>
                <input
                  type="text"
                  name="historyTitle"
                  placeholder="z. B. Geändert durch Gesetz vom 1. Oktober 2026"
                />
              </label>
              <label class="search-field editorial-grid__full">
                <span>Hinweis zum Historieneintrag</span>
                <textarea
                  name="historyNote"
                  rows="3"
                  placeholder="Optionaler erläuternder Hinweis zur Änderung."
                ></textarea>
              </label>
            </div>

            <div class="editorial-actions">
              <button class="button-link" type="submit">JSON-Dateien erzeugen</button>
              <button class="button-link button-link--secondary" type="reset">Formular zurücksetzen</button>
            </div>
          </form>
        </section>

        <section class="editorial-panel" data-editorial-output hidden>
          <div class="section-header section-header--compact">
            <h2>Vorschau und Export</h2>
            <p data-editorial-output-summary>
              Hier erscheinen nach erfolgreicher Validierung die erzeugten JSON-Dateien.
            </p>
          </div>
          <div class="editorial-file-list" data-editorial-file-list></div>
        </section>
      </section>

      <script
        id="editorial-bootstrap"
        type="application/json"
        is:inline
        set:html={serializeForScript(bootstrapData)}
      ></script>
      <script src="../../../scripts/editorial-page.ts"></script>
    </Fragment>
  )}
</BaseLayout>
