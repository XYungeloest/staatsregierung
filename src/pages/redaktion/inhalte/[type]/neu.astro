---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import EntryEditorForm from '../../../../components/editorial/EntryEditorForm.astro';
import EntryPreview from '../../../../components/editorial/EntryPreview.astro';
import StudioNav from '../../../../components/editorial/StudioNav.astro';
import { getDatabase } from '../../../../lib/dynamic/env.ts';
import { getEditorialAccessInfo } from '../../../../lib/editorial/access.ts';
import { buildEditorialFormValues, createBlankEditorialDraft, getEditorialPreviewRoute } from '../../../../lib/editorial/drafts.ts';
import { getEditorialEntryByTypeAndSlug } from '../../../../lib/editorial/repository.ts';
import { getEditorialSourceDraft } from '../../../../lib/editorial/sources.ts';
import { getEditorialStoragePath, getEditorialTypeDefinition, isEditorialEntryType } from '../../../../lib/editorial/studio.ts';
import { getEditorialUrl, getHomeUrl, withBase } from '../../../../lib/portal/routes.ts';

const typeParam = Astro.params.type;

if (!isEditorialEntryType(typeParam)) {
  Astro.response.status = 404;
}

const type = typeParam && isEditorialEntryType(typeParam) ? typeParam : undefined;
const definition = type ? getEditorialTypeDefinition(type) : undefined;
const accessInfo = getEditorialAccessInfo(Astro.request);
const sourceId = Astro.url.searchParams.get('source') ?? undefined;
const sourceOrigin = Astro.url.searchParams.get('origin');
const errorMessage = Astro.url.searchParams.get('error') ?? undefined;
const message = Astro.url.searchParams.get('message') ?? undefined;

const sourceDraft =
  type && sourceId && (sourceOrigin === 'd1' || sourceOrigin === 'file')
    ? await getEditorialSourceDraft(getDatabase(), type, sourceOrigin, sourceId)
    : undefined;

const existingConflict =
  type && sourceDraft ? await getEditorialEntryByTypeAndSlug(getDatabase(), type, sourceDraft.slug) : undefined;

const currentDraft = type ? sourceDraft ?? createBlankEditorialDraft(type) : undefined;
const formValues = currentDraft ? buildEditorialFormValues(currentDraft) : undefined;
const previewRoute =
  currentDraft && type
    ? getEditorialPreviewRoute(type, currentDraft.slug, currentDraft.route)
    : undefined;
const exportPath =
  currentDraft && type ? getEditorialStoragePath(type, currentDraft.slug) : undefined;
---

<BaseLayout
  title={definition ? `${definition.label} neu anlegen` : 'Inhaltstyp nicht gefunden'}
  description={definition?.description ?? 'Der angeforderte Inhaltstyp wird im Redaktionsstudio nicht unterstützt.'}
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Redaktion', href: getEditorialUrl() },
    { label: 'Inhalte', href: `${getEditorialUrl()}inhalte/` },
    { label: definition?.pluralLabel ?? 'Unbekannter Typ', href: type ? `${getEditorialUrl()}inhalte/${type}/` : undefined },
    { label: 'Neu' },
  ]}
  noindex={true}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Redaktion', href: getEditorialUrl() },
      { label: 'Inhalte', href: `${getEditorialUrl()}inhalte/` },
      { label: definition?.pluralLabel ?? 'Unbekannter Typ', href: type ? `${getEditorialUrl()}inhalte/${type}/` : undefined },
      { label: 'Neu' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Neuer Entwurf</p>
    <h1>{definition ? `${definition.label} anlegen` : 'Inhaltstyp nicht gefunden'}</h1>
    <p class="lead">
      {definition
        ? 'Neue Inhalte können manuell oder auf Basis bestehender Portalquellen erfasst werden.'
        : 'Bitte öffnen Sie einen unterstützten Inhaltstyp aus der Studio-Übersicht.'}
    </p>
  </section>

  <section class="section">
    <StudioNav current="content" />
  </section>

  {message ? (
    <section class="section">
      <div class="editorial-feedback editorial-feedback--success">{message}</div>
    </section>
  ) : null}

  {type && definition && currentDraft && formValues ? (
    existingConflict ? (
      <section class="section">
        <div class="status-notice status-notice--warning">
          <h2>Ein Entwurf mit diesem Slug existiert bereits</h2>
          <p>
            Für die Quelle <strong>{currentDraft.title}</strong> liegt bereits ein Redaktionsstand
            vor. Öffnen Sie den bestehenden Entwurf, statt einen zweiten Datensatz mit demselben
            Slug anzulegen.
          </p>
          <p>
            <a class="inline-link" href={`${getEditorialUrl()}inhalte/${type}/${existingConflict.id}/`}>
              Zum bestehenden Entwurf
            </a>
          </p>
        </div>
      </section>
    ) : (
      <section class="section studio-workspace">
        <div class="studio-workspace__main">
          <EntryEditorForm
            type={type}
            values={formValues}
            accessInfo={accessInfo}
            saveAction={withBase(`/redaktion/api/inhalte/${type}/save`)}
            publishAction={withBase(`/redaktion/api/inhalte/${type}/publish`)}
            exportAction={withBase(`/redaktion/api/inhalte/${type}/export`)}
            liveUrl={previewRoute}
            errorMessage={errorMessage}
          />
        </div>
        <div class="studio-workspace__side">
          <EntryPreview
            type={type}
            title={currentDraft.title}
            slug={currentDraft.slug}
            route={previewRoute ?? currentDraft.route}
            status={currentDraft.status}
            content={currentDraft.content}
          />
          {sourceDraft ? (
            <section class="panel">
              <div class="section-header section-header--compact">
                <h2>Vorlage</h2>
              </div>
              <p>
                Ursprung: <strong>{sourceOrigin === 'd1' ? 'D1' : 'Datei'}</strong>
                {' · '}
                Quelle: <code>{sourceId}</code>
              </p>
              {exportPath ? <p>Späterer Exportpfad: <code>{exportPath}</code></p> : null}
            </section>
          ) : null}
        </div>
      </section>
    )
  ) : (
    <section class="section">
      <div class="status-notice status-notice--warning">
        <h2>Inhaltstyp nicht gefunden</h2>
        <p>Die angeforderte Redaktionsroute ist nicht definiert.</p>
      </div>
    </section>
  )}
</BaseLayout>
