---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import StudioNav from '../../../../components/editorial/StudioNav.astro';
import StatusBadge from '../../../../components/editorial/StatusBadge.astro';
import { getDatabase, getRuntimeBindingState } from '../../../../lib/dynamic/env.ts';
import { listEditorialEntries } from '../../../../lib/editorial/repository.ts';
import { listEditorialSources } from '../../../../lib/editorial/sources.ts';
import { getEditorialTypeDefinition, isEditorialEntryType } from '../../../../lib/editorial/studio.ts';
import { getEditorialUrl, getHomeUrl } from '../../../../lib/portal/routes.ts';

const typeParam = Astro.params.type;

if (!isEditorialEntryType(typeParam)) {
  Astro.response.status = 404;
}

const type = typeParam && isEditorialEntryType(typeParam) ? typeParam : undefined;
const definition = type ? getEditorialTypeDefinition(type) : undefined;
const runtime = getRuntimeBindingState(Astro.url);
const database = getDatabase();
const entries = type ? await listEditorialEntries(database, { type }) : [];
const sources = type ? await listEditorialSources(database, type) : [];
const entryBySlug = new Map(entries.map((entry) => [entry.slug, entry]));
---

<BaseLayout
  title={definition ? `${definition.pluralLabel} bearbeiten` : 'Inhaltstyp nicht gefunden'}
  description={definition?.description ?? 'Der angeforderte Inhaltstyp wird im Redaktionsstudio nicht unterstützt.'}
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Redaktion', href: getEditorialUrl() },
    { label: 'Inhalte', href: `${getEditorialUrl()}inhalte/` },
    { label: definition?.pluralLabel ?? 'Unbekannter Typ' },
  ]}
  noindex={true}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Redaktion', href: getEditorialUrl() },
      { label: 'Inhalte', href: `${getEditorialUrl()}inhalte/` },
      { label: definition?.pluralLabel ?? 'Unbekannter Typ' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Redaktionsbereich</p>
    <h1>{definition?.pluralLabel ?? 'Inhaltstyp nicht gefunden'}</h1>
    <p class="lead">
      {definition?.description ??
        'Bitte öffnen Sie einen unterstützten Inhaltstyp aus der Übersicht des Redaktionsstudios.'}
    </p>
    <p class="detail-line">Umgebung: {runtime.environment}</p>
  </section>

  <section class="section">
    <StudioNav current="content" />
  </section>

  {type && definition ? (
    <Fragment>
      <section class="section section-muted">
        <div class="section-header">
          <h2>Arbeitsstände</h2>
          <p>Vorhandene Entwürfe und veröffentlichte Redaktionsstände für diesen Inhaltstyp.</p>
        </div>
        <p class="section-link-row">
          <a class="button-link" href={`${getEditorialUrl()}inhalte/${type}/neu`}>Neuen Eintrag anlegen</a>
        </p>
        {entries.length > 0 ? (
          <ul class="record-list">
            {entries.map((entry) => (
              <li class="record-list__item studio-record">
                <strong>
                  <a class="inline-link" href={`${getEditorialUrl()}inhalte/${type}/${entry.id}/`}>
                    {entry.title}
                  </a>
                </strong>
                <span>{entry.slug}</span>
                <span><StatusBadge status={entry.status} /></span>
                <span>Version {entry.currentVersionNumber}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p>Für diesen Typ liegen noch keine Redaktionsstände in D1 vor.</p>
        )}
      </section>

      <section class="section">
        <div class="section-header">
          <h2>Bestehende Quellen</h2>
          <p>
            Vorhandene Inhalte aus D1 oder aus den dateibasierten JSON-Beständen können als Vorlage
            in einen bearbeitbaren Entwurf übernommen werden.
          </p>
        </div>
        {sources.length > 0 ? (
          <ul class="record-list">
            {sources.map((source) => {
              const existingEntry = entryBySlug.get(source.slug);
              const href = existingEntry
                ? `${getEditorialUrl()}inhalte/${type}/${existingEntry.id}/`
                : `${getEditorialUrl()}inhalte/${type}/neu?source=${encodeURIComponent(source.id)}&origin=${encodeURIComponent(source.sourceOrigin)}`;

              return (
                <li class="record-list__item studio-record">
                  <strong><a class="inline-link" href={href}>{source.title}</a></strong>
                  <span>{source.slug}</span>
                  <span>{source.description ?? (source.sourceOrigin === 'd1' ? 'D1-Quelle' : 'Datei-Quelle')}</span>
                  <span>{existingEntry ? 'bereits als Entwurf vorhanden' : 'als Vorlage öffnen'}</span>
                </li>
              );
            })}
          </ul>
        ) : (
          <p>Für diesen Typ konnten derzeit keine bestehenden Quellen geladen werden.</p>
        )}
      </section>
    </Fragment>
  ) : (
    <section class="section">
      <div class="status-notice status-notice--warning">
        <h2>Inhaltstyp nicht gefunden</h2>
        <p>Die angeforderte Redaktionsroute ist nicht definiert.</p>
      </div>
    </section>
  )}
</BaseLayout>
