---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getHomeUrl, getPressUrl } from '../../../lib/portal/index.ts';
---

<BaseLayout title="Reden" description="Vorbereitete Struktur für Reden im Pressebereich.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Presse', href: getPressUrl() },
      { label: 'Reden' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Presse & Aktuelles</p>
    <h1>Reden</h1>
    <p class="lead">
      Die Routenhülle für Reden ist bereits Teil der Master-Architektur. Redaktionelle Inhalte
      folgen in einer späteren Phase.
    </p>
  </section>
</BaseLayout>
