---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SpeechCard from '../../../components/portal/SpeechCard.astro';
import {
  getEventIndexUrl,
  getHomeUrl,
  getPressUrl,
  loadSpeeches,
} from '../../../lib/portal/index.ts';

const speeches = await loadSpeeches();
const leadSpeech = speeches[0];
const remainingSpeeches = speeches.slice(1);
---

<BaseLayout title="Reden & Regierungserklärungen" description="Reden und Regierungserklärungen der Staatsregierung.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Presse & Aktuelles', href: getPressUrl() },
      { label: 'Reden & Regierungserklärungen' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Presse & Aktuelles</p>
    <h1>Reden & Regierungserklärungen</h1>
    <p class="lead">
      Hier werden programmatische Reden, Regierungserklärungen und politische Grundsatztexte der
      Staatsregierung in geordneter Form bereitgestellt.
    </p>
  </section>

  {leadSpeech ? (
    <section class="section section-muted">
      <div class="section-header">
        <h2>Aktuelle Rede</h2>
      </div>
      <SpeechCard speech={leadSpeech} />
    </section>
  ) : null}

  <section class="section">
    <div class="section-header">
      <h2>Archiv</h2>
      <p>Alle Reden und Regierungserklärungen bleiben mit Datum und Sprecherangabe dauerhaft erreichbar.</p>
    </div>
    <div class="content-stack">
      {(remainingSpeeches.length > 0 ? remainingSpeeches : speeches).map((speech) => (
        <SpeechCard speech={speech} />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getEventIndexUrl()}>Weiter zu den Terminen</a>
    </p>
  </section>
</BaseLayout>
