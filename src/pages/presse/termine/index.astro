---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import EventCard from '../../../components/portal/EventCard.astro';
import { loadEvents } from '../../../lib/portal/content.ts';
import {
  getEventIndexUrl,
  getHomeUrl,
  getPressUrl,
} from '../../../lib/portal/index.ts';

const events = await loadEvents();
---

<BaseLayout title="Termine" description="Öffentliche Termine und Presseveranstaltungen der Staatsregierung.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Presse & Aktuelles', href: getPressUrl() },
      { label: 'Termine' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Presse & Aktuelles</p>
    <h1>Termine</h1>
    <p class="lead">
      Öffentliche Termine, Pressekonferenzen und thematische Veranstaltungen der Staatsregierung
      werden hier in einer schlichten, gut geordneten Übersicht gebündelt.
    </p>
    <nav class="hero-actions" aria-label="Terminangebote">
      <a class="button-link button-link--secondary" href={`${getEventIndexUrl()}kalender.ics`}>
        Kalender abonnieren
      </a>
    </nav>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Anstehende Termine</h2>
      <p>Ort, Datum und Kurzbeschreibung werden für jeden Termin in einer eigenen Detailseite bereitgestellt.</p>
    </div>
    <div class="content-stack">
      {events.map((event) => (
        <EventCard event={event} />
      ))}
    </div>
  </section>
</BaseLayout>
