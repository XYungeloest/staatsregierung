---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getHomeUrl, getPressReleaseIndexUrl } from '../../lib/portal/index.ts';
---

<BaseLayout title="Presse & Aktuelles" description="Pressebereich der Staatsregierung des Ostdeutschen Freistaates.">
  <Breadcrumbs items={[{ label: 'Startseite', href: getHomeUrl() }, { label: 'Presse' }]} />

  <section class="section page-header">
    <p class="eyebrow">Presse & Aktuelles</p>
    <h1>Presse & Aktuelles</h1>
    <p class="lead">
      Der Pressebereich führt Mitteilungen, später auch Reden und Termine, unter einer
      gemeinsamen Struktur zusammen.
    </p>
  </section>

  <section class="section">
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h2>Pressemitteilungen</h2>
        <p>Bereits angebundener redaktioneller Bestand mit stabilen Detailseiten.</p>
        <p><a class="inline-link" href={getPressReleaseIndexUrl()}>Zu den Pressemitteilungen</a></p>
      </article>
      <article class="panel">
        <h2>Reden</h2>
        <p>Die Struktur für Reden ist vorbereitet und wird in den nächsten Phasen redaktionell ergänzt.</p>
        <p><a class="inline-link" href="/presse/reden/">Zu den Reden</a></p>
      </article>
      <article class="panel">
        <h2>Termine</h2>
        <p>Auch Termine werden künftig in den Pressebereich eingebettet, ohne eigene Serverlogik.</p>
        <p><a class="inline-link" href="/presse/termine/">Zu den Terminen</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
