---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqAccordion from '../../components/portal/FaqAccordion.astro';
import LegislationTracker from '../../components/portal/LegislationTracker.astro';
import { legislationTrackerItems } from '../../data/dashboard/legislation.ts';
import {
  formatDate,
  getCurrentVersion,
  getHomeUrl,
  getIndexUrl,
  getLawConstitutionUrl,
  getNormUrl,
  getSearchUrl,
  getSubjectsUrl,
  loadAllNorms,
} from '../../lib/norms/index.ts';

const norms = await loadAllNorms();
const currentNorms = norms.filter((entry) => entry.versions.some((version) => version.isCurrent));
const latestUpdates = [...norms]
  .sort((left, right) => getCurrentVersion(right).validFrom.localeCompare(getCurrentVersion(left).validFrom))
  .slice(0, 3);
const faqItems = [
  {
    question: 'Wo finde ich aktuelle und historische Fassungen?',
    answer:
      'Auf jeder Normseite sind die aktuelle Fassung, die Historienseite und gegebenenfalls gespeicherte historische Fassungen direkt erreichbar.',
    href: getIndexUrl(),
    hrefLabel: 'Zum Archiv und zu den Historien',
  },
  {
    question: 'Wie funktioniert die Suche im Rechtsbereich?',
    answer:
      'Die Suche nutzt einen beim Build erzeugten Index und wertet die Treffer direkt im Browser aus.',
    href: getSearchUrl(),
    hrefLabel: 'Zur Normensuche',
  },
  {
    question: 'Bleibt das Rechtsportal eigenständig nutzbar?',
    answer:
      'Ja. Der Rechtsbereich bleibt funktional vollständig erhalten und ist zugleich in die Website der Staatsregierung integriert.',
  },
];
---

<BaseLayout
  title="Recht"
  description="Integrierter Rechtsbereich der Staatsregierung des Ostdeutschen Freistaates."
  scripts={['portal-modules']}
>
  <Breadcrumbs items={[{ label: 'Startseite', href: getHomeUrl() }, { label: 'Recht' }]} />

  <section class="section page-header">
    <p class="eyebrow">Rechtsbereich</p>
    <h1>Recht</h1>
    <p class="lead">
      Der Rechtsbereich führt das bisherige Rechtsportal mit aktuellen Fassungen, historischen
      Fassungen, Normenhistorien, Suche, Sachgebieten und Index unter einem gemeinsamen
      Regierungsauftritt fort.
    </p>
    <nav class="hero-actions" aria-label="Rechtseinstiege">
      <a class="button-link" href={getSearchUrl()}>Normensuche</a>
      <a class="button-link button-link--secondary" href={getIndexUrl()}>Archiv</a>
      <a class="button-link button-link--secondary" href={getSubjectsUrl()}>Sachgebiete</a>
      <a class="button-link button-link--secondary" href={getLawConstitutionUrl()}>Verfassung</a>
    </nav>
  </section>

  <section class="section">
    <div class="meta-grid">
      <div class="meta-card">
        <span class="meta-label">Normenbestand</span>
        <strong>{norms.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Aktuelle Fassungen</span>
        <strong>{currentNorms.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Ausgabe</span>
        <strong>Dauerhaft veröffentlicht</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Verortung</span>
        <strong>/recht/ als Kernmodul</strong>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Letzte Änderungen</h2>
      <p>Diese Übersicht dient als Einstieg in den unter <code>/recht/</code> eingebundenen Normenbestand.</p>
    </div>
    <div class="card-grid">
      {latestUpdates.map((norm) => {
        const currentVersion = getCurrentVersion(norm);

        return (
          <article class="panel">
            <h3><a class="inline-link" href={getNormUrl(norm.meta.slug)}>{norm.meta.title}</a></h3>
            <p>{norm.meta.summary}</p>
            <p class="detail-line">Rechtsstand seit {formatDate(currentVersion.validFrom)}</p>
          </article>
        );
      })}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Gesetzgebungs-Tracker</h2>
      <p>
        Laufende und kürzlich abgeschlossene Vorhaben werden mit Ressortbezug, Statuskette und
        direkter Verlinkung in Themen- oder Normseiten dargestellt.
      </p>
    </div>
    <LegislationTracker items={legislationTrackerItems} />
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Häufige Fragen zum Rechtsbereich</h2>
      <p>Das FAQ-Muster wird auch im Rechtsportal einheitlich als aufklappbare Fragenstruktur eingesetzt.</p>
    </div>
    <FaqAccordion items={faqItems} />
  </section>
</BaseLayout>
