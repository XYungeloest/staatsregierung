---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import NormBody from '../../../../components/norms/NormBody.astro';
import NormMetaCard from '../../../../components/norms/NormMetaCard.astro';
import NormOutline from '../../../../components/norms/NormOutline.astro';
import NormStatusNotice from '../../../../components/norms/NormStatusNotice.astro';
import { loadPressReleases, loadTopics } from '../../../../lib/portal/content.ts';
import {
  getPressReleaseIndexUrl,
  getPressReleaseUrl,
  getTopicUrl,
  getTopicsUrl,
} from '../../../../lib/portal/routes.ts';
import {
  buildNormOutline,
  formatDate,
  toDisplayText,
} from '../../../../lib/norms/presentation.ts';
import {
  getHomeUrl,
  getLawPortalUrl,
  getNormHistoryUrl,
  getNormUrl,
  getNormVersionUrl,
} from '../../../../lib/norms/index.ts';
import { getCurrentVersion, loadAllNorms } from '../../../../lib/norms/content.ts';

export async function getStaticPaths() {
  const norms = await loadAllNorms();

  return norms.map((norm) => ({
    params: { slug: norm.meta.slug },
    props: { norm, currentVersion: getCurrentVersion(norm) },
  }));
}

const { norm, currentVersion } = Astro.props;
const historicalVersions = norm.versions.filter((entry) => !entry.isCurrent);
const outline = buildNormOutline(currentVersion.body);
const normTitle = toDisplayText(norm.meta.title);
const normLabel = norm.meta.abbr ? `${normTitle} (${toDisplayText(norm.meta.abbr)})` : normTitle;
const currentDescription = `Aktuelle Fassung von ${normLabel} im Rechtsbereich des Freistaates Ostdeutschland. Ressort: ${toDisplayText(norm.meta.ministry)}. Rechtsstand seit ${formatDate(currentVersion.validFrom)}.`;
const [topics, pressReleases] = await Promise.all([loadTopics(), loadPressReleases()]);
const relatedTopics = topics.filter((topic) =>
  topic.rechtsgrundlagen.some((entry) => entry.normSlug === norm.meta.slug),
);
const relatedPressReleases = pressReleases
  .filter((release) => release.relatedNormSlugs?.includes(norm.meta.slug))
  .slice(0, 3);
---

<BaseLayout
  title={normTitle}
  description={currentDescription}
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Recht', href: getLawPortalUrl() },
    { label: toDisplayText(norm.meta.shortTitle || norm.meta.title), href: getNormUrl(norm.meta.slug) },
  ]}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Recht', href: getLawPortalUrl() },
      { label: toDisplayText(norm.meta.shortTitle || norm.meta.title) },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Aktuelle Fassung</p>
    <h1>{toDisplayText(norm.meta.title)}</h1>
    <p class="lead">{toDisplayText(norm.meta.summary)}</p>
    <p class="status-line">Rechtsstand: aktuelle Fassung seit {formatDate(currentVersion.validFrom)}</p>
    <nav class="link-list link-list--inline" aria-label="Seitennavigation">
      <a href={getNormHistoryUrl(norm.meta.slug)}>Historie</a>
      {historicalVersions.map((version) => (
        <a href={getNormVersionUrl(norm.meta.slug, version.versionId)}>
          Fassung vom {formatDate(version.validFrom)}
        </a>
      ))}
    </nav>
  </section>

  <NormStatusNotice norm={norm} version={currentVersion} />

  <div class="content-grid">
    <div class="content-stack">
      <NormOutline items={outline} />
      <section class="section">
        <div class="section-header">
          <h2>Normtext</h2>
          <p>{toDisplayText(currentVersion.changeNote)}</p>
        </div>
        <NormBody blocks={currentVersion.body} />
      </section>
    </div>

    <aside class="content-stack">
      <NormMetaCard norm={norm} version={currentVersion} />
      {relatedTopics.length > 0 || relatedPressReleases.length > 0 ? (
        <section class="section">
          <div class="section-header section-header--compact">
            <h2>Bezüge im Portal</h2>
          </div>
          {relatedTopics.length > 0 ? (
            <>
              <h3>Themen</h3>
              <ul class="record-list">
                {relatedTopics.map((topic) => (
                  <li class="record-list__item">
                    <a class="inline-link" href={getTopicUrl(topic.slug)}>{topic.title}</a>
                    <span>{topic.teaser}</span>
                  </li>
                ))}
              </ul>
              <p class="section-link-row">
                <a class="inline-link" href={getTopicsUrl()}>Zu Themen & Projekte</a>
              </p>
            </>
          ) : null}
          {relatedPressReleases.length > 0 ? (
            <>
              <h3>Presse</h3>
              <ul class="record-list">
                {relatedPressReleases.map((release) => (
                  <li class="record-list__item">
                    <a class="inline-link" href={getPressReleaseUrl(release.slug)}>{release.title}</a>
                    <span>{formatDate(release.date)} · {release.ressort}</span>
                  </li>
                ))}
              </ul>
              <p class="section-link-row">
                <a class="inline-link" href={getPressReleaseIndexUrl()}>Zu den Pressemitteilungen</a>
              </p>
            </>
          ) : null}
        </section>
      ) : null}
    </aside>
  </div>
</BaseLayout>
