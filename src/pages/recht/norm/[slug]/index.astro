---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import NormBody from '../../../../components/norms/NormBody.astro';
import NormMetaCard from '../../../../components/norms/NormMetaCard.astro';
import NormOutline from '../../../../components/norms/NormOutline.astro';
import NormStatusNotice from '../../../../components/norms/NormStatusNotice.astro';
import {
  buildNormOutline,
  formatDate,
  toDisplayText,
} from '../../../../lib/norms/presentation.ts';
import {
  getCurrentVersion,
  getHomeUrl,
  getLawPortalUrl,
  getNormHistoryUrl,
  getNormVersionUrl,
  loadAllNorms,
} from '../../../../lib/norms/index.ts';

export async function getStaticPaths() {
  const norms = await loadAllNorms();

  return norms.map((norm) => ({
    params: { slug: norm.meta.slug },
    props: { norm, currentVersion: getCurrentVersion(norm) },
  }));
}

const { norm, currentVersion } = Astro.props;
const historicalVersions = norm.versions.filter((entry) => !entry.isCurrent);
const outline = buildNormOutline(currentVersion.body);
---

<BaseLayout title={toDisplayText(norm.meta.title)} description={toDisplayText(norm.meta.summary)}>
  <Breadcrumbs
    items={[
      { label: 'Start', href: getHomeUrl() },
      { label: 'Recht', href: getLawPortalUrl() },
      { label: toDisplayText(norm.meta.shortTitle || norm.meta.title) },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Aktuelle Fassung</p>
    <h1>{toDisplayText(norm.meta.title)}</h1>
    <p class="lead">{toDisplayText(norm.meta.summary)}</p>
    <p class="status-line">Rechtsstand: aktuelle Fassung seit {formatDate(currentVersion.validFrom)}</p>
    <nav class="link-list link-list--inline" aria-label="Seitennavigation">
      <a href={getNormHistoryUrl(norm.meta.slug)}>Historie</a>
      {historicalVersions.map((version) => (
        <a href={getNormVersionUrl(norm.meta.slug, version.versionId)}>
          Fassung vom {formatDate(version.validFrom)}
        </a>
      ))}
    </nav>
  </section>

  <NormStatusNotice norm={norm} version={currentVersion} />

  <div class="content-grid">
    <div class="content-stack">
      <NormOutline items={outline} />
      <section class="section">
        <div class="section-header">
          <h2>Normtext</h2>
          <p>{toDisplayText(currentVersion.changeNote)}</p>
        </div>
        <NormBody blocks={currentVersion.body} />
      </section>
    </div>

    <NormMetaCard norm={norm} version={currentVersion} />
  </div>
</BaseLayout>
