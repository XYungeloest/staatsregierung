---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import { formatDate, toDisplayText } from '../../../../lib/norms/presentation.ts';
import {
  getCurrentVersion,
  getHomeUrl,
  getLawPortalUrl,
  getNormUrl,
  getVersionById,
  getNormVersionUrl,
  loadAllNorms,
} from '../../../../lib/norms/index.ts';

export async function getStaticPaths() {
  const norms = await loadAllNorms();
  const relatedNormLabels = Object.fromEntries(
    norms.map((entry) => [entry.meta.slug, toDisplayText(entry.meta.title)]),
  );

  return norms.map((norm) => ({
    params: { slug: norm.meta.slug },
    props: { norm, currentVersion: getCurrentVersion(norm), relatedNormLabels },
  }));
}

const { norm, currentVersion, relatedNormLabels } = Astro.props;
const initialVersion = getVersionById(norm, norm.history.initialVersionId);
const initialVersionLabel = initialVersion ? formatDate(initialVersion.validFrom) : norm.history.initialVersionId;
const initialVersionUrl = initialVersion
  ? initialVersion.isCurrent
    ? getNormUrl(norm.meta.slug)
    : getNormVersionUrl(norm.meta.slug, initialVersion.versionId)
  : undefined;
const normTitle = toDisplayText(norm.meta.title);
const historyDescription = `Historienseite zu ${normTitle} mit Stammfassung, gespeicherten Fassungen und Änderungshinweisen im Rechtsbereich des Freistaates Ostdeutschland.`;
---

<BaseLayout
  title={`${normTitle} Historie`}
  description={historyDescription}
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Recht', href: getLawPortalUrl() },
    { label: toDisplayText(norm.meta.shortTitle || norm.meta.title), href: getNormUrl(norm.meta.slug) },
    { label: 'Historie' },
  ]}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Recht', href: getLawPortalUrl() },
      { label: toDisplayText(norm.meta.shortTitle || norm.meta.title), href: getNormUrl(norm.meta.slug) },
      { label: 'Historie' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Normenhistorie</p>
    <h1>{toDisplayText(norm.meta.title)}</h1>
    <p class="lead">Historienseite mit Stammfassung, Änderungsbezügen und allen gespeicherten Fassungen.</p>
    <nav class="link-list link-list--inline" aria-label="Seitennavigation">
      <a href={getNormUrl(norm.meta.slug)}>Zur aktuellen Fassung</a>
    </nav>
  </section>

  <div class="content-grid content-grid--wide">
    <section class="section">
      <div class="section-header">
        <h2>Fassungen</h2>
      </div>
      <ul class="timeline-list">
        {norm.versions.map((version) => (
          <li>
            <strong>
              {version.isCurrent ? (
                <a class="inline-link" href={getNormUrl(norm.meta.slug)}>{formatDate(version.validFrom)}</a>
              ) : (
                <a class="inline-link" href={getNormVersionUrl(norm.meta.slug, version.versionId)}>{formatDate(version.validFrom)}</a>
              )}
            </strong>
            <span>Gültig von {formatDate(version.validFrom)} bis {version.validTo ? formatDate(version.validTo) : 'heute'}</span>
            <span>{toDisplayText(version.changeNote)}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Historieneinträge</h2>
      </div>
      <ul class="timeline-list">
        {norm.history.entries.map((entry) => (
          <li>
            <strong>{formatDate(entry.date)}</strong>
            <span>{toDisplayText(entry.title)}</span>
            <span>{toDisplayText(entry.citation)}</span>
            {entry.relatedNorm ? (
              relatedNormLabels[entry.relatedNorm] ? (
                <span>
                  Bezug:{' '}
                  <a class="inline-link" href={getNormUrl(entry.relatedNorm)}>
                    {relatedNormLabels[entry.relatedNorm]}
                  </a>
                </span>
              ) : (
                <span>Bezug: {toDisplayText(entry.relatedNorm)}</span>
              )
            ) : null}
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Stammdaten</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Stammfassung</dt>
          <dd>
            {initialVersionUrl ? (
              <a class="inline-link" href={initialVersionUrl}>{initialVersionLabel}</a>
            ) : (
              initialVersionLabel
            )}
          </dd>
        </div>
        <div>
          <dt>Aktueller Rechtsstand</dt>
          <dd>{formatDate(currentVersion.validFrom)}</dd>
        </div>
        <div>
          <dt>Vorgänger</dt>
          <dd>{norm.meta.predecessor ? toDisplayText(norm.meta.predecessor) : 'keiner'}</dd>
        </div>
        <div>
          <dt>Nachfolger</dt>
          <dd>{norm.meta.successor ? toDisplayText(norm.meta.successor) : 'keiner'}</dd>
        </div>
      </dl>
    </section>
  </div>
</BaseLayout>
