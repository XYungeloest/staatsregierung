---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import {
  formatNormType,
  getHomeUrl,
  getIndexGroups,
  getLawPortalUrl,
  getNormUrl,
  loadAllNorms,
  toDisplayText,
} from '../../../lib/norms/index.ts';

const norms = await loadAllNorms();
const groups = getIndexGroups(norms);
---

<BaseLayout
  title="Normenarchiv"
  description="Alphabetischer Zugang zu den im Rechtsbereich des Freistaates Ostdeutschland geführten Normen."
  breadcrumbs={[
    { label: 'Startseite', href: getHomeUrl() },
    { label: 'Recht', href: getLawPortalUrl() },
    { label: 'Archiv', href: getLawPortalUrl() + 'archiv/' },
  ]}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Recht', href: getLawPortalUrl() },
      { label: 'Archiv' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Rechtsbereich</p>
    <h1>Archiv</h1>
    <p class="lead">
      Das Archiv dient als alphabetischer Zugang zu allen im Rechtsbereich geführten Normen.
    </p>
    <nav class="letter-nav" aria-label="Buchstaben-Navigation">
      {groups.map((group) => (
        <a href={`#${group.letter}`}>{group.letter}</a>
      ))}
    </nav>
  </section>

  {groups.map((group) => (
    <section class="section" id={group.letter}>
      <div class="section-header">
        <h2>{group.letter}</h2>
      </div>
      <ul class="record-list">
        {group.norms.map((norm) => (
          <li class="record-list__item">
            <a class="inline-link" href={getNormUrl(norm.meta.slug)}>{toDisplayText(norm.meta.title)}</a>
            <span>{norm.meta.abbr} · {formatNormType(norm.meta.type)}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
