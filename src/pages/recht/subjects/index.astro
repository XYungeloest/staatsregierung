---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import {
  getHomeUrl,
  getLawPortalUrl,
  getSubjectUrl,
  getSubjectGroups,
  loadAllNorms,
  toDisplayText,
} from '../../../lib/norms/index.ts';

const groups = getSubjectGroups(await loadAllNorms());
---

<BaseLayout title="Sachgebiete" description="Sachgebietsübersicht des Rechtsbereichs.">
  <Breadcrumbs
    items={[
      { label: 'Start', href: getHomeUrl() },
      { label: 'Recht', href: getLawPortalUrl() },
      { label: 'Sachgebiete' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Rechtsbereich</p>
    <h1>Sachgebiete</h1>
    <p class="lead">Die Normen des Portals sind zusätzlich nach Sachgebieten erschlossen.</p>
  </section>

  <section class="section">
    <ul class="record-list">
      {groups.map((group) => (
        <li class="record-list__item">
          <a class="inline-link" href={getSubjectUrl(group.name)}>{toDisplayText(group.name)}</a>
          <span>{group.norms.length} Normen</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
