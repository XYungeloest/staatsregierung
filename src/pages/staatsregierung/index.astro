---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GovernmentMemberCard from '../../components/portal/GovernmentMemberCard.astro';
import TopicCard from '../../components/portal/TopicCard.astro';
import { siteConfig } from '../../config/site.ts';
import {
  getActionPlanUrl,
  getCabinetUrl,
  getCoalitionUrl,
  getGovernmentMembersUrl,
  getHomeUrl,
  getMinisterPresidentUrl,
  getTopicsUrl,
  loadGovernmentMembers,
  loadMinistries,
  loadTopics,
} from '../../lib/portal/index.ts';

const [members, topics, ministries] = await Promise.all([
  loadGovernmentMembers(),
  loadTopics(),
  loadMinistries(),
]);
const currentGovernment = siteConfig.currentGovernment;
const headOfGovernment = members[0];
const featuredMembers = members.slice(0, 6);
const ministryLookup = new Map(ministries.map((ministry) => [ministry.slug, ministry]));
const flagshipTopics = [
  'wohnen-und-vergesellschaftung',
  'bildungsreform',
  'transparenz-und-lobbyregister',
].flatMap((slug) => {
  const topic = topics.find((entry) => entry.slug === slug);
  return topic ? [topic] : [];
});
---

<BaseLayout
  title="Staatsregierung"
  description="Übersichtsseite der Staatsregierung des Ostdeutschen Freistaates."
>
  <Breadcrumbs items={[{ label: 'Startseite', href: getHomeUrl() }, { label: 'Staatsregierung' }]} />

  <section class="section page-header">
    <p class="eyebrow">Staatsregierung</p>
    <h1>Staatsregierung</h1>
    <p class="lead">
      Die Staatsregierung des Ostdeutschen Freistaates wird vom {currentGovernment.cabinetName}
      getragen. Sie verbindet politische Leitung, Kabinettsarbeit, Ressorts und programmatische
      Vorhaben unter einer gemeinsamen staatlichen Portalstruktur.
    </p>
    <nav class="hero-actions" aria-label="Regierungseinstiege">
      <a class="button-link" href={getMinisterPresidentUrl()}>Ministerpräsident</a>
      <a class="button-link button-link--secondary" href={getCabinetUrl()}>Kabinett & Ressorts</a>
      <a class="button-link button-link--secondary" href={getActionPlanUrl()}>15-Punkte-Plan</a>
    </nav>
  </section>

  <section class="section">
    <div class="meta-grid">
      <div class="meta-card">
        <span class="meta-label">Kabinettsname</span>
        <strong>{currentGovernment.cabinetName}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Koalition</span>
        <strong>{currentGovernment.coalitionShort}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Regierungssitz</span>
        <strong>{currentGovernment.seatOfGovernment}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Ressorts</span>
        <strong>{ministries.length}</strong>
      </div>
    </div>
  </section>

  <div class="content-grid">
    <section class="section">
      <div class="section-header">
        <h2>Leitung der Staatsregierung</h2>
      </div>
      {headOfGovernment ? <GovernmentMemberCard member={headOfGovernment} /> : null}
      <div class="body-copy">
        <p>
          Die Staatsregierung bestimmt die Richtlinien der Politik, koordiniert Kabinettsverfahren
          und bündelt politische Kommunikation, Ressortsteuerung und zentrale Landesaufgaben.
        </p>
        <p>
          Seit dem {siteConfig.date.formatLong(currentGovernment.formedOn)} führt
          {` ${currentGovernment.headOfGovernment} `} die Staatsregierung. Stellvertretende
          Ministerpräsidentin ist {currentGovernment.deputyHead}.
        </p>
        <p>
          Dresden ist der sichtbare politische Bezugspunkt für Kabinettsarbeit,
          Regierungskoordination und ressortübergreifende Umsetzung.
        </p>
      </div>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Direkteinstiege</h2>
      </div>
      <nav class="link-list">
        <a href={getMinisterPresidentUrl()}>Ministerpräsident</a>
        <a href={getCabinetUrl()}>Kabinett und Ressorts</a>
        <a href={getCoalitionUrl()}>Koalition</a>
        <a href={getActionPlanUrl()}>15-Punkte-Plan</a>
        <a href={getGovernmentMembersUrl()}>Regierungsmitglieder</a>
      </nav>
    </aside>
  </div>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Regierungsarchitektur</h2>
      <p>
        Die Staatsregierung wird als zusammenhängender Hauptbereich geführt und bindet personelle,
        politische und thematische Ebenen sichtbar zusammen.
      </p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Politische Leitung</h3>
        <p>
          Ministerpräsident, Staatskanzlei und Stellvertretung sind als klarer Führungsbereich
          gebündelt.
        </p>
        <p><a class="inline-link" href={getMinisterPresidentUrl()}>Zur Leitungsseite</a></p>
      </article>
      <article class="panel">
        <h3>Kabinett & Ressorts</h3>
        <p>
          Ressortseiten zeigen Leitung, Aufgaben, Kontakt und thematische Einbindung in kompakter
          Form.
        </p>
        <p><a class="inline-link" href={getCabinetUrl()}>Zum Kabinett</a></p>
      </article>
      <article class="panel">
        <h3>Koalition & Programm</h3>
        <p>
          Koalitionsrahmen und 15-Punkte-Plan bilden die politische Arbeitsgrundlage des
          Regierungshandelns.
        </p>
        <p><a class="inline-link" href={getCoalitionUrl()}>Zur Koalition</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Politische Schwerpunkte</h2>
      <p>
        Diese Themen tragen die aktuelle Regierungsarbeit bereits sichtbar und sind direkt mit
        Ressorts und Rechtsgrundlagen verknüpft.
      </p>
    </div>
    <div class="card-grid card-grid--two">
      {flagshipTopics.map((topic) => (
        <TopicCard
          topic={topic}
          ministryName={ministryLookup.get(topic.federfuehrendesRessort)?.kurzname}
        />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getTopicsUrl()}>Zu allen Themen & Projekte</a>
    </p>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Regierungsmitglieder</h2>
      <p>Die Profile der Regierungsmitglieder bleiben dateibasiert, konsistent und mit stabilen URLs erreichbar.</p>
    </div>
    <div class="card-grid card-grid--two">
      {featuredMembers.map((member) => (
        <GovernmentMemberCard member={member} variant="compact" />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getGovernmentMembersUrl()}>Alle Regierungsmitglieder anzeigen</a>
    </p>
  </section>
</BaseLayout>
