---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import GovernmentMemberCard from '../../../components/portal/GovernmentMemberCard.astro';
import MinistryCard from '../../../components/portal/MinistryCard.astro';
import { siteConfig } from '../../../config/site.ts';
import {
  getActionPlanUrl,
  getCabinetUrl,
  getGovernmentUrl,
  getHomeUrl,
  getTopicUrl,
  loadGovernmentMembers,
  loadMinistries,
  loadTopics,
} from '../../../lib/portal/index.ts';

const [members, ministries, topics] = await Promise.all([
  loadGovernmentMembers(),
  loadMinistries(),
  loadTopics(),
]);
const ministerPresident = members[0];
const leadershipMinistries = ministries.filter((ministry) =>
  ['staatskanzlei', 'kapitalakkumulation-des-fiskus'].includes(ministry.slug),
);
const topPriorities = topics
  .filter((topic) =>
    ['wohnen-und-vergesellschaftung', 'haushalt-und-finanzen', 'transparenz-und-lobbyregister'].includes(
      topic.slug,
    ),
  )
  .slice(0, 3);
---

<BaseLayout
  title="Ministerpräsident"
  description="Leitungsseite des Ministerpräsidenten innerhalb der Staatsregierung."
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Staatsregierung', href: getGovernmentUrl() },
      { label: 'Ministerpräsident' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Leitung</p>
    <h1>Ministerpräsident</h1>
    <p class="lead">
      Der Ministerpräsident führt die Staatsregierung, bestimmt die Richtlinien der Politik und
      koordiniert die Arbeit des Kabinetts. Politischer Bezugspunkt dieser Leitungsfunktion ist
      Dresden als Sitz der Staatsregierung.
    </p>
  </section>

  <section class="section section-muted">
    {ministerPresident ? <GovernmentMemberCard member={ministerPresident} /> : null}
  </section>

  <section class="section">
    <div class="content-grid">
      <section class="section body-copy">
        <p>
          Die Leitungsfunktion der Staatsregierung bündelt Kabinettssteuerung, ressortübergreifende
          Koordinierung und öffentliche Repräsentation. Von hier aus werden politische
          Schwerpunkte, Regierungsverfahren und zentrale Kommunikationslinien zusammengeführt.
        </p>
        <p>
          Die derzeitige Regierungsbildung datiert vom{' '}
          {siteConfig.date.formatLong(siteConfig.currentGovernment.formedOn)}. Die Leitungsseite
          fasst die politischen Kerndaten bewusst sachlich und übersichtlich zusammen.
        </p>
        <p>
          Die Leitungsfunktion des Ministerpräsidenten ist eng mit der Staatskanzlei und dem
          Fiskusressort verknüpft. Von hier aus werden Regierungsschwerpunkte, Umsetzungsstände und
          politische Prioritäten der Staatsregierung gebündelt.
        </p>
      </section>

      <aside class="section meta-panel">
        <div class="section-header section-header--compact">
          <h2>Auf einen Blick</h2>
        </div>
        <dl class="meta-list">
          <div>
            <dt>Amtsträger</dt>
            <dd>{siteConfig.currentGovernment.headOfGovernment}</dd>
          </div>
          <div>
            <dt>Kabinett</dt>
            <dd>{siteConfig.currentGovernment.cabinetName}</dd>
          </div>
          <div>
            <dt>Koalition</dt>
            <dd>{siteConfig.currentGovernment.coalitionShort}</dd>
          </div>
        </dl>
        <p><a class="inline-link" href={getCabinetUrl()}>Zum Kabinett Honecker</a></p>
        <p><a class="inline-link" href={getActionPlanUrl()}>Zum 15-Punkte-Plan</a></p>
      </aside>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Unmittelbar geführte Bereiche</h2>
      <p>Die Leitungsfunktion des Ministerpräsidenten ist inhaltlich besonders mit diesen Bereichen verbunden.</p>
    </div>
    <div class="card-grid card-grid--two">
      {leadershipMinistries.map((ministry) => (
        <MinistryCard ministry={ministry} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Leitende Schwerpunkte</h2>
      <p>Diese Themen markieren politische Prioritäten der Staatsregierung in der laufenden Legislaturperiode.</p>
    </div>
    <ul class="record-list">
      {topPriorities.map((topic) => (
        <li class="record-list__item">
          <strong><a class="inline-link" href={getTopicUrl(topic.slug)}>{topic.title}</a></strong>
          <span>{topic.teaser}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
