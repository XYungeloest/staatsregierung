---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ActionPlanDashboard from '../../../components/portal/ActionPlanDashboard.astro';
import ProjectTimeline from '../../../components/portal/ProjectTimeline.astro';
import { timelineEntries } from '../../../data/dashboard/timeline.ts';
import { getDatabase } from '../../../lib/dynamic/env.ts';
import { listProjectStatuses } from '../../../lib/dynamic/repository.ts';
import {
  getCabinetUrl,
  getGovernmentUrl,
  getHomeUrl,
  getLawHomeUrl,
  getMinisterPresidentUrl,
  getTopicsUrl,
} from '../../../lib/portal/index.ts';
const actionPlanItems = await listProjectStatuses(getDatabase());
const completedCount = actionPlanItems.filter((point) => point.status === 'umgesetzt').length;
const partlyCount = actionPlanItems.filter((point) => point.status === 'teilweise_umgesetzt').length;
const plannedCount = actionPlanItems.filter((point) => point.status === 'angelegt').length;
---

<BaseLayout
  title="15-Punkte-Plan"
  description="Regierungsprogrammatische Leitlinien der Staatsregierung."
  scripts={['portal-modules']}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Staatsregierung', href: getGovernmentUrl() },
      { label: '15-Punkte-Plan' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Regierungsprogramm</p>
    <h1>15-Punkte-Plan</h1>
    <p class="lead">
      Der 15-Punkte-Plan bündelt die zentralen politischen Linien der Staatsregierung in einer
      lesbaren Übersicht mit Statusindikatoren und direkten Portalverlinkungen.
    </p>
  </section>

  <section class="section">
    <div class="meta-grid">
      <div class="meta-card">
        <span class="meta-label">Programmpunkte</span>
        <strong>{actionPlanItems.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Umgesetzt</span>
        <strong>{completedCount}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Teilweise umgesetzt</span>
        <strong>{partlyCount}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Angelegt</span>
        <strong>{plannedCount}</strong>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Fortschritts-Dashboard</h2>
      <p>
        Alle Programmpunkte werden mit Statussymbolen, Ressortbezug und direkten Verlinkungen auf
        Themen- oder Rechtsseiten dargestellt.
      </p>
    </div>
    <ActionPlanDashboard items={actionPlanItems} />
    <p class="section-link-row">
      <a class="inline-link" href={getTopicsUrl()}>Zur Themenübersicht</a>
    </p>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Projekt-Timeline seit Dezember 2025</h2>
      <p>
        Die Zeitachse ordnet wichtige Regierungsmaßnahmen, Normerlasse, Presseereignisse und
        Haushaltsentscheidungen chronologisch in die Gesamtentwicklung ein.
      </p>
    </div>
    <ProjectTimeline entries={timelineEntries} />
  </section>

  <section class="section section-muted">
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h2>Ministerpräsident</h2>
        <p>Die Leitungsseite bündelt Regierungskoordination, politische Prioritäten und den Regierungssitz Dresden.</p>
        <p><a class="inline-link" href={getMinisterPresidentUrl()}>Zur Leitungsseite</a></p>
      </article>
      <article class="panel">
        <h2>Kabinett & Ressorts</h2>
        <p>Die Ressortseiten machen Zuständigkeiten, Themenbezüge und institutionelle Verantwortung lesbar zugänglich.</p>
        <p><a class="inline-link" href={getCabinetUrl()}>Zum Kabinett</a></p>
      </article>
      <article class="panel">
        <h2>Rechtsportal</h2>
        <p>Aktuelle Fassungen, Historienseiten und der Gesetzgebungs-Tracker bleiben als Kernmodul unter <code>/recht/</code> erreichbar.</p>
        <p><a class="inline-link" href={getLawHomeUrl()}>Zum Rechtsbereich</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
