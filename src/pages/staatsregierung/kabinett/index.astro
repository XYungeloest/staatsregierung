---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import GovernmentMemberCard from '../../../components/portal/GovernmentMemberCard.astro';
import MinistryCard from '../../../components/portal/MinistryCard.astro';
import TopicCard from '../../../components/portal/TopicCard.astro';
import { siteConfig } from '../../../config/site.ts';
import {
  getGovernmentMemberUrl,
  getGovernmentMembersUrl,
  getGovernmentUrl,
  getHomeUrl,
} from '../../../lib/portal/index.ts';
import {
  loadGovernmentMembers,
  loadMinistries,
  loadTopics,
} from '../../../lib/portal/content.ts';

const [members, ministries, topics] = await Promise.all([
  loadGovernmentMembers(),
  loadMinistries(),
  loadTopics(),
]);
const currentGovernment = siteConfig.currentGovernment;
const memberLookup = new Map(members.map((member) => [member.slug, member]));
const ministryLookup = new Map(ministries.map((ministry) => [ministry.slug, ministry]));
const assignments = [
  {
    office: 'Ministerpräsident',
    holderSlug: 'karl-honecker',
    ministrySlug: 'kapitalakkumulation-des-fiskus',
    note: 'Führt die Staatsregierung und verantwortet den Fiskus in Personalunion.',
  },
  {
    office: 'Staatskanzlei',
    holderSlug: 'emma-mueller',
    ministrySlug: 'staatskanzlei',
    note: 'Verantwortet die Regierungskoordination und Kabinettsverfahren.',
  },
  {
    office: 'Stellvertretende Ministerpräsidentin; Inneres, Bau und kommunale Angelegenheiten',
    holderSlug: 'mia-wollrath',
    ministrySlug: 'inneres-bau-und-kommunale-angelegenheiten',
  },
  {
    office: 'Grenzschutz, Faschismusbekämpfung und bewaffnete Organe',
    holderSlug: 'alexandrija-dunvjiak',
    ministrySlug: 'grenzschutz-faschismusbekaempfung-und-bewaffnete-organe',
  },
  {
    office: 'Soziale und gesundheitliche Fürsorge',
    holderSlug: 'simon-kellermann',
    ministrySlug: 'soziale-und-gesundheitliche-fuersorge',
  },
  {
    office: 'Rechtsstaatlichkeit und Angelegenheiten des Staates',
    holderSlug: 'mateo-delgado',
    ministrySlug: 'rechtsstaatlichkeit-und-angelegenheiten-des-staates',
  },
  {
    office: 'Völkerfreundschaft und Nachbarschaftspolitik',
    holderSlug: 'tim-dieter',
    ministrySlug: 'voelkerfreundschaft-und-nachbarschaftspolitik',
  },
  {
    office: 'Mobilität, Infrastruktur und Landesentwicklung',
    holderSlug: 'vincent-flick',
    ministrySlug: 'mobilitaet-infrastruktur-und-landesentwicklung',
  },
  {
    office: 'Kultur, Wissenschaft und Tourismus',
    holderSlug: 'freya-warnecke',
    ministrySlug: 'kultur-wissenschaft-und-tourismus',
  },
  {
    office: 'Bildung und sportliche Ertüchtigung',
    holderSlug: 'friedrich-ritter',
    ministrySlug: 'bildung-und-sportliche-ertuechtigung',
  },
  {
    office: 'Umwelt, Energie und Klimaschutz',
    holderSlug: 'tim-dieter',
    ministrySlug: 'umwelt-energie-und-klimaschutz',
    note: 'Wird von Tim Dieter zusätzlich in Personalunion geführt.',
  },
  {
    office: 'Küste, Fischerei, Forst und Landwirtschaft',
    holderSlug: 'elizabeth-eberhardt',
    ministrySlug: 'kueste-fischerei-forst-und-landwirtschaft',
  },
  {
    office: 'Wirtschaft, Arbeitsmarkt und Beschäftigung',
    holderSlug: 'gerhardt-lehrmann',
    ministrySlug: 'wirtschaft-arbeitsmarkt-und-beschaeftigung',
  },
];
const topicHighlights = [
  'wohnen-und-vergesellschaftung',
  'oepnv-und-mobilitaet',
  'familie-und-soziales',
  'haushalt-und-finanzen',
].flatMap((slug) => {
  const topic = topics.find((entry) => entry.slug === slug);
  return topic ? [topic] : [];
});
---

<BaseLayout title="Kabinett Honecker" description="Kabinettsübersicht der Staatsregierung.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Staatsregierung', href: getGovernmentUrl() },
      { label: 'Kabinett Honecker' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Regierungsarbeit</p>
    <h1>{currentGovernment.cabinetName}</h1>
    <p class="lead">
      Das {currentGovernment.cabinetName} ist die achte Staatsregierung des Ostdeutschen
      Freistaates. Es wurde am {siteConfig.date.formatLong(currentGovernment.formedOn)} gebildet
      und wird von einer Koalition aus {currentGovernment.coalition} getragen.
    </p>
  </section>

  <section class="section">
    <div class="meta-grid">
      <div class="meta-card">
        <span class="meta-label">Koalition</span>
        <strong>{currentGovernment.coalitionShort}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Ministerpräsident</span>
        <strong>{currentGovernment.headOfGovernment}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Regierungssitz</span>
        <strong>{currentGovernment.seatOfGovernment}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Ressorts</span>
        <strong>{ministries.length}</strong>
      </div>
    </div>
  </section>

  <div class="content-grid">
    <section class="section">
      <div class="section-header">
        <h2>Politische Einordnung</h2>
      </div>
      <div class="body-copy">
        <p>
          Das Kabinett Honecker löste das {currentGovernment.predecessor} ab. Es verbindet
          institutionellen Ausbau, öffentliche Daseinsvorsorge, steuernde Landespolitik und den
          Ausbau eines eigenständigen ostdeutschen Staatswesens.
        </p>
        <p>
          Die Kabinettsstruktur ist im Portal nicht als paralleles Ministerienverzeichnis
          ausgelagert, sondern direkt als Teil der Staatsregierung verortet. Dadurch bleiben
          Leitung, Ressorts und politische Vorhaben eng miteinander verbunden.
        </p>
      </div>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Kabinettsdaten</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Gebildet</dt>
          <dd>{siteConfig.date.formatLong(currentGovernment.formedOn)}</dd>
        </div>
        <div>
          <dt>Vorgänger</dt>
          <dd>{currentGovernment.predecessor}</dd>
        </div>
        <div>
          <dt>Mitgliederprofile</dt>
          <dd>{members.length}</dd>
        </div>
      </dl>
    </aside>
  </div>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Mitglieder der Staatsregierung</h2>
      <p>Die Mitgliederprofile bilden die aktuelle personelle Zusammensetzung des Kabinetts ab.</p>
    </div>
    <div class="card-grid card-grid--two">
      {members.map((member) => (
        <GovernmentMemberCard member={member} variant="compact" />
      ))}
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Ressorts</h2>
      <p>Die Ressortseiten bündeln Leitung, Aufgaben, Kontakt und thematische Zuständigkeiten.</p>
    </div>
    <div class="card-grid card-grid--two">
      {ministries.map((ministry) => (
        <MinistryCard ministry={ministry} />
      ))}
    </div>
  </section>
  
  <section class="section">
    <div class="section-header">
      <h2>Ressortzuschnitt</h2>
      <p>
        Die Portfolioübersicht macht Leitungsverantwortung, Personalunionen und den konkreten
        Ressortbezug sichtbar.
      </p>
    </div>
    <ul class="record-list">
      {assignments.map((assignment) => {
        const member = memberLookup.get(assignment.holderSlug);
        const ministry = ministryLookup.get(assignment.ministrySlug);

        return (
          <li class="record-list__item">
            <strong>{assignment.office}</strong>
            {member ? (
              <span>
                <a class="inline-link" href={getGovernmentMemberUrl(member.slug)}>{member.name}</a>
              </span>
            ) : null}
            {ministry ? <span>Ressort: {ministry.kurzname}</span> : null}
            {assignment.note ? <span>{assignment.note}</span> : null}
          </li>
        );
      })}
    </ul>
    <p class="detail-line">
      Weitere Einzelprofile stehen unter{' '}
      <a class="inline-link" href={getGovernmentMembersUrl()}>Regierungsmitglieder</a> bereit.
    </p>
  </section>


  <section class="section">
    <div class="section-header">
      <h2>Regierungsprojekte im Kabinettszuschnitt</h2>
      <p>
        Themen und Projekte sind nicht losgelöst, sondern klar an federführende Ressorts und
        Kabinettsstrukturen angebunden.
      </p>
    </div>
    <div class="card-grid card-grid--two">
      {topicHighlights.map((topic) => (
        <TopicCard
          topic={topic}
          ministryName={ministryLookup.get(topic.federfuehrendesRessort)?.kurzname}
        />
      ))}
    </div>
  </section>
</BaseLayout>
