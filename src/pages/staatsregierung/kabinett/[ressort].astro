---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import InlineEditTrigger from '../../../components/editorial/InlineEditTrigger.astro';
import InlineEditorPanel from '../../../components/editorial/InlineEditorPanel.astro';
import PageTools from '../../../components/editorial/PageTools.astro';
import TopicCard from '../../../components/portal/TopicCard.astro';
import { getDatabase } from '../../../lib/dynamic/env.ts';
import {
  getGovernmentUrl,
  getHomeUrl,
  getMinistriesUrl,
  getMinistryUrl,
  resolvePortalPath,
} from '../../../lib/portal/index.ts';
import {
  getRuntimeNormLookup,
  loadRuntimeMinistryBySlug,
  loadRuntimeTopics,
} from '../../../lib/runtime-content/index.ts';
import { getNormUrl } from '../../../lib/norms/index.ts';
import {
  resolveMinistryPageContent,
  shouldRenderEditorialUi,
} from '../../../lib/editorial/live.ts';
import { getEditorialSessionLogoutHref } from '../../../lib/editorial/session.ts';
import {
  buildInlineEditHref,
  buildInlineSectionState,
  getInlineBaseDraft,
  getInlineFieldDefinition,
  getInlinePanelState,
  getInlineSectionStatusLabel,
} from '../../../lib/editorial/inline.ts';
import type { EditorialInlineSectionState } from '../../../lib/editorial/inline.ts';

const slug = Astro.params.ressort ?? '';
const fallbackMinistry = slug ? loadRuntimeMinistryBySlug(slug) : undefined;
const { ministry, editorial } = await resolveMinistryPageContent(slug, fallbackMinistry);

if (!ministry) {
  Astro.response.status = 404;
}

const topics = loadRuntimeTopics();
const normLookup = getRuntimeNormLookup();
const relatedTopics = ministry
  ? topics.filter(
      (topic) =>
        topic.federfuehrendesRessort === ministry.slug ||
        (topic.mitzeichnungsressorts ?? []).includes(ministry.slug),
    )
  : [];
const legalReferences = Array.from(
  new Map(
    relatedTopics.flatMap((topic) =>
      topic.rechtsgrundlagen.map((entry) => [
        entry.normSlug ?? `${topic.slug}:${entry.label}`,
        {
          ...entry,
          topicTitle: topic.title,
          norm: entry.normSlug ? normLookup.get(entry.normSlug) : undefined,
        },
      ]),
    ),
  ).values(),
).slice(0, 10);
const showEditorialUi = await shouldRenderEditorialUi(Astro.request, Astro.url);
const editorialSessionLogoutHref = getEditorialSessionLogoutHref(Astro.url.pathname);
const database = showEditorialUi ? getDatabase() : undefined;
const inlineBase = showEditorialUi && database && slug
  ? await getInlineBaseDraft(database, 'ressort', slug)
  : undefined;

function getInlineState(fieldKey: string): EditorialInlineSectionState | undefined {
  if (!inlineBase) {
    return undefined;
  }

  const definition = getInlineFieldDefinition('ressort', fieldKey);
  return definition
    ? buildInlineSectionState(
        'ressort',
        definition,
        inlineBase.sourceOrigin,
        inlineBase.fallbackDraft,
        inlineBase.currentDraft,
        inlineBase.publishedDraft,
      )
    : undefined;
}

const heroInline = getInlineState('hero');
const mediaInline = getInlineState('media');
const tasksInline = getInlineState('aufgaben');
const contactInline = getInlineState('kontakt');
const inlinePanel =
  showEditorialUi && database && slug && Astro.url.searchParams.get('editor')
    ? await getInlinePanelState(database, Astro.url, 'ressort', slug, Astro.url.searchParams.get('editor') ?? '')
    : undefined;
const editorMessage = Astro.url.searchParams.get('message') ?? undefined;
const editorError = Astro.url.searchParams.get('error') ?? undefined;
---

{ministry ? (
  <BaseLayout
    title={`${ministry.kurzname} | ${ministry.name}`}
    description={ministry.teaser}
    breadcrumbs={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Staatsregierung', href: getGovernmentUrl() },
      { label: 'Kabinett', href: getMinistriesUrl() },
      { label: ministry.kurzname },
    ]}
    ogImage={{
      url: ministry.bild,
      alt: ministry.bildAlt ?? `Ansichtsbild für das ${ministry.name}`,
    }}
  >
    <Breadcrumbs
      items={[
        { label: 'Startseite', href: getHomeUrl() },
        { label: 'Staatsregierung', href: getGovernmentUrl() },
        { label: 'Kabinett', href: getMinistriesUrl() },
        { label: ministry.kurzname },
      ]}
    />

    <section class="section page-header">
      <p class="eyebrow">Ressort</p>
      <h1>{ministry.name}</h1>
      <p class="lead">{ministry.teaser}</p>
      <p class="detail-line">{ministry.leitung}</p>
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(heroInline)}
        href={buildInlineEditHref(Astro.url, 'hero')}
        label="Ressortkopf"
        statusLabel={heroInline ? getInlineSectionStatusLabel(heroInline) : 'Fallback'}
      />
    </section>

    <section class="section">
      <PageTools
        visible={showEditorialUi}
        studioHref={editorial.studioHref}
        sourceLabel={editorial.sourceLabel}
        liveLabel={editorial.liveLabel}
        hasPendingChanges={editorial.entryState.hasPendingChanges}
        sessionDisableHref={editorialSessionLogoutHref}
      />
    </section>

    <div class="content-grid">
      <section class="section">
        <InlineEditTrigger
          visible={showEditorialUi && Boolean(mediaInline)}
          href={buildInlineEditHref(Astro.url, 'media')}
          label="Medienblock"
          statusLabel={mediaInline ? getInlineSectionStatusLabel(mediaInline) : 'Fallback'}
        />
        <img
          class="media-banner"
          src={resolvePortalPath(ministry.bild)}
          alt={ministry.bildAlt ?? `Ansichtsbild für das ${ministry.name}`}
        />
        <p class="media-credit">Bildnachweis: {ministry.bildnachweis}</p>
        <div class="status-notice status-notice--current">
          <h2>Ressortprofil</h2>
          <p>
            Die Ressortseite fasst Auftrag, Aufgaben, Themenbezug und Kontakt des Ressorts in einer
            kompakten, regierungsnahen Form zusammen.
          </p>
        </div>
        <div class="body-copy">
          <p>{ministry.teaser}</p>
        </div>

        <div class="section-header">
          <h2>Aufgaben</h2>
        </div>
        <InlineEditTrigger
          visible={showEditorialUi && Boolean(tasksInline)}
          href={buildInlineEditHref(Astro.url, 'aufgaben')}
          label="Aufgaben"
          statusLabel={tasksInline ? getInlineSectionStatusLabel(tasksInline) : 'Fallback'}
        />
        <ul class="record-list">
          {ministry.aufgaben.map((task) => (
            <li class="record-list__item">
              <span>{task}</span>
            </li>
          ))}
        </ul>

        <div class="section-header">
          <h2>Thematische Schwerpunkte</h2>
        </div>
        <div class="tag-list">
          {ministry.themen.map((topic) => (
            <span class="tag">{topic}</span>
          ))}
        </div>
      </section>

      <aside class="section meta-panel">
        <div class="section-header section-header--compact">
          <h2>Kontakt</h2>
        </div>
        <InlineEditTrigger
          visible={showEditorialUi && Boolean(contactInline)}
          href={buildInlineEditHref(Astro.url, 'kontakt')}
          label="Kontaktblock"
          statusLabel={contactInline ? getInlineSectionStatusLabel(contactInline) : 'Fallback'}
        />
        <dl class="meta-list">
          <div>
            <dt>Leitung</dt>
            <dd>{ministry.leitung}</dd>
          </div>
          {ministry.kontakt.name ? (
            <div>
              <dt>Ansprechstelle</dt>
              <dd>{ministry.kontakt.name}</dd>
            </div>
          ) : null}
          {ministry.kontakt.referat ? (
            <div>
              <dt>Referat</dt>
              <dd>{ministry.kontakt.referat}</dd>
            </div>
          ) : null}
          <div>
            <dt>E-Mail</dt>
            <dd>{ministry.kontakt.email ?? 'wird ergänzt'}</dd>
          </div>
          <div>
            <dt>Telefon</dt>
            <dd>{ministry.kontakt.telefon ?? 'wird ergänzt'}</dd>
          </div>
        </dl>
        <nav class="link-list">
          {ministry.verknuepfteLinks.map((link) => (
            <a href={resolvePortalPath(link.href)}>{link.label}</a>
          ))}
          <a href={getMinistryUrl(ministry.slug)}>Stabile URL dieses Ressorts</a>
        </nav>
      </aside>
    </div>

    {relatedTopics.length > 0 ? (
      <section class="section section-muted">
        <div class="section-header">
          <h2>Zugeordnete Themen & Projekte</h2>
          <p>
            Diese Themenseiten werden federführend oder mitzeichnend von diesem Ressort begleitet.
          </p>
        </div>
        <div class="card-grid card-grid--two">
          {relatedTopics.map((topic) => (
            <TopicCard topic={topic} ministryName={ministry.kurzname} />
          ))}
        </div>
      </section>
    ) : null}

    {legalReferences.length > 0 ? (
      <section class="section">
        <div class="section-header">
          <h2>Rechtsgrundlagen aus den zugeordneten Themen</h2>
          <p>Die Übersicht zeigt direkte Verknüpfungen aus Themen- und Projektseiten in den Rechtsbereich.</p>
        </div>
        <ul class="record-list">
          {legalReferences.map((entry) => (
            <li class="record-list__item">
              {entry.norm ? (
                <strong><a class="inline-link" href={getNormUrl(entry.norm.slug)}>{entry.label}</a></strong>
              ) : (
                <strong>{entry.label}</strong>
              )}
              <span>Themenbezug: {entry.topicTitle}</span>
              {entry.note ? <span>{entry.note}</span> : null}
            </li>
          ))}
        </ul>
      </section>
    ) : null}

    <InlineEditorPanel
      visible={showEditorialUi && Boolean(inlinePanel)}
      currentUrl={Astro.url}
      panel={inlinePanel}
      message={editorMessage}
      errorMessage={editorError}
    />
  </BaseLayout>
) : (
  <BaseLayout
    title="Ressort nicht gefunden"
    description="Die angeforderte Ressortseite konnte nicht geladen werden."
    breadcrumbs={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Staatsregierung', href: getGovernmentUrl() },
      { label: 'Kabinett', href: getMinistriesUrl() },
      { label: 'Nicht gefunden' },
    ]}
  >
    <Breadcrumbs
      items={[
        { label: 'Startseite', href: getHomeUrl() },
        { label: 'Staatsregierung', href: getGovernmentUrl() },
        { label: 'Kabinett', href: getMinistriesUrl() },
        { label: 'Nicht gefunden' },
      ]}
    />

    <section class="section">
      <div class="status-notice status-notice--warning">
        <h1>Ressortseite nicht gefunden</h1>
        <p>Für diese URL liegt weder ein statisches Ressortprofil noch ein veröffentlichter D1-Override vor.</p>
      </div>
    </section>
  </BaseLayout>
)}
