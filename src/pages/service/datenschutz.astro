---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InlineEditTrigger from '../../components/editorial/InlineEditTrigger.astro';
import InlineEditorPanel from '../../components/editorial/InlineEditorPanel.astro';
import PageTools from '../../components/editorial/PageTools.astro';
import { getDatabase } from '../../lib/dynamic/env.ts';
import {
  buildInlineEditHref,
  buildInlineSectionState,
  getInlineBaseDraft,
  getInlineFieldDefinition,
  getInlinePanelState,
  getInlineSectionStatusLabel,
} from '../../lib/editorial/inline.ts';
import type { EditorialInlineSectionState } from '../../lib/editorial/inline.ts';
import { getHomeUrl, getServiceUrl } from '../../lib/portal/index.ts';
import { loadRuntimeServicePageBySlug } from '../../lib/runtime-content/index.ts';
import {
  resolveServicePageContent,
  shouldRenderEditorialUi,
} from '../../lib/editorial/live.ts';
import { getEditorialSessionLogoutHref } from '../../lib/editorial/session.ts';

const { page, editorial } = await resolveServicePageContent(
  'datenschutz',
  loadRuntimeServicePageBySlug('datenschutz'),
);
const showEditorialUi = await shouldRenderEditorialUi(Astro.request, Astro.url);
const editorialSessionLogoutHref = getEditorialSessionLogoutHref(Astro.url.pathname);
const database = showEditorialUi ? getDatabase() : undefined;
const inlineBase = showEditorialUi && database
  ? await getInlineBaseDraft(database, 'service-seite', 'datenschutz')
  : undefined;

function getInlineState(fieldKey: string): EditorialInlineSectionState | undefined {
  if (!inlineBase) {
    return undefined;
  }

  const definition = getInlineFieldDefinition('service-seite', fieldKey);
  return definition
    ? buildInlineSectionState(
        'service-seite',
        definition,
        inlineBase.sourceOrigin,
        inlineBase.fallbackDraft,
        inlineBase.currentDraft,
        inlineBase.publishedDraft,
      )
    : undefined;
}

const heroInline = getInlineState('hero');
const bodyInline = getInlineState('body');
const inlinePanel =
  showEditorialUi && database && Astro.url.searchParams.get('editor')
    ? await getInlinePanelState(database, Astro.url, 'service-seite', 'datenschutz', Astro.url.searchParams.get('editor') ?? '')
    : undefined;
const editorMessage = Astro.url.searchParams.get('message') ?? undefined;
const editorError = Astro.url.searchParams.get('error') ?? undefined;
---

<BaseLayout title={page?.title ?? 'Datenschutz'} description="Datenschutzhinweise des Regierungsportals.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Service', href: getServiceUrl() },
      { label: 'Datenschutz' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>{page?.title ?? 'Datenschutz'}</h1>
    <InlineEditTrigger
      visible={showEditorialUi && Boolean(heroInline)}
      href={buildInlineEditHref(Astro.url, 'hero')}
      label="Seitentitel"
      statusLabel={heroInline ? getInlineSectionStatusLabel(heroInline) : 'Fallback'}
    />
  </section>

  <section class="section">
    <PageTools
      visible={showEditorialUi}
      studioHref={editorial.studioHref}
      sourceLabel={editorial.sourceLabel}
      liveLabel={editorial.liveLabel}
      hasPendingChanges={editorial.entryState.hasPendingChanges}
      sessionDisableHref={editorialSessionLogoutHref}
    />
  </section>

  <div class="content-grid">
    <section class="section body-copy">
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(bodyInline)}
        href={buildInlineEditHref(Astro.url, 'body')}
        label="Inhaltsblock"
        statusLabel={bodyInline ? getInlineSectionStatusLabel(bodyInline) : 'Fallback'}
      />
      {(page?.body ?? []).map((paragraph) => (
        <p>{paragraph}</p>
      ))}

      <div class="section-header">
        <h2>Technische Einordnung</h2>
      </div>
      <p>
        Die Website wird als statischer Build ausgeliefert. Es gibt keine Loginbereiche, keine
        serverseitige Formularverarbeitung und keine nutzerbezogene Datenbank.
      </p>
      <p>
        Suchfunktionen im Rechtsbereich greifen auf einen vorab erzeugten Suchindex zurück, der
        beim Build in statische Dateien geschrieben wird.
      </p>

      <div class="section-header">
        <h2>Webanalyse mit Google Analytics 4</h2>
      </div>
      <p>
        Zur technischen Reichweitenmessung kann Google Analytics 4 eingesetzt werden. Die
        Einbindung erfolgt clientseitig im Browser. In der aktuellen Konfiguration ist die
        Webanalyse standardmäßig aktiviert; eine gespeicherte Ablehnung überschreibt diesen
        Standard für das jeweilige Gerät.
      </p>
      <p>
        Google kann dabei Informationen über die Nutzung der Website verarbeiten. Die Integration
        nutzt die von Google bereitgestellte Tag-Infrastruktur und setzt keine eigene
        serverseitige Tracking-Architektur ein.
      </p>
      <p>
        Eine bereits getroffene Entscheidung wird lokal im Browser gespeichert. Sie können diese
        Entscheidung jederzeit zurücksetzen.
      </p>
      <p>
        <button type="button" class="button-link button-link--secondary" data-analytics-consent-reset>
          Analytics-Entscheidung zurücksetzen
        </button>
      </p>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Datenschutzprofil</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Architektur</dt>
          <dd>Vollständig statische Auslieferung</dd>
        </div>
        <div>
          <dt>Backend</dt>
          <dd>Kein Login, keine Datenbank und keine serverseitige Formverarbeitung</dd>
        </div>
        <div>
          <dt>Suche</dt>
          <dd>Vorab generierter Suchindex im Rechtsbereich</dd>
        </div>
        <div>
          <dt>Webanalyse</dt>
          <dd>Google Analytics 4, Standard derzeit aktiviert</dd>
        </div>
      </dl>
    </aside>
  </div>

  <InlineEditorPanel
    visible={showEditorialUi && Boolean(inlinePanel)}
    currentUrl={Astro.url}
    panel={inlinePanel}
    message={editorMessage}
    errorMessage={editorError}
  />
</BaseLayout>
