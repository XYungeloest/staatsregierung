---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getHomeUrl, getServiceUrl, loadPageBySlug } from '../../lib/portal/index.ts';

const page = await loadPageBySlug('datenschutz');
---

<BaseLayout title={page?.title ?? 'Datenschutz'} description="Datenschutzhinweise des Regierungsportals.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Service', href: getServiceUrl() },
      { label: 'Datenschutz' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>{page?.title ?? 'Datenschutz'}</h1>
  </section>

  <div class="content-grid">
    <section class="section body-copy">
      {(page?.body ?? []).map((paragraph) => (
        <p>{paragraph}</p>
      ))}

      <div class="section-header">
        <h2>Technische Einordnung</h2>
      </div>
      <p>
        Die Website wird als statischer Build ausgeliefert. Es gibt keine Loginbereiche, keine
        serverseitige Formularverarbeitung und keine nutzerbezogene Datenbank.
      </p>
      <p>
        Suchfunktionen im Rechtsbereich greifen auf einen vorab erzeugten Suchindex zurück, der
        beim Build in statische Dateien geschrieben wird.
      </p>

      <div class="section-header">
        <h2>Webanalyse mit Google Analytics 4</h2>
      </div>
      <p>
        Zur technischen Reichweitenmessung kann Google Analytics 4 eingesetzt werden. Die
        Einbindung erfolgt clientseitig im Browser. In der aktuellen Konfiguration ist die
        Webanalyse standardmäßig aktiviert; eine gespeicherte Ablehnung überschreibt diesen
        Standard für das jeweilige Gerät.
      </p>
      <p>
        Google kann dabei Informationen über die Nutzung der Website verarbeiten. Die Integration
        nutzt die von Google bereitgestellte Tag-Infrastruktur und setzt keine eigene
        serverseitige Tracking-Architektur ein.
      </p>
      <p>
        Eine bereits getroffene Entscheidung wird lokal im Browser gespeichert. Sie können diese
        Entscheidung jederzeit zurücksetzen.
      </p>
      <p>
        <button type="button" class="button-link button-link--secondary" data-analytics-consent-reset>
          Analytics-Entscheidung zurücksetzen
        </button>
      </p>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Datenschutzprofil</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Architektur</dt>
          <dd>Vollständig statische Auslieferung</dd>
        </div>
        <div>
          <dt>Backend</dt>
          <dd>Kein Login, keine Datenbank und keine serverseitige Formverarbeitung</dd>
        </div>
        <div>
          <dt>Suche</dt>
          <dd>Vorab generierter Suchindex im Rechtsbereich</dd>
        </div>
        <div>
          <dt>Webanalyse</dt>
          <dd>Google Analytics 4, Standard derzeit aktiviert</dd>
        </div>
      </dl>
    </aside>
  </div>
</BaseLayout>
