---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import {
  getAccessibilityUrl,
  getCareerUrl,
  getContactUrl,
  getFaqUrl,
  getHomeUrl,
  getImprintUrl,
  getPrivacyUrl,
  getServiceOverviewUrl,
  loadJobOffers,
} from '../../lib/portal/index.ts';

const offers = await loadJobOffers();
---

<BaseLayout title="Service" description="Servicebereich der Staatsregierung.">
  <Breadcrumbs items={[{ label: 'Startseite', href: getHomeUrl() }, { label: 'Service' }]} />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>Service</h1>
    <p class="lead">
      Der Servicebereich bündelt Karriere, Kontakt, FAQ sowie rechtlich-organisatorische Hinweise
      an einem einheitlichen Ort.
    </p>
    <p class="detail-line">
      <a class="inline-link" href={getServiceOverviewUrl()}>Zur kompakten Übersicht aller Portalbereiche</a>
    </p>
  </section>

  <section class="section">
    <div class="meta-grid">
      <div class="meta-card">
        <span class="meta-label">Stellenangebote</span>
        <strong>{offers.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Kontaktlogik</span>
        <strong>Digitaler Wegweiser</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Formularverarbeitung</span>
        <strong>Keine</strong>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h2>Karriere</h2>
        <p>Offene Stellen, Rahmendaten und Kontaktwege für die Arbeit in der Landesverwaltung.</p>
        <p><a class="inline-link" href={getCareerUrl()}>Zur Karriere</a></p>
      </article>
      <article class="panel">
        <h2>Kontakt</h2>
        <p>Zentrale Kontaktwege und ein digitaler Zuständigkeitswegweiser für typische Anliegen.</p>
        <p><a class="inline-link" href={getContactUrl()}>Zum Kontakt</a></p>
      </article>
      <article class="panel">
        <h2>FAQ</h2>
        <p>Hilfen zur Nutzung des Rechtsportals, zu Downloads, Informationsanträgen und Kontaktwegen.</p>
        <p><a class="inline-link" href={getFaqUrl()}>Zur FAQ</a></p>
      </article>
      <article class="panel">
        <h2>Barrierefreiheit</h2>
        <p>BITV-artig aufgebaute Hinweisseite mit Stand, bekannten Einschränkungen und Feedbackweg.</p>
        <p><a class="inline-link" href={getAccessibilityUrl()}>Zur Barrierefreiheit</a></p>
      </article>
      <article class="panel">
        <h2>Impressum</h2>
        <p>Verantwortlichkeiten und Einordnung der fiktiven Regierungswebsite.</p>
        <p><a class="inline-link" href={getImprintUrl()}>Zum Impressum</a></p>
      </article>
      <article class="panel">
        <h2>Datenschutz</h2>
        <p>Datenschutzhinweise zu statischer Auslieferung, optional speicherbarer Analytics-Entscheidung und fehlendem Formularbackend.</p>
        <p><a class="inline-link" href={getPrivacyUrl()}>Zum Datenschutz</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
