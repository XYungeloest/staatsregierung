---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InlineEditTrigger from '../../components/editorial/InlineEditTrigger.astro';
import InlineEditorPanel from '../../components/editorial/InlineEditorPanel.astro';
import PageTools from '../../components/editorial/PageTools.astro';
import { getDatabase } from '../../lib/dynamic/env.ts';
import {
  buildInlineEditHref,
  buildInlineSectionState,
  getInlineBaseDraft,
  getInlineFieldDefinition,
  getInlinePanelState,
  getInlineSectionStatusLabel,
} from '../../lib/editorial/inline.ts';
import type { EditorialInlineSectionState } from '../../lib/editorial/inline.ts';
import { getContactUrl, getHomeUrl, getServiceUrl } from '../../lib/portal/index.ts';
import { loadRuntimeServicePageBySlug } from '../../lib/runtime-content/index.ts';
import {
  resolveServicePageContent,
  shouldRenderEditorialUi,
} from '../../lib/editorial/live.ts';
import { getEditorialSessionLogoutHref } from '../../lib/editorial/session.ts';

const { page, editorial } = await resolveServicePageContent(
  'barrierefreiheit',
  loadRuntimeServicePageBySlug('barrierefreiheit'),
);
const showEditorialUi = await shouldRenderEditorialUi(Astro.request, Astro.url);
const editorialSessionLogoutHref = getEditorialSessionLogoutHref(Astro.url.pathname);
const database = showEditorialUi ? getDatabase() : undefined;
const inlineBase = showEditorialUi && database
  ? await getInlineBaseDraft(database, 'service-seite', 'barrierefreiheit')
  : undefined;

function getInlineState(fieldKey: string): EditorialInlineSectionState | undefined {
  if (!inlineBase) {
    return undefined;
  }

  const definition = getInlineFieldDefinition('service-seite', fieldKey);
  return definition
    ? buildInlineSectionState(
        'service-seite',
        definition,
        inlineBase.sourceOrigin,
        inlineBase.fallbackDraft,
        inlineBase.currentDraft,
        inlineBase.publishedDraft,
      )
    : undefined;
}

const heroInline = getInlineState('hero');
const bodyInline = getInlineState('body');
const inlinePanel =
  showEditorialUi && database && Astro.url.searchParams.get('editor')
    ? await getInlinePanelState(database, Astro.url, 'service-seite', 'barrierefreiheit', Astro.url.searchParams.get('editor') ?? '')
    : undefined;
const editorMessage = Astro.url.searchParams.get('message') ?? undefined;
const editorError = Astro.url.searchParams.get('error') ?? undefined;
---

<BaseLayout title={page?.title ?? 'Barrierefreiheit'} description="Hinweise zur Barrierefreiheit des Regierungsportals.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Service', href: getServiceUrl() },
      { label: 'Barrierefreiheit' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>{page?.title ?? 'Barrierefreiheit'}</h1>
    <p class="lead">
      Diese Erklärung orientiert sich in Aufbau und Ton an BITV-artigen Musterseiten, bleibt aber
      Teil einer fiktiven Politiksimulation.
    </p>
    <InlineEditTrigger
      visible={showEditorialUi && Boolean(heroInline)}
      href={buildInlineEditHref(Astro.url, 'hero')}
      label="Seitentitel"
      statusLabel={heroInline ? getInlineSectionStatusLabel(heroInline) : 'Ausgangsstand'}
    />
  </section>

  <section class="section">
    <PageTools
      visible={showEditorialUi}
      studioHref={editorial.studioHref}
      sourceLabel={editorial.sourceLabel}
      liveLabel={editorial.liveLabel}
      hasPendingChanges={editorial.entryState.hasPendingChanges}
      sessionDisableHref={editorialSessionLogoutHref}
    />
  </section>

  <div class="content-grid">
    <section class="section body-copy">
      <InlineEditTrigger
        visible={showEditorialUi && Boolean(bodyInline)}
        href={buildInlineEditHref(Astro.url, 'body')}
        label="Inhaltsblock"
        statusLabel={bodyInline ? getInlineSectionStatusLabel(bodyInline) : 'Ausgangsstand'}
      />
      {(page?.body ?? []).map((paragraph) => (
        <p>{paragraph}</p>
      ))}

      <div class="section-header">
        <h2>Stand der Vereinbarkeit</h2>
      </div>
      <p>
        Das Portal ist darauf ausgelegt, die Anforderungen an eine barrierearme Nutzung weitgehend
        zu erfüllen. Dazu gehören semantische Struktur, Tastaturbedienbarkeit, ausreichende
        Kontraste, lesbare Typografie und klare Navigationspfade.
      </p>

      <div class="section-header">
        <h2>Bekannte Einschränkungen</h2>
      </div>
      <ul class="record-list">
        <li class="record-list__item"><span>Einzelne Platzhaltergrafiken tragen nur allgemeine Alternativtexte.</span></li>
        <li class="record-list__item"><span>Clientseitige Hilfslogiken wie Filter und Zuständigkeitswegweiser werden fortlaufend auf Tastaturbedienbarkeit geprüft.</span></li>
        <li class="record-list__item"><span>Historisch importierte Inhalte können in Einzelfällen noch heterogene Textstrukturen enthalten.</span></li>
      </ul>

      <div class="section-header">
        <h2>Feedback und Kontakt</h2>
      </div>
      <p>
        Hinweise zur Barrierefreiheit, zu Darstellungsproblemen oder zu nicht ausreichend
        zugänglichen Inhalten können über die Kontaktseite übermittelt werden.
      </p>
      <p><a class="inline-link" href={getContactUrl()}>Zur Kontaktseite</a></p>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Prüfprofil</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Stand</dt>
          <dd>Fortlaufende Prüfung und redaktionelle Verbesserung</dd>
        </div>
        <div>
          <dt>Prüfgegenstände</dt>
          <dd>Navigation, Formulare, Kartenmodule, Rechtsportal, Mobile Darstellung</dd>
        </div>
        <div>
          <dt>Rückmeldung</dt>
          <dd>Über die zentrale Kontaktseite</dd>
        </div>
      </dl>
    </aside>
  </div>

  <InlineEditorPanel
    visible={showEditorialUi && Boolean(inlinePanel)}
    currentUrl={Astro.url}
    panel={inlinePanel}
    message={editorMessage}
    errorMessage={editorError}
  />
</BaseLayout>
