---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getHomeUrl, getServiceUrl, loadPageBySlug } from '../../lib/portal/index.ts';

const page = await loadPageBySlug('barrierefreiheit');
---

<BaseLayout title={page?.title ?? 'Barrierefreiheit'} description="Hinweise zur Barrierefreiheit des Regierungsportals.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Service', href: getServiceUrl() },
      { label: 'Barrierefreiheit' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>{page?.title ?? 'Barrierefreiheit'}</h1>
  </section>

  <div class="content-grid">
    <section class="section body-copy">
      {(page?.body ?? []).map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Stand der Umsetzung</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Navigation</dt>
          <dd>Semantische Struktur mit Header, Footer, Breadcrumbs und Skip-Link</dd>
        </div>
        <div>
          <dt>Darstellung</dt>
          <dd>Klare Kontraste, ruhige Typografie und verständliche Inhaltsblöcke</dd>
        </div>
        <div>
          <dt>Hinweise</dt>
          <dd>Rückmeldungen können über die zentrale Kontaktseite erfolgen</dd>
        </div>
      </dl>
    </aside>
  </div>
</BaseLayout>
