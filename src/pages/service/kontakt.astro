---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import InlineEditTrigger from '../../components/editorial/InlineEditTrigger.astro';
import InlineEditorPanel from '../../components/editorial/InlineEditorPanel.astro';
import PageTools from '../../components/editorial/PageTools.astro';
import ServiceCard from '../../components/portal/ServiceCard.astro';
import { siteConfig } from '../../config/site.ts';
import { getDatabase } from '../../lib/dynamic/env.ts';
import {
  buildInlineEditHref,
  buildInlineSectionState,
  getInlineBaseDraft,
  getInlineFieldDefinition,
  getInlinePanelState,
  getInlineSectionStatusLabel,
} from '../../lib/editorial/inline.ts';
import type { EditorialInlineSectionState } from '../../lib/editorial/inline.ts';
import {
  getCareerUrl,
  getFaqUrl,
  getHomeUrl,
  getLawHomeUrl,
  getMinistryUrl,
  getServiceUrl,
} from '../../lib/portal/index.ts';
import { loadRuntimeMinistries, loadRuntimeServicePageBySlug } from '../../lib/runtime-content/index.ts';
import {
  resolveServicePageContent,
  shouldRenderEditorialUi,
} from '../../lib/editorial/live.ts';
import { getEditorialSessionLogoutHref } from '../../lib/editorial/session.ts';

const { page, editorial } = await resolveServicePageContent(
  'kontakt',
  loadRuntimeServicePageBySlug('kontakt'),
);
const contact = siteConfig.contact;
const ministries = loadRuntimeMinistries();
const showEditorialUi = await shouldRenderEditorialUi(Astro.request, Astro.url);
const editorialSessionLogoutHref = getEditorialSessionLogoutHref(Astro.url.pathname);
const database = showEditorialUi ? getDatabase() : undefined;
const inlineBase = showEditorialUi && database
  ? await getInlineBaseDraft(database, 'service-seite', 'kontakt')
  : undefined;

function getInlineState(fieldKey: string): EditorialInlineSectionState | undefined {
  if (!inlineBase) {
    return undefined;
  }

  const definition = getInlineFieldDefinition('service-seite', fieldKey);
  return definition
    ? buildInlineSectionState(
        'service-seite',
        definition,
        inlineBase.sourceOrigin,
        inlineBase.fallbackDraft,
        inlineBase.currentDraft,
        inlineBase.publishedDraft,
      )
    : undefined;
}

const heroInline = getInlineState('hero');
const bodyInline = getInlineState('body');
const inlinePanel =
  showEditorialUi && database && Astro.url.searchParams.get('editor')
    ? await getInlinePanelState(database, Astro.url, 'service-seite', 'kontakt', Astro.url.searchParams.get('editor') ?? '')
    : undefined;
const editorMessage = Astro.url.searchParams.get('message') ?? undefined;
const editorError = Astro.url.searchParams.get('error') ?? undefined;
const routedContacts = [
  {
    key: 'allgemein',
    title: 'Allgemeine Anfragen',
    description: 'Für allgemeine Bürgeranliegen und Hinweise ist das Bürgertelefon der richtige erste Kontaktweg.',
    primaryLabel: contact.citizenService.label,
    primaryValue: `${contact.citizenService.phone} · ${contact.citizenService.email}`,
    links: [{ label: 'Zur FAQ', href: getFaqUrl() }],
  },
  {
    key: 'presse',
    title: 'Presseanfragen',
    description: 'Für Medienanfragen, Pressetermine und kurzfristige Auskünfte ist die Pressestelle zuständig.',
    primaryLabel: contact.pressOffice.label,
    primaryValue: `${contact.pressOffice.phone} · ${contact.pressOffice.email}`,
    links: [],
  },
  {
    key: 'recht',
    title: 'Rechtsportal und Normensuche',
    description: 'Fragen zur Recherche beginnen in der Regel direkt im Rechtsbereich oder in der FAQ zur Portalnutzung.',
    primaryLabel: 'Rechtsbereich',
    primaryValue: 'Aktuelle Fassungen, Historien und Suche',
    links: [{ label: 'Zum Rechtsportal', href: getLawHomeUrl() }, { label: 'Zur FAQ', href: getFaqUrl() }],
  },
  {
    key: 'informationsantrag',
    title: 'Informationsanträge und Transparenz',
    description: 'Anliegen zum Informationszugang sollten zuerst anhand der Transparenz- und Informationshinweise geprüft werden.',
    primaryLabel: 'Hinweis',
    primaryValue: 'Prüfung über FAQ, Rechtsgrundlagen und zuständiges Ressort',
    links: [{ label: 'Zum Rechtsportal', href: getLawHomeUrl() }, { label: 'Zur FAQ', href: getFaqUrl() }],
  },
  {
    key: 'karriere',
    title: 'Karriere und Stellenangebote',
    description: 'Für Rückfragen zu Ausschreibungen ist die jeweils in der Stellenanzeige genannte Kontaktstelle maßgeblich.',
    primaryLabel: 'Karrierebereich',
    primaryValue: 'Stellenübersicht und Ansprechpartner je Ausschreibung',
    links: [{ label: 'Zur Karriere', href: getCareerUrl() }],
  },
];
---

<BaseLayout
  title={page?.title ?? 'Kontakt'}
  description="Kontaktseite der Staatsregierung."
  scripts={['portal-modules']}
>
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Service', href: getServiceUrl() },
      { label: 'Kontakt' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>{page?.title ?? 'Kontakt'}</h1>
    <p class="lead">
      Zentrale Kontaktwege der Staatsregierung, der Pressestelle und der allgemeinen
      Servicekommunikation.
    </p>
    <InlineEditTrigger
      visible={showEditorialUi && Boolean(heroInline)}
      href={buildInlineEditHref(Astro.url, 'hero')}
      label="Seitentitel"
      statusLabel={heroInline ? getInlineSectionStatusLabel(heroInline) : 'Fallback'}
    />
  </section>

  <section class="section">
    <PageTools
      visible={showEditorialUi}
      studioHref={editorial.studioHref}
      sourceLabel={editorial.sourceLabel}
      liveLabel={editorial.liveLabel}
      hasPendingChanges={editorial.entryState.hasPendingChanges}
      sessionDisableHref={editorialSessionLogoutHref}
    />
  </section>

  <div class="content-grid">
    <section class="section">
      <div class="body-copy">
        <InlineEditTrigger
          visible={showEditorialUi && Boolean(bodyInline)}
          href={buildInlineEditHref(Astro.url, 'body')}
          label="Inhaltsblock"
          statusLabel={bodyInline ? getInlineSectionStatusLabel(bodyInline) : 'Fallback'}
        />
        {(page?.body ?? []).map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <div class="card-grid card-grid--three">
        <ServiceCard
          title={contact.citizenService.label}
          body={`${contact.citizenService.phone} · ${contact.citizenService.email}`}
        />
        <ServiceCard
          title={contact.pressOffice.label}
          body={`${contact.pressOffice.phone} · ${contact.pressOffice.email}`}
        />
        <ServiceCard title="Postanschrift" body={contact.postalAddress} />
      </div>

      <div class="section-header">
        <h2>Zuständigkeitswegweiser</h2>
        <p>Die Auswahl liefert nur einen Hinweis auf den passenden Kontaktweg. Es werden keine Daten übertragen.</p>
      </div>
      <form class="search-form" id="contact-router" data-role="contact-router">
        <label class="search-field">
          <span>Anliegen auswählen</span>
          <select name="topic">
            <option value="">Bitte auswählen</option>
            <option value="allgemein">Allgemeine Anfrage</option>
            <option value="presse">Presseanfrage</option>
            <option value="recht">Rechtsportal oder Normensuche</option>
            <option value="informationsantrag">Informationsantrag oder Transparenz</option>
            <option value="karriere">Karriere und Stellenangebote</option>
          </select>
        </label>
      </form>

      <div class="content-stack" id="contact-router-results">
        {routedContacts.map((entry) => (
          <article class="panel contact-route-card" data-route-key={entry.key} hidden>
            <h3>{entry.title}</h3>
            <p>{entry.description}</p>
            <p class="detail-line">
              <strong>{entry.primaryLabel}:</strong> {entry.primaryValue}
            </p>
            {entry.links.length > 0 ? (
              <p class="section-link-row">
                {entry.links.map((link, index) => (
                  <>
                    {index > 0 ? ' · ' : ''}
                    <a class="inline-link" href={link.href}>{link.label}</a>
                  </>
                ))}
              </p>
            ) : null}
          </article>
        ))}
      </div>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Zentrale Kontaktwege</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Telefon</dt>
          <dd>{contact.citizenService.phone}</dd>
        </div>
        <div>
          <dt>E-Mail</dt>
          <dd>{contact.citizenService.email}</dd>
        </div>
        <div>
          <dt>Anschrift</dt>
          <dd>{contact.addressLines.join(', ')}</dd>
        </div>
      </dl>
      <div class="section-header section-header--compact">
        <h2>Servicezeiten</h2>
      </div>
      <ul class="record-list">
        {contact.officeHours.map((entry) => (
          <li class="record-list__item"><span>{entry}</span></li>
        ))}
      </ul>
      <div class="section-header section-header--compact">
        <h2>Ressorts</h2>
      </div>
      <ul class="record-list">
        {ministries.slice(0, 6).map((ministry) => (
          <li class="record-list__item">
            <strong><a class="inline-link" href={getMinistryUrl(ministry.slug)}>{ministry.kurzname}</a></strong>
            <span>{ministry.leitung}</span>
          </li>
        ))}
      </ul>
      <p class="detail-line">
        Weitere fachliche Zuständigkeiten finden sich auf den jeweiligen Ressortseiten.
      </p>
    </aside>
  </div>

  <InlineEditorPanel
    visible={showEditorialUi && Boolean(inlinePanel)}
    currentUrl={Astro.url}
    panel={inlinePanel}
    message={editorMessage}
    errorMessage={editorError}
  />

</BaseLayout>
