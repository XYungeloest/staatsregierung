---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../config/site.ts';
import { getHomeUrl, getServiceUrl, loadPageBySlug } from '../../lib/portal/index.ts';

const page = await loadPageBySlug('impressum');
---

<BaseLayout title={page?.title ?? 'Impressum'} description="Impressum des Regierungsportals.">
  <Breadcrumbs
    items={[
      { label: 'Startseite', href: getHomeUrl() },
      { label: 'Service', href: getServiceUrl() },
      { label: 'Impressum' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>{page?.title ?? 'Impressum'}</h1>
  </section>

  <div class="content-grid">
    <section class="section body-copy">
      {(page?.body ?? []).map((paragraph) => (
        <p>{paragraph}</p>
      ))}
      <p>
        Das Projekt dient der Darstellung einer fiktiven Staatsregierung und eines integrierten
        Rechtsportals. Es beansprucht keine amtliche Authentizität und ersetzt keine reale
        Veröffentlichung einer Behörde.
      </p>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Verantwortung</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Stelle</dt>
          <dd>{siteConfig.contact.authorityShort}</dd>
        </div>
        <div>
          <dt>Sitz</dt>
          <dd>{siteConfig.contact.addressLines.join(', ')}</dd>
        </div>
        <div>
          <dt>Einordnung</dt>
          <dd>Fiktive Politiksimulation, keine echte amtliche Veröffentlichung</dd>
        </div>
      </dl>
    </aside>
  </div>
</BaseLayout>
