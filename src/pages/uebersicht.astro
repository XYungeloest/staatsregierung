---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import {
  getCareerUrl,
  getGovernmentMembersUrl,
  getGovernmentUrl,
  getHomeUrl,
  getJobsUrl,
  getLawHomeUrl,
  getLawIndexUrl,
  getLawSearchUrl,
  getLawSubjectsUrl,
  getMinistriesUrl,
  getPressUrl,
} from '../lib/portal/index.ts';

const sections = [
  {
    title: 'Staatsregierung',
    links: [
      { label: 'Regierung', href: getGovernmentUrl() },
      { label: 'Regierungsmitglieder', href: getGovernmentMembersUrl() },
      { label: 'Ministerien', href: getMinistriesUrl() },
    ],
  },
  {
    title: 'Presse und Karriere',
    links: [
      { label: 'Presse', href: getPressUrl() },
      { label: 'Karriere', href: getCareerUrl() },
      { label: 'Stellenangebote', href: getJobsUrl() },
    ],
  },
  {
    title: 'Rechtsbereich',
    links: [
      { label: 'Recht', href: getLawHomeUrl() },
      { label: 'Normensuche', href: getLawSearchUrl() },
      { label: 'Alphabetischer Index', href: getLawIndexUrl() },
      { label: 'Sachgebiete', href: getLawSubjectsUrl() },
    ],
  },
];
---

<BaseLayout title="Übersicht" description="Seitenübersicht des Regierungsportals.">
  <Breadcrumbs items={[{ label: 'Start', href: getHomeUrl() }, { label: 'Übersicht' }]} />

  <section class="section page-header">
    <p class="eyebrow">Service</p>
    <h1>Übersicht</h1>
    <p class="lead">Die Übersicht bündelt die wichtigsten Einstiege des Regierungsportals in einer kompakten Struktur.</p>
  </section>

  <div class="card-grid">
    {sections.map((section) => (
      <section class="panel">
        <h3>{section.title}</h3>
        <nav class="link-list">
          {section.links.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </section>
    ))}
  </div>
</BaseLayout>
