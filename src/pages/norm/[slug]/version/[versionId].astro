---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import NormBody from '../../../../components/norms/NormBody.astro';
import NormMetaCard from '../../../../components/norms/NormMetaCard.astro';
import NormOutline from '../../../../components/norms/NormOutline.astro';
import NormStatusNotice from '../../../../components/norms/NormStatusNotice.astro';
import { buildNormOutline, formatDate, toDisplayText } from '../../../../lib/norms/presentation.ts';
import {
  getHomeUrl,
  getNormHistoryUrl,
  getNormUrl,
  loadAllNorms,
} from '../../../../lib/norms/index.ts';

export async function getStaticPaths() {
  const norms = await loadAllNorms();

  return norms.flatMap((norm) =>
    norm.versions
      .filter((version) => !version.isCurrent)
      .map((version) => ({
        params: { slug: norm.meta.slug, versionId: version.versionId },
        props: { norm, version },
      })),
  );
}

const { norm, version } = Astro.props;
const outline = buildNormOutline(version.body);
---

<BaseLayout
  title={`${toDisplayText(norm.meta.title)} ${version.versionId}`}
  description={`Historische Fassung ${version.versionId} von ${toDisplayText(norm.meta.title)}.`}
>
  <Breadcrumbs
    items={[
      { label: 'Start', href: getHomeUrl() },
      { label: toDisplayText(norm.meta.shortTitle || norm.meta.title), href: getNormUrl(norm.meta.slug) },
      { label: `Fassung vom ${formatDate(version.validFrom)}` },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Historische Fassung</p>
    <h1>{toDisplayText(norm.meta.title)}</h1>
    <p class="lead">Diese Seite zeigt die gespeicherte konsolidierte Fassung mit dem Stand vom {formatDate(version.validFrom)}.</p>
    <p class="status-line">
      Gültig vom {formatDate(version.validFrom)} bis {version.validTo ? formatDate(version.validTo) : 'heute'}
    </p>
    <nav class="link-list link-list--inline" aria-label="Seitennavigation">
      <a href={getNormUrl(norm.meta.slug)}>Zur aktuellen Fassung</a>
      <a href={getNormHistoryUrl(norm.meta.slug)}>Zur Historie</a>
    </nav>
  </section>

  <NormStatusNotice norm={norm} version={version} historical={true} />

  <div class="content-grid">
    <div class="content-stack">
      <NormOutline items={outline} />
      <section class="section">
        <div class="section-header">
          <h2>Historischer Normtext</h2>
          <p>{toDisplayText(version.changeNote)}</p>
        </div>
        <NormBody blocks={version.body} />
      </section>
    </div>

    <NormMetaCard norm={norm} version={version} historical={true} />
  </div>
</BaseLayout>
