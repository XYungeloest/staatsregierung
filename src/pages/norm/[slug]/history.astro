---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCurrentVersion, getNormUrl, getNormVersionUrl, loadAllNorms } from '../../../lib/norms/index.ts';

export async function getStaticPaths() {
  const norms = await loadAllNorms();

  return norms.map((norm) => ({
    params: { slug: norm.meta.slug },
    props: { norm, currentVersion: getCurrentVersion(norm) },
  }));
}

const { norm, currentVersion } = Astro.props;
---

<BaseLayout title={`${norm.meta.title} Historie`} description={`Normenhistorie zu ${norm.meta.title}.`}>
  <section class="section page-header">
    <p class="eyebrow">Normenhistorie</p>
    <h1>{norm.meta.title}</h1>
    <p class="lead">Historienseite mit Stammfassung, Aenderungsbezuegen und allen gespeicherten Fassungen.</p>
    <nav class="link-list link-list--inline" aria-label="Seitennavigation">
      <a href={getNormUrl(norm.meta.slug)}>Zur aktuellen Fassung</a>
    </nav>
  </section>

  <div class="content-grid content-grid--wide">
    <section class="section">
      <div class="section-header">
        <h2>Fassungen</h2>
      </div>
      <ul class="timeline-list">
        {norm.versions.map((version) => (
          <li>
            <strong>
              {version.isCurrent ? (
                <a class="inline-link" href={getNormUrl(norm.meta.slug)}>{version.versionId}</a>
              ) : (
                <a class="inline-link" href={getNormVersionUrl(norm.meta.slug, version.versionId)}>{version.versionId}</a>
              )}
            </strong>
            <span>Gueltig von {version.validFrom} bis {version.validTo ?? 'heute'}</span>
            <span>{version.changeNote}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Historieneintraege</h2>
      </div>
      <ul class="timeline-list">
        {norm.history.entries.map((entry) => (
          <li>
            <strong>{entry.date}</strong>
            <span>{entry.title}</span>
            <span>{entry.citation}</span>
            {entry.relatedNorm ? <span>Bezug: {entry.relatedNorm}</span> : null}
          </li>
        ))}
      </ul>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Stammdaten</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Stammfassung</dt>
          <dd>{norm.history.initialVersionId}</dd>
        </div>
        <div>
          <dt>Aktueller Rechtsstand</dt>
          <dd>{currentVersion.validFrom}</dd>
        </div>
        <div>
          <dt>Vorgaenger</dt>
          <dd>{norm.meta.predecessor ?? 'keiner'}</dd>
        </div>
        <div>
          <dt>Nachfolger</dt>
          <dd>{norm.meta.successor ?? 'keiner'}</dd>
        </div>
      </dl>
    </section>
  </div>
</BaseLayout>
