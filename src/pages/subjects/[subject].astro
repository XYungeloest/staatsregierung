---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getNormUrl, getSubjectGroups, loadAllNorms } from '../../lib/norms/index.ts';

export async function getStaticPaths() {
  const groups = getSubjectGroups(await loadAllNorms());

  return groups.map((group) => ({
    params: { subject: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
---

<BaseLayout title={group.name} description={`Sachgebiet ${group.name} im Ostrecht-Portal.`}>
  <section class="section page-header">
    <p class="eyebrow">Sachgebiet</p>
    <h1>{group.name}</h1>
    <p class="lead">Diesem Sachgebiet sind aktuell {group.norms.length} Normen zugeordnet.</p>
  </section>

  <section class="section">
    <ul class="record-list">
      {group.norms.map((norm) => (
        <li class="record-list__item">
          <a class="inline-link" href={getNormUrl(norm.meta.slug)}>{norm.meta.title}</a>
          <span>{norm.meta.abbr} · {norm.meta.ministry}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
