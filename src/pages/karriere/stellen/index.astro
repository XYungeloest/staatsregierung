---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import JobOfferCard from '../../../components/portal/JobOfferCard.astro';
import { getCareerUrl, getHomeUrl, loadJobOffers } from '../../../lib/portal/index.ts';

const offers = await loadJobOffers();
---

<BaseLayout title="Stellenangebote" description="Offene Stellenangebote der Staatsregierung.">
  <Breadcrumbs
    items={[
      { label: 'Start', href: getHomeUrl() },
      { label: 'Karriere', href: getCareerUrl() },
      { label: 'Stellenangebote' },
    ]}
  />

  <section class="section page-header">
    <p class="eyebrow">Karriere</p>
    <h1>Stellenangebote</h1>
    <p class="lead">Die Stellenliste ist dateibasiert aufgebaut und führt jede Ausschreibung auf eine statische Detailseite.</p>
  </section>

  <section class="section">
    <div class="meta-grid">
      <div class="meta-card">
        <span class="meta-label">Offene Stellen</span>
        <strong>{offers.length}</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Bereiche</span>
        <strong>Verwaltung, Kommunikation, Kultur</strong>
      </div>
      <div class="meta-card">
        <span class="meta-label">Verfahren</span>
        <strong>Vollständig statisch</strong>
      </div>
    </div>
  </section>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Alle Ausschreibungen</h2>
      <p>Jede Ausschreibung enthält Ressort, Arbeitsort, Veröffentlichungsdatum, Bewerbungsfrist und Kontaktangaben.</p>
    </div>
    <div class="card-grid card-grid--two">
      {offers.map((offer) => (
        <JobOfferCard offer={offer} />
      ))}
    </div>
  </section>
</BaseLayout>
