---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getHomeUrl, getJobsUrl, loadCurrentJobOffers } from '../../lib/portal/index.ts';

const offers = await loadCurrentJobOffers(3);
---

<BaseLayout title="Karriere" description="Karrierebereich der Staatsregierung des Ostdeutschen Freistaates.">
  <Breadcrumbs items={[{ label: 'Start', href: getHomeUrl() }, { label: 'Karriere' }]} />

  <section class="section page-header">
    <p class="eyebrow">Karriere</p>
    <h1>Arbeiten für die Staatsregierung</h1>
    <p class="lead">
      Der Karrierebereich bündelt Stellenangebote und dient als Einstieg für künftige, dateibasierte
      Inhalte zu Berufsbildern und Bewerbungswegen.
    </p>
    <nav class="hero-actions" aria-label="Karrierenavigation">
      <a class="button-link" href={getJobsUrl()}>Zu den Stellenangeboten</a>
    </nav>
  </section>

  <div class="card-grid">
    {offers.map((offer) => (
      <article class="panel">
        <h3>{offer.title}</h3>
        <p>{offer.teaser}</p>
        <p class="detail-line">{offer.ministry}</p>
      </article>
    ))}
  </div>
</BaseLayout>
