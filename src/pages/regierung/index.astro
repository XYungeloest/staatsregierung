---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GovernmentMemberCard from '../../components/portal/GovernmentMemberCard.astro';
import { siteConfig } from '../../config/site.ts';
import {
  getCabinetUrl,
  getGovernmentMembersUrl,
  getHomeUrl,
  getMinistriesUrl,
  loadGovernmentMembers,
} from '../../lib/portal/index.ts';

const members = await loadGovernmentMembers();
const headOfGovernment = members[0];
const currentGovernment = siteConfig.currentGovernment;
const featuredMembers = members.slice(0, 4);
---

<BaseLayout title="Regierung" description="Übersichtsseite der Staatsregierung des Ostdeutschen Freistaates.">
  <Breadcrumbs items={[{ label: 'Start', href: getHomeUrl() }, { label: 'Regierung' }]} />

  <section class="section page-header">
    <p class="eyebrow">Staatsregierung</p>
    <h1>Regierung</h1>
    <p class="lead">
      Die Staatsregierung des Ostdeutschen Freistaates wird aktuell vom
      {` ${currentGovernment.cabinetName} `} getragen. Sie bündelt politische Leitung,
      Kabinettsarbeit und ressortübergreifende Koordinierung.
    </p>
    <nav class="link-list link-list--inline" aria-label="Regierungsnavigation">
      <a href={getGovernmentMembersUrl()}>Regierungsmitglieder</a>
      <a href={getCabinetUrl()}>Kabinett</a>
      <a href={getMinistriesUrl()}>Ministerien</a>
    </nav>
  </section>

  <div class="content-grid">
    <section class="section">
      <div class="section-header">
        <h2>Leitung der Staatsregierung</h2>
      </div>
      {headOfGovernment ? <GovernmentMemberCard member={headOfGovernment} /> : null}
      <div class="body-copy">
        <p>
          Die Regierung bestimmt die Richtlinien der Politik, bereitet Kabinettsentscheidungen vor
          und sorgt für die Abstimmung zwischen Staatskanzlei und Ministerien. Sie ist dem Landtag
          politisch verantwortlich.
        </p>
        <p>
          Seit dem {siteConfig.date.formatLong(currentGovernment.formedOn)} führt
          {` ${currentGovernment.headOfGovernment} `} die Staatsregierung. Stellvertretende
          Ministerpräsidentin ist {currentGovernment.deputyHead}.
        </p>
      </div>
    </section>

    <aside class="section meta-panel">
      <div class="section-header section-header--compact">
        <h2>Auf einen Blick</h2>
      </div>
      <dl class="meta-list">
        <div>
          <dt>Regierungsmitglieder</dt>
          <dd>{members.length}</dd>
        </div>
        <div>
          <dt>Führung</dt>
          <dd>{currentGovernment.headOfGovernment}</dd>
        </div>
        <div>
          <dt>Kabinett</dt>
          <dd>{currentGovernment.cabinetName}</dd>
        </div>
        <div>
          <dt>Koalition</dt>
          <dd>{currentGovernment.coalitionShort}</dd>
        </div>
      </dl>
    </aside>
  </div>

  <section class="section section-muted">
    <div class="section-header">
      <h2>Schwerpunkte der Regierungsarbeit</h2>
      <p>
        Die ersten Arbeitslinien des Kabinetts Honecker orientieren sich an den politischen
        Leitmotiven des jungen Freistaates.
      </p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Staatsaufbau</h3>
        <p>
          Verwaltung, Rechtsrahmen und staatliche Institutionen werden sichtbar als eigenständige
          ostdeutsche Landesordnung ausgestaltet.
        </p>
      </article>
      <article class="panel">
        <h3>Daseinsvorsorge</h3>
        <p>
          Gesundheit, Bildung, soziale Fürsorge und kommunale Handlungsfähigkeit bilden einen
          Schwerpunkt der laufenden Regierungsarbeit.
        </p>
      </article>
      <article class="panel">
        <h3>Infrastruktur und Profil</h3>
        <p>
          Mobilität, Medienordnung, regionale Entwicklung und öffentlich sichtbare Landespolitik
          prägen das Profil der Staatsregierung.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Regierungsmitglieder</h2>
      <p>Die Profile der Regierungsmitglieder sind als eigenständige, dateibasierte Inhalte angelegt.</p>
    </div>
    <div class="card-grid card-grid--two">
      {featuredMembers.map((member) => (
        <GovernmentMemberCard member={member} variant="compact" />
      ))}
    </div>
    <p class="section-link-row">
      <a class="inline-link" href={getGovernmentMembersUrl()}>Alle Regierungsmitglieder anzeigen</a>
    </p>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Struktur der Regierung</h2>
      <p>Die Regierung ist über drei Einstiege erschlossen und mit den Ministerien des Portals verknüpft.</p>
    </div>
    <div class="card-grid card-grid--three">
      <article class="panel">
        <h3>Kabinett</h3>
        <p>
          Die Kabinettsseite zeigt politische Einordnung, Portfoliozuschnitt und die aktuelle
          Zusammensetzung der Staatsregierung.
        </p>
        <p><a class="inline-link" href={getCabinetUrl()}>Zum Kabinett Honecker</a></p>
      </article>
      <article class="panel">
        <h3>Regierungsmitglieder</h3>
        <p>
          Einzelprofile führen Namen, Ämter, Ressorts und Kurzbiografien an einer stabilen URL
          zusammen.
        </p>
        <p><a class="inline-link" href={getGovernmentMembersUrl()}>Zu den Profilen</a></p>
      </article>
      <article class="panel">
        <h3>Ministerien</h3>
        <p>
          Die Ministerien ergänzen die Regierungsseite um Aufgaben, Themen, Kontaktangaben und
          Zuständigkeiten.
        </p>
        <p><a class="inline-link" href={getMinistriesUrl()}>Zu den Ministerien</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
