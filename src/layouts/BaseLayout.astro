---
import '../styles/global.css';
import AnalyticsConsentBanner from '../components/analytics/AnalyticsConsentBanner.astro';
import {
  analyticsConfig,
  getDefaultAnalyticsConsentState,
  isAnalyticsEnabled,
} from '../config/analytics.ts';
import {
  isEditorialNavLinkVisible,
  isOfficialStyleHeaderEnabled,
  isStickyHeaderEnabled,
} from '../config/features.ts';
import { siteConfig } from '../config/site.ts';
import {
  buildBreadcrumbJsonLd,
  buildCanonicalUrl,
  buildPageTitle,
  type SeoBreadcrumbItem,
  type SeoImage,
  type StructuredData,
  toAbsoluteUrl,
} from '../lib/seo/index.ts';
import {
  getEditorialUrl,
  getHomeUrl,
  getLawSearchUrl,
  getSiteUrl,
} from '../lib/portal/routes.ts';
import analyticsConsentScriptUrl from '../scripts/analytics-consent.ts?url';
import portalModulesScriptUrl from '../scripts/portal-modules.ts?url';

interface Props {
  title: string;
  description?: string;
  scripts?: ('portal-modules')[];
  breadcrumbs?: SeoBreadcrumbItem[];
  structuredData?: StructuredData | StructuredData[];
  noindex?: boolean;
  ogType?: 'website' | 'article';
  ogImage?: SeoImage;
}

const {
  title,
  description = siteConfig.seo.defaultDescription,
  scripts = [],
  breadcrumbs = [],
  structuredData,
  noindex = false,
  ogType = 'website',
  ogImage,
} = Astro.props;

const currentPath = Astro.url.pathname;
const pageTitle = buildPageTitle(title);
const base = import.meta.env.BASE_URL;
const canonicalUrl = buildCanonicalUrl(Astro.url, Astro.site);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const showEditorialLink = isEditorialNavLinkVisible();
const showOfficialStyleHeader = isOfficialStyleHeaderEnabled();
const stickyHeader = isStickyHeaderEnabled();
const flagAssetUrl = `${base}${siteConfig.officialFlagAssetPath.replace(/^\//, '')}`;
const analyticsEnabled = isAnalyticsEnabled();
const defaultAnalyticsConsentState = getDefaultAnalyticsConsentState();
const loadPortalModules = scripts.includes('portal-modules');
const breadcrumbJsonLd = buildBreadcrumbJsonLd(breadcrumbs, currentPath, Astro.site);
const structuredDataItems = [
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
];
const ogImageUrl = ogImage ? toAbsoluteUrl(ogImage.url, Astro.site) : undefined;

function getPathname(href: string): string {
  return new URL(href, Astro.url).pathname;
}

function isActivePath(targetPath: string, exact = false): boolean {
  if (targetPath === '/') {
    return currentPath === '/';
  }

  return exact
    ? currentPath === targetPath
    : currentPath === targetPath || currentPath.startsWith(targetPath);
}

const mainNavLinks = siteConfig.mainNavigation.map((entry) => {
  const href = getSiteUrl(entry.pathKey);

  return {
    href,
    label: entry.label,
    isActive: isActivePath(getPathname(href)),
  };
});

const serviceLinks = [
  { href: getHomeUrl(), label: 'Startseite' },
  ...siteConfig.serviceNavigation.map((entry) => ({
    href: getSiteUrl(entry.pathKey),
    label: entry.label,
  })),
].map((entry) => ({
  ...entry,
  isActive: isActivePath(getPathname(entry.href), true),
}));

const utilityNavLinks = siteConfig.serviceNavigation.map((entry) => {
  const href = getSiteUrl(entry.pathKey);

  return {
    href,
    label: entry.label,
    isActive: isActivePath(getPathname(href), true),
  };
});

const footerPortalLinks = [
  { href: getSiteUrl('government'), label: 'Staatsregierung' },
  { href: getSiteUrl('topics'), label: 'Themen & Projekte' },
  { href: getSiteUrl('lawHome'), label: 'Recht' },
  { href: getSiteUrl('press'), label: 'Presse & Aktuelles' },
  { href: getSiteUrl('budget'), label: 'Haushalt' },
  { href: getSiteUrl('freestate'), label: 'Über den Freistaat' },
  { href: getSiteUrl('service'), label: 'Service' },
].map((entry) => ({
  ...entry,
  isActive: isActivePath(getPathname(entry.href)),
}));

const footerUtilityLinks = [
  { href: getLawSearchUrl(), label: 'Rechtssuche' },
  { href: getSiteUrl('lawIndex'), label: 'Archiv' },
  { href: getSiteUrl('serviceOverview'), label: 'Übersicht' },
  { href: getSiteUrl('contact'), label: 'Kontakt' },
  { href: getSiteUrl('career'), label: 'Karriere' },
  { href: getSiteUrl('faq'), label: 'FAQ' },
  { href: getSiteUrl('imprint'), label: 'Impressum' },
  { href: getSiteUrl('privacy'), label: 'Datenschutz' },
  { href: getSiteUrl('accessibility'), label: 'Barrierefreiheit' },
  ...(showEditorialLink ? [{ href: getEditorialUrl(), label: 'Redaktion' }] : []),
].map((entry) => ({
  ...entry,
  isActive: isActivePath(getPathname(entry.href), true),
}));
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content={siteConfig.seo.locale} />
    <meta property="og:site_name" content={siteConfig.seo.siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl ? (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta name="twitter:image" content={ogImageUrl} />
        {ogImage?.alt ? (
          <>
            <meta property="og:image:alt" content={ogImage.alt} />
            <meta name="twitter:image:alt" content={ogImage.alt} />
          </>
        ) : null}
      </>
    ) : null}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <title>{pageTitle}</title>
    {analyticsEnabled ? (
      <>
        <script
          is:inline
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${analyticsConfig.measurementId}`}
        ></script>
        <script
          is:inline
          set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = window.gtag || gtag;
            window.gtag('js', new Date());
            (function() {
              var consentState = '${defaultAnalyticsConsentState}';
              try {
                var storedConsent = window.localStorage.getItem('${analyticsConfig.consentStorageKey}');
                if (storedConsent === 'accepted' || storedConsent === 'rejected') {
                  consentState = storedConsent;
                }
              } catch {}

              var analyticsStorage = consentState === 'accepted' ? 'granted' : 'denied';
              window.gtag('consent', 'default', {
                analytics_storage: analyticsStorage,
                ad_storage: 'denied',
                ad_user_data: 'denied',
                ad_personalization: 'denied'
              });
            })();
          `}
        />
      </>
    ) : null}
    {structuredDataItems.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>
    <div class="page-shell">
      {showOfficialStyleHeader ? (
        <Fragment>
          <div class="site-notice" role="note" aria-label="Hinweis zur Fiktionalität">
            <div class="container site-notice__inner">
              <div class="site-notice__flag">
                <img
                  src={flagAssetUrl}
                  alt=""
                  onerror="this.style.display='none'; if (this.nextElementSibling) this.nextElementSibling.removeAttribute('hidden');"
                />
                <span class="site-notice__flag-fallback" aria-hidden="true" hidden>
                  {siteConfig.officialFlagFallback}
                </span>
              </div>
              <p>{siteConfig.simulationNotice}</p>
            </div>
          </div>

          <header class:list={['site-header', stickyHeader && 'site-header--sticky']}>
            <div class="site-utility-bar">
              <div class="container site-utility-bar__inner">
                <nav class="service-nav" aria-label="Servicenavigation">
                  {utilityNavLinks.map((link) => (
                    <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                      {link.label}
                    </a>
                  ))}
                </nav>
                <a class="site-utility-bar__search-link" href={getLawSearchUrl()}>
                  Rechtssuche
                </a>
              </div>
            </div>

            <div class="container site-header__main">
              <div class="site-branding">
                <a class="site-wordmark" href={getHomeUrl()}>
                  <span class="site-wordmark__media" aria-hidden="true">
                    <img
                      src={flagAssetUrl}
                      alt=""
                      onerror="this.style.display='none'; if (this.nextElementSibling) this.nextElementSibling.removeAttribute('hidden');"
                    />
                    <span class="site-notice__flag-fallback" hidden>
                      {siteConfig.officialFlagFallback}
                    </span>
                  </span>
                  <span class="site-wordmark__text">
                    <span class="site-kicker">{siteConfig.authorityName}</span>
                    <span class="site-title">{siteConfig.portalTitle}</span>
                    <span class="site-subtitle">{siteConfig.portalSubtitle}</span>
                  </span>
                </a>
              </div>

              <div class="site-search">
                <form
                  class="header-search"
                  action={getLawSearchUrl()}
                  method="get"
                  role="search"
                  aria-label={siteConfig.searchLabel}
                >
                  <label class="header-search__field">
                    <span>{siteConfig.searchLabel}</span>
                    <div class="header-search__control">
                      <input
                        type="search"
                        name="q"
                        autocomplete="off"
                        placeholder={siteConfig.searchPlaceholder}
                      />
                      <button class="button-link" type="submit">Suchen</button>
                    </div>
                  </label>
                </form>
              </div>
            </div>

            <div class="site-mobile-nav">
              <div class="container">
                <details class="mobile-nav">
                  <summary class="mobile-nav__summary">Menü</summary>
                  <div class="mobile-nav__panel">
                    <div class="mobile-nav__group">
                      <p class="eyebrow">Hauptbereiche</p>
                      <nav class="mobile-nav__links" aria-label="Mobile Hauptnavigation">
                        {mainNavLinks.map((link) => (
                          <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                            {link.label}
                          </a>
                        ))}
                      </nav>
                    </div>

                    <div class="mobile-nav__group">
                      <p class="eyebrow">Service & Hilfe</p>
                      <nav class="mobile-nav__links" aria-label="Mobile Servicenavigation">
                        {serviceLinks.map((link) => (
                          <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                            {link.label}
                          </a>
                        ))}
                      </nav>
                    </div>

                    <div class="mobile-nav__actions">
                      <a class="button-link button-link--secondary" href={getLawSearchUrl()}>
                        Rechtssuche
                      </a>
                    </div>
                  </div>
                </details>
              </div>
            </div>

            <div class="site-nav-bar">
              <div class="container">
                <nav class="site-nav" aria-label="Hauptnavigation">
                  {mainNavLinks.map((link) => (
                    <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                      {link.label}
                    </a>
                  ))}
                </nav>
              </div>
            </div>
          </header>
        </Fragment>
      ) : (
        <Fragment>
          <div class="site-banner">
            <div class="container site-banner__inner">
              <p>Amtliche Informationsdarstellung innerhalb einer politischen Simulation</p>
            </div>
          </div>
          <header class="site-header">
            <div class="container site-header__inner">
              <div class="site-brand">
                <p class="site-kicker">{siteConfig.authorityName}</p>
                <a class="site-title" href={getHomeUrl()}>
                  {siteConfig.portalTitle}
                </a>
                <p class="site-subtitle">{siteConfig.portalSubtitle}</p>
              </div>
              <nav class="site-nav" aria-label="Hauptnavigation">
                {mainNavLinks.map((link) => (
                  <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                    {link.label}
                  </a>
                ))}
              </nav>
            </div>
          </header>
        </Fragment>
      )}

      <main id="main-content" class="container site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <div class="site-footer__meta">
            <p class="site-footer__small">{siteConfig.simulationNotice}</p>
          </div>
          <div class="site-footer__grid">
            <section class="site-footer__section">
              <h2>Kontakt</h2>
              <p>{siteConfig.contact.authorityShort}</p>
              <p>{siteConfig.contact.addressLines.join(', ')}</p>
              <p>
                <a href={`tel:${siteConfig.contact.citizenService.phone.replace(/\s+/g, '')}`}>
                  {siteConfig.contact.citizenService.phone}
                </a>
              </p>
              <p>
                <a href={`mailto:${siteConfig.contact.citizenService.email}`}>
                  {siteConfig.contact.citizenService.email}
                </a>
              </p>
            </section>

            <section class="site-footer__section">
              <h2>Portalbereiche</h2>
              <nav class="footer-nav" aria-label="Portalbereiche">
                {footerPortalLinks.map((link) => (
                  <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                    {link.label}
                  </a>
                ))}
              </nav>
            </section>

            <section class="site-footer__section">
              <h2>Hilfe & Recht</h2>
              <nav class="footer-nav" aria-label="Hilfelinks im Footer">
                {footerUtilityLinks.map((link) => (
                  <a href={link.href} aria-current={link.isActive ? 'page' : undefined}>
                    {link.label}
                  </a>
                ))}
              </nav>
            </section>
          </div>
        </div>
      </footer>
    </div>
    {analyticsEnabled ? <AnalyticsConsentBanner /> : null}
    {analyticsEnabled ? (
      <script is:inline type="module" src={analyticsConsentScriptUrl}></script>
    ) : null}
    {loadPortalModules ? (
      <script is:inline type="module" src={portalModulesScriptUrl}></script>
    ) : null}
  </body>
</html>
