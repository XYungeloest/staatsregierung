---
import '../styles/global.css';
import { isEditorialNavLinkVisible } from '../config/features.ts';
import { getEditorialUrl } from '../lib/norms/routes.ts';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Statisches Rechtsportal des Freistaats Ostdeutschland.' } = Astro.props;
const pageTitle = `${title} | Freistaat Ostdeutschland`;
const base = import.meta.env.BASE_URL;
const showEditorialLink = isEditorialNavLinkVisible();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>
    <div class="page-shell">
      <div class="site-banner">
        <div class="container site-banner__inner">
          <p>Amtliche Informationsdarstellung innerhalb einer politischen Simulation</p>
        </div>
      </div>
      <header class="site-header">
        <div class="container site-header__inner">
          <div class="site-brand">
            <p class="site-kicker">Freistaat Ostdeutschland</p>
            <a class="site-title" href={base}>Ostrecht-Portal</a>
            <p class="site-subtitle">Rechtsportal mit aktuellen Fassungen, Historien und Verzeichnissen</p>
          </div>
          <nav class="site-nav" aria-label="Hauptnavigation">
            <a href={base}>Start</a>
            <a href={`${base}search/`}>Suche</a>
            <a href={`${base}index/`}>Index</a>
            <a href={`${base}subjects/`}>Sachgebiete</a>
            {showEditorialLink ? <a href={getEditorialUrl()}>Redaktion</a> : null}
          </nav>
        </div>
      </header>

      <main id="main-content" class="container site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container site-footer__inner">
          <p>Simulationsportal mit rein statischer Ausgabe auf Basis von Astro und TypeScript.</p>
          <nav class="footer-nav" aria-label="Fußnavigation">
            <a href={base}>Start</a>
            <a href={`${base}search/`}>Suche</a>
            <a href={`${base}index/`}>Index</a>
            <a href={`${base}subjects/`}>Sachgebiete</a>
            {showEditorialLink ? <a href={getEditorialUrl()}>Redaktion</a> : null}
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
