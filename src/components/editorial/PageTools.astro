---
interface Props {
  visible: boolean;
  studioHref: string;
  sourceLabel: string;
  liveLabel: string;
  hasPendingChanges?: boolean;
  sessionEnableHref?: string;
  sessionDisableHref?: string;
}

const {
  visible,
  studioHref,
  sourceLabel,
  liveLabel,
  hasPendingChanges = false,
  sessionEnableHref,
  sessionDisableHref,
} = Astro.props;
---

{visible ? (
  <aside class="editorial-page-tools" aria-label="Redaktioneller Einstieg">
    <p class="editorial-page-tools__label">Redaktion</p>
    <p class="editorial-page-tools__meta">
      <strong>{sourceLabel}</strong>
      {' · '}
      {liveLabel}
      {hasPendingChanges ? ' · Entwurf wartet auf Veröffentlichung' : ''}
    </p>
    <p class="editorial-page-tools__hint">
      Bearbeiten-Links sind direkt an den relevanten Inhaltsblöcken eingeblendet.
    </p>
    <p><a class="inline-link" href={studioHref}>Seite im Redaktionsstudio öffnen</a></p>
    {sessionEnableHref ? (
      <p><a class="inline-link" href={sessionEnableHref}>Öffentliche Bearbeitung für diese Domain aktivieren</a></p>
    ) : null}
    {sessionDisableHref ? (
      <p><a class="inline-link" href={sessionDisableHref}>Redaktionelle Sichtbarkeit beenden</a></p>
    ) : null}
  </aside>
) : null}
