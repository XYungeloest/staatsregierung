---
import { buildMediaUrl } from '../../lib/dynamic/media.ts';
import type { EditorialInlinePanelState } from '../../lib/editorial/inline.ts';
import { buildInlineCloseHref, buildInlineStudioHref } from '../../lib/editorial/inline.ts';
import { formatEditorialPublishMode } from '../../lib/editorial/studio.ts';
import { withBase } from '../../lib/portal/routes.ts';

interface Props {
  visible: boolean;
  currentUrl: URL;
  panel?: EditorialInlinePanelState;
  errorMessage?: string;
  message?: string;
}

const {
  visible,
  currentUrl,
  panel,
  errorMessage,
  message,
} = Astro.props;

function fieldValue(name: string): string {
  return panel?.field.draftValues[name] ?? '';
}

const closeHref = buildInlineCloseHref(currentUrl);
---

{visible && panel ? (
  <aside class="editorial-inline-panel" aria-label="Seitennahe Bearbeitung" id="redaktion-panel">
    <div class="editorial-inline-panel__overlay">
      <a href={closeHref} aria-label="Panel schließen"></a>
    </div>
    <div class="editorial-inline-panel__drawer">
      <div class="editorial-inline-panel__header">
        <div>
          <p class="editorial-page-tools__label">Seitennahe Bearbeitung</p>
          <h2>{panel.field.definition.label}</h2>
          <p>{panel.field.definition.description}</p>
        </div>
        <a class="button-link button-link--ghost" href={closeHref}>Schließen</a>
      </div>

      {message ? <div class="editorial-feedback editorial-feedback--success">{message}</div> : null}
      {errorMessage ? <div class="editorial-feedback editorial-feedback--error">{errorMessage}</div> : null}

      <div class="editorial-inline-panel__status">
        <div class="meta-card">
          <span class="meta-label">Öffentlich</span>
          <strong>{panel.field.hasOverrideValue ? 'Override / Livewert' : 'Fallback'}</strong>
        </div>
        <div class="meta-card">
          <span class="meta-label">Entwurf</span>
          <strong>{panel.field.hasDraftChanges ? 'Abweichung vorhanden' : 'Kein offener Unterschied'}</strong>
        </div>
        <div class="meta-card">
          <span class="meta-label">Modus</span>
          <strong>{formatEditorialPublishMode(panel.currentDraft.publishMode)}</strong>
        </div>
      </div>

      <p class="detail-line">{panel.field.sourceLabel}</p>

      <div class="editorial-inline-panel__compare">
        <article class="panel">
          <h3>Statischer / primärer Ausgangswert</h3>
          <pre>{JSON.stringify(panel.field.fallbackValues, null, 2)}</pre>
        </article>
        <article class="panel">
          <h3>Aktueller Entwurf</h3>
          <pre>{JSON.stringify(panel.field.draftValues, null, 2)}</pre>
        </article>
      </div>

      <form
        class="editorial-form studio-form"
        method="post"
        action={withBase(`/redaktion/api/inline/${panel.type}/${panel.slug}`)}
      >
        <input type="hidden" name="fieldKey" value={panel.fieldKey} />
        <input type="hidden" name="returnTo" value={panel.returnTo} />

        <div class="editorial-grid editorial-grid--two">
          {panel.field.definition.fields.includes('title') ? (
            <label class="search-field editorial-grid__full">
              <span>Titel</span>
              <input type="text" name="title" value={fieldValue('title')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('name') ? (
            <label class="search-field editorial-grid__full">
              <span>Name</span>
              <input type="text" name="name" value={fieldValue('name')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('kurzname') ? (
            <label class="search-field">
              <span>Kurzname</span>
              <input type="text" name="kurzname" value={fieldValue('kurzname')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('leitung') ? (
            <label class="search-field">
              <span>Leitung</span>
              <input type="text" name="leitung" value={fieldValue('leitung')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('amt') ? (
            <label class="search-field">
              <span>Amt</span>
              <input type="text" name="amt" value={fieldValue('amt')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('ressort') ? (
            <label class="search-field">
              <span>Ressort</span>
              <input type="text" name="ressort" value={fieldValue('ressort')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('date') ? (
            <label class="search-field">
              <span>Datum</span>
              <input type="date" name="date" value={fieldValue('date')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('reihenfolge') ? (
            <label class="search-field">
              <span>Reihenfolge</span>
              <input type="number" min="1" name="reihenfolge" value={fieldValue('reihenfolge') || '1'} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('topicStatus') ? (
            <label class="search-field">
              <span>Status</span>
              <select name="topicStatus">
                <option value="laufend" selected={fieldValue('topicStatus') === 'laufend'}>laufend</option>
                <option value="kernprojekt" selected={fieldValue('topicStatus') === 'kernprojekt'}>kernprojekt</option>
                <option value="teilweise-umgesetzt" selected={fieldValue('topicStatus') === 'teilweise-umgesetzt'}>teilweise-umgesetzt</option>
                <option value="umgesetzt" selected={fieldValue('topicStatus') === 'umgesetzt'}>umgesetzt</option>
              </select>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('federfuehrendesRessort') ? (
            <label class="search-field">
              <span>Federführendes Ressort</span>
              <input type="text" name="federfuehrendesRessort" value={fieldValue('federfuehrendesRessort')} required />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('mitzeichnungsressortsText') ? (
            <label class="search-field">
              <span>Mitzeichnende Ressorts</span>
              <input type="text" name="mitzeichnungsressortsText" value={fieldValue('mitzeichnungsressortsText')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('isFeatured') ? (
            <label class="search-field editorial-inline-panel__checkbox">
              <span>Hervorheben</span>
              <input type="checkbox" name="isFeatured" checked={fieldValue('isFeatured') === 'on'} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('teaser') ? (
            <label class="search-field editorial-grid__full">
              <span>Teaser</span>
              <textarea name="teaser" rows="4" required>{fieldValue('teaser')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('hero') ? (
            <label class="search-field editorial-grid__full">
              <span>Hero</span>
              <textarea name="hero" rows="4">{fieldValue('hero')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('bodyText') ? (
            <label class="search-field editorial-grid__full">
              <span>Textabschnitte</span>
              <textarea name="bodyText" rows="10" required>{fieldValue('bodyText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('beschlossenText') ? (
            <label class="search-field editorial-grid__full">
              <span>Beschlossen</span>
              <textarea name="beschlossenText" rows="8" required>{fieldValue('beschlossenText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('umgesetztText') ? (
            <label class="search-field editorial-grid__full">
              <span>Umgesetzt</span>
              <textarea name="umgesetztText" rows="8" required>{fieldValue('umgesetztText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('naechsteSchritteText') ? (
            <label class="search-field editorial-grid__full">
              <span>Nächste Schritte</span>
              <textarea name="naechsteSchritteText" rows="8" required>{fieldValue('naechsteSchritteText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('faqText') ? (
            <label class="search-field editorial-grid__full">
              <span>FAQ</span>
              <textarea name="faqText" rows="8" required>{fieldValue('faqText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('aufgabenText') ? (
            <label class="search-field editorial-grid__full">
              <span>Aufgaben</span>
              <textarea name="aufgabenText" rows="8" required>{fieldValue('aufgabenText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('kurzbiografie') ? (
            <label class="search-field editorial-grid__full">
              <span>Kurzbiografie</span>
              <textarea name="kurzbiografie" rows="4" required>{fieldValue('kurzbiografie')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('langbiografieText') ? (
            <label class="search-field editorial-grid__full">
              <span>Langbiografie</span>
              <textarea name="langbiografieText" rows="10" required>{fieldValue('langbiografieText')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('zitat') ? (
            <label class="search-field editorial-grid__full">
              <span>Zitat</span>
              <textarea name="zitat" rows="3">{fieldValue('zitat')}</textarea>
            </label>
          ) : null}
          {panel.field.definition.fields.includes('contactName') ? (
            <label class="search-field">
              <span>Ansprechstelle</span>
              <input type="text" name="contactName" value={fieldValue('contactName')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('contactEmail') ? (
            <label class="search-field">
              <span>E-Mail</span>
              <input type="email" name="contactEmail" value={fieldValue('contactEmail')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('contactTelefon') ? (
            <label class="search-field">
              <span>Telefon</span>
              <input type="text" name="contactTelefon" value={fieldValue('contactTelefon')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('contactReferat') ? (
            <label class="search-field">
              <span>Referat</span>
              <input type="text" name="contactReferat" value={fieldValue('contactReferat')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('tagsText') ? (
            <label class="search-field editorial-grid__full">
              <span>Schlagworte</span>
              <input type="text" name="tagsText" value={fieldValue('tagsText')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('imageUrl') ? (
            <label class="search-field editorial-grid__full">
              <span>Externe Bild-URL</span>
              <input type="url" name="imageUrl" value={fieldValue('imageUrl')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('mediaKey') ? (
            <label class="search-field editorial-grid__full">
              <span>mediaKey</span>
              {panel.mediaAssets.length > 0 ? (
                <select name="mediaKey">
                  <option value="">Kein R2-Medium ausgewählt</option>
                  {panel.mediaAssets.map((asset) => (
                    <option value={asset.key} selected={fieldValue('mediaKey') === asset.key}>
                      {asset.title} · {asset.key}
                    </option>
                  ))}
                </select>
              ) : (
                <input type="text" name="mediaKey" value={fieldValue('mediaKey')} />
              )}
            </label>
          ) : null}
          {panel.field.definition.fields.includes('imageAlt') ? (
            <label class="search-field editorial-grid__full">
              <span>Alt-Text</span>
              <input type="text" name="imageAlt" value={fieldValue('imageAlt')} />
            </label>
          ) : null}
          {panel.field.definition.fields.includes('imageCredit') ? (
            <label class="search-field editorial-grid__full">
              <span>Credit</span>
              <input type="text" name="imageCredit" value={fieldValue('imageCredit')} />
            </label>
          ) : null}
          <label class="search-field editorial-grid__full">
            <span>Änderungsvermerk</span>
            <input type="text" name="summary" />
          </label>
        </div>

        <div class="editorial-actions">
          <button class="button-link" type="submit" name="intent" value="save">Entwurf speichern</button>
          <button class="button-link button-link--secondary" type="submit" name="intent" value="publish">Veröffentlichen</button>
          <button class="button-link button-link--ghost" type="submit" name="intent" value="use_fallback">Statischen Wert übernehmen</button>
          {panel.entry && panel.currentDraft.publishMode === 'override' ? (
            <button class="button-link button-link--ghost" type="submit" name="intent" value="reset">Override zurücksetzen</button>
          ) : null}
          <a class="button-link button-link--ghost" href={buildInlineStudioHref(panel.type, panel.slug, panel.entry?.id)}>
            Im Studio öffnen
          </a>
        </div>
      </form>

      {panel.field.usesMedia ? (
        <section class="panel">
          <div class="section-header section-header--compact">
            <h3>Medienbibliothek</h3>
            <p>Kleine Auswahl vorhandener R2-Medien für dieses Feld.</p>
          </div>

          <form
            class="editorial-form studio-form"
            method="post"
            enctype="multipart/form-data"
            action={withBase('/redaktion/api/medien/upload')}
          >
            <input type="hidden" name="returnTo" value={panel.returnTo} />
            <div class="editorial-grid editorial-grid--two">
              <label class="search-field editorial-grid__full">
                <span>Datei</span>
                <input type="file" name="file" required />
              </label>
              <label class="search-field">
                <span>Titel</span>
                <input type="text" name="title" />
              </label>
              <label class="search-field">
                <span>Alt-Text</span>
                <input type="text" name="altText" required />
              </label>
              <label class="search-field">
                <span>Credit</span>
                <input type="text" name="credit" />
              </label>
            </div>
            <div class="editorial-actions">
              <button class="button-link button-link--ghost" type="submit">Medium hochladen</button>
            </div>
          </form>

          {panel.mediaAssets.length > 0 ? (
            <div class="editorial-media-library">
              {panel.mediaAssets.map((asset) => (
                <article class="editorial-media-library__item">
                  <p><strong>{asset.title}</strong></p>
                  <p><code>{asset.key}</code></p>
                  <p>{asset.altText}</p>
                  <p class="detail-line">{asset.credit ?? 'ohne Credit'}</p>
                  <p class="section-link-row">
                    <a class="inline-link" href={buildMediaUrl(asset.key)} target="_blank" rel="noreferrer">Öffnen</a>
                  </p>
                </article>
              ))}
            </div>
          ) : (
            <p>Derzeit sind keine R2-Medien hinterlegt.</p>
          )}
        </section>
      ) : null}
    </div>
  </aside>
) : null}
