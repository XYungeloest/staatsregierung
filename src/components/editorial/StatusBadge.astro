---
import { formatEditorialStatus, getEditorialStatusTone, type EditorialEntryStatus } from '../../lib/editorial/studio.ts';

interface Props {
  status: EditorialEntryStatus;
}

const { status } = Astro.props;
const tone = getEditorialStatusTone(status);
---

<span class={`studio-status studio-status--${tone}`}>{formatEditorialStatus(status)}</span>
