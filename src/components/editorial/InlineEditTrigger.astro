---
interface Props {
  visible: boolean;
  href: string;
  label: string;
  statusLabel: string;
}

const { visible, href, label, statusLabel } = Astro.props;
---

{visible ? (
  <p class="editorial-inline-trigger">
    <span class="editorial-inline-trigger__badge">Redaktion</span>
    <a class="editorial-inline-trigger__link" href={href}>Bearbeiten: {label}</a>
    <span>{statusLabel}</span>
  </p>
) : null}
