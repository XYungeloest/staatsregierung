---
import type { EditorialFormValues } from '../../lib/editorial/drafts.ts';
import { withBase } from '../../lib/portal/routes.ts';
import { getEditorialTypeDefinition, type EditorialEntryType } from '../../lib/editorial/studio.ts';
import type { EditorialAccessInfo } from '../../lib/editorial/access.ts';

interface Props {
  type: EditorialEntryType;
  values: EditorialFormValues;
  accessInfo: EditorialAccessInfo;
  saveAction: string;
  publishAction: string;
  exportAction: string;
  downloadAction?: string;
  liveUrl?: string;
  errorMessage?: string;
}

const {
  type,
  values,
  accessInfo,
  saveAction,
  publishAction,
  exportAction,
  downloadAction,
  liveUrl,
  errorMessage,
} = Astro.props;

const definition = getEditorialTypeDefinition(type);
const isDirectPublish = definition.publishMode === 'direct';

function textValue(key: string, fallback = ''): string {
  const value = values[key];
  if (typeof value === 'number') {
    return String(value);
  }

  if (typeof value === 'string') {
    return value;
  }

  return fallback;
}

function booleanValue(key: string): boolean {
  return values[key] === true;
}

const topicStatuses = [
  'umgesetzt',
  'kernprojekt',
  'teilweise-umgesetzt',
  'sehr-weit-umgesetzt',
  'deutlich-umgesetzt',
  'ausbauphase',
  'laufend',
];

const projectStatuses = ['umgesetzt', 'teilweise_umgesetzt', 'angelegt'];
---

<form class="editorial-form studio-form" method="post" action={saveAction}>
  <input type="hidden" name="entryId" value={textValue('entryId')} />
  <input type="hidden" name="author" value={accessInfo.email ?? accessInfo.displayName} />
  <input type="hidden" name="sourceId" value={textValue('sourceId')} />
  <input type="hidden" name="sourceOrigin" value={textValue('sourceOrigin')} />
  <input type="hidden" name="status" value="draft" />

  <div class="editorial-feedback">
    Bearbeiter: <strong>{accessInfo.displayName}</strong>
    {' · '}
    Schutz: <strong>{accessInfo.protectedByAccess ? 'Cloudflare Access erkannt' : 'lokale oder ungeschützte Sitzung'}</strong>
  </div>

  {errorMessage ? <div class="editorial-feedback editorial-feedback--error">{errorMessage}</div> : null}

  <div class="editorial-grid editorial-grid--two">
    <label class="search-field">
      <span>Slug</span>
      <input type="text" name="slug" value={textValue('slug')} required />
    </label>
    <label class="search-field">
      <span>Technische Route</span>
      <input type="text" name="route" value={textValue('route')} placeholder="optional abweichende Ziel-URL" />
    </label>
    <label class="search-field editorial-grid__full">
      <span>Titel</span>
      <input type="text" name="title" value={textValue('title')} required />
    </label>
    <label class="search-field editorial-grid__full">
      <span>Änderungsvermerk</span>
      <input
        type="text"
        name="summary"
        value={textValue('summary')}
        placeholder="z. B. Teaser präzisiert, Datum aktualisiert"
      />
    </label>
  </div>

  {type === 'pressemitteilung' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field">
        <span>Datum</span>
        <input type="date" name="date" value={textValue('date')} required />
      </label>
      <label class="search-field">
        <span>Ressort</span>
        <input type="text" name="ressort" value={textValue('ressort')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Teaser</span>
        <textarea name="teaser" rows="3" required>{textValue('teaser')}</textarea>
      </label>
      <label class="search-field">
        <span>mediaKey</span>
        <input type="text" name="mediaKey" value={textValue('mediaKey')} />
      </label>
      <label class="search-field">
        <span>imageUrl</span>
        <input type="text" name="imageUrl" value={textValue('imageUrl')} />
      </label>
      <label class="search-field">
        <span>Bild-Alttext</span>
        <input type="text" name="imageAlt" value={textValue('imageAlt')} required />
      </label>
      <label class="search-field">
        <span>Bildnachweis</span>
        <input type="text" name="imageCredit" value={textValue('imageCredit')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Tags</span>
        <input type="text" name="tagsText" value={textValue('tagsText')} placeholder="kommagetrennt" />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Fließtext</span>
        <textarea name="bodyText" rows="12" required>{textValue('bodyText')}</textarea>
      </label>
      <label class="editorial-checkbox">
        <input type="checkbox" name="isFeatured" checked={booleanValue('isFeatured')} />
        <span>Als hervorgehobene Meldung markieren</span>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Zugeordnete Themen-Slugs</span>
        <input type="text" name="relatedTopicSlugsText" value={textValue('relatedTopicSlugsText')} placeholder="kommagetrennt" />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Zugeordnete Norm-Slugs</span>
        <input type="text" name="relatedNormSlugsText" value={textValue('relatedNormSlugsText')} placeholder="kommagetrennt" />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Verwandte Presse-Slugs</span>
        <input type="text" name="relatedPressSlugsText" value={textValue('relatedPressSlugsText')} placeholder="kommagetrennt" />
      </label>
    </div>
  ) : null}

  {type === 'termin' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field">
        <span>Datum</span>
        <input type="date" name="date" value={textValue('date')} required />
      </label>
      <label class="search-field">
        <span>Ort</span>
        <input type="text" name="location" value={textValue('location')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Teaser</span>
        <textarea name="teaser" rows="3" required>{textValue('teaser')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Fließtext</span>
        <textarea name="bodyText" rows="10" required>{textValue('bodyText')}</textarea>
      </label>
      <label class="search-field">
        <span>mediaKey</span>
        <input type="text" name="mediaKey" value={textValue('mediaKey')} />
      </label>
      <label class="search-field">
        <span>imageUrl</span>
        <input type="text" name="imageUrl" value={textValue('imageUrl')} />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Bild-Alttext</span>
        <input type="text" name="imageAlt" value={textValue('imageAlt')} />
      </label>
    </div>
  ) : null}

  {type === 'stellenangebot' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field">
        <span>Ressort</span>
        <input type="text" name="ressort" value={textValue('ressort')} required />
      </label>
      <label class="search-field">
        <span>Standort</span>
        <input type="text" name="standort" value={textValue('standort')} required />
      </label>
      <label class="search-field">
        <span>Arbeitsbereich</span>
        <input type="text" name="arbeitsbereich" value={textValue('arbeitsbereich')} required />
      </label>
      <label class="search-field">
        <span>Beschäftigungsart</span>
        <input type="text" name="employmentType" value={textValue('employmentType')} required />
      </label>
      <label class="search-field">
        <span>Veröffentlicht am</span>
        <input type="date" name="datePosted" value={textValue('datePosted')} required />
      </label>
      <label class="search-field">
        <span>Bewerbungsfrist</span>
        <input type="date" name="applicationDeadline" value={textValue('applicationDeadline')} required />
      </label>
      <label class="search-field">
        <span>Entgeltgruppe</span>
        <input type="text" name="payGrade" value={textValue('payGrade')} />
      </label>
      <label class="editorial-checkbox">
        <input type="checkbox" name="isActive" checked={booleanValue('isActive')} />
        <span>Stellenangebot ist aktiv</span>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Teaser</span>
        <textarea name="teaser" rows="3" required>{textValue('teaser')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Fließtext</span>
        <textarea name="bodyText" rows="12" required>{textValue('bodyText')}</textarea>
      </label>
      <label class="search-field">
        <span>Ansprechperson</span>
        <input type="text" name="contactName" value={textValue('contactName')} />
      </label>
      <label class="search-field">
        <span>E-Mail</span>
        <input type="email" name="contactEmail" value={textValue('contactEmail')} />
      </label>
      <label class="search-field">
        <span>Telefon</span>
        <input type="text" name="contactTelefon" value={textValue('contactTelefon')} />
      </label>
      <label class="search-field">
        <span>Referat</span>
        <input type="text" name="contactReferat" value={textValue('contactReferat')} />
      </label>
      <label class="search-field">
        <span>mediaKey</span>
        <input type="text" name="mediaKey" value={textValue('mediaKey')} />
      </label>
      <label class="search-field">
        <span>imageUrl</span>
        <input type="text" name="imageUrl" value={textValue('imageUrl')} />
      </label>
      <label class="search-field">
        <span>Bild-Alttext</span>
        <input type="text" name="imageAlt" value={textValue('imageAlt')} />
      </label>
      <label class="search-field">
        <span>Bildnachweis</span>
        <input type="text" name="imageCredit" value={textValue('imageCredit')} />
      </label>
    </div>
  ) : null}

  {type === 'projektstatus' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field editorial-grid__full">
        <span>Beschreibung</span>
        <textarea name="description" rows="4" required>{textValue('description')}</textarea>
      </label>
      <label class="search-field">
        <span>Status</span>
        <select name="projectStatus" required>
          {projectStatuses.map((status) => (
            <option value={status} selected={textValue('projectStatus') === status}>{status}</option>
          ))}
        </select>
      </label>
      <label class="search-field">
        <span>Ressort</span>
        <input type="text" name="ressort" value={textValue('ressort')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Ziel-Link</span>
        <input type="text" name="href" value={textValue('href')} required />
      </label>
      <label class="search-field">
        <span>Position</span>
        <input type="number" name="position" value={textValue('position', '1')} min="1" required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Rechtsreferenzen</span>
        <textarea
          name="referencesText"
          rows="6"
          placeholder="Label | norm-slug"
        >{textValue('referencesText')}</textarea>
      </label>
    </div>
  ) : null}

  {type === 'service-seite' ? (
    <div class="editorial-grid">
      <label class="search-field editorial-grid__full">
        <span>Textabschnitte</span>
        <textarea name="bodyText" rows="14" required>{textValue('bodyText')}</textarea>
      </label>
    </div>
  ) : null}

  {type === 'themenseite' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field editorial-grid__full">
        <span>Teaser</span>
        <textarea name="teaser" rows="3" required>{textValue('teaser')}</textarea>
      </label>
      <label class="search-field">
        <span>Status</span>
        <select name="topicStatus" required>
          {topicStatuses.map((status) => (
            <option value={status} selected={textValue('topicStatus') === status}>{status}</option>
          ))}
        </select>
      </label>
      <label class="search-field">
        <span>Federführendes Ressort</span>
        <input type="text" name="federfuehrendesRessort" value={textValue('federfuehrendesRessort')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Hero-Abschnitt</span>
        <textarea name="hero" rows="4">{textValue('hero')}</textarea>
      </label>
      <label class="search-field">
        <span>Was ist beschlossen?</span>
        <textarea name="beschlossenText" rows="7" required>{textValue('beschlossenText')}</textarea>
      </label>
      <label class="search-field">
        <span>Was ist umgesetzt?</span>
        <textarea name="umgesetztText" rows="7" required>{textValue('umgesetztText')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Nächste Schritte</span>
        <textarea name="naechsteSchritteText" rows="7" required>{textValue('naechsteSchritteText')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Rechtsgrundlagen</span>
        <textarea
          name="rechtsgrundlagenText"
          rows="6"
          placeholder="Label | normSlug | optionaler Hinweis"
        >{textValue('rechtsgrundlagenText')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>FAQ</span>
        <textarea
          name="faqText"
          rows="8"
          placeholder="Frage | Antwort"
        >{textValue('faqText')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Mitzeichnende Ressorts</span>
        <input type="text" name="mitzeichnungsressortsText" value={textValue('mitzeichnungsressortsText')} placeholder="kommagetrennt" />
      </label>
    </div>
  ) : null}

  {type === 'ressort' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field">
        <span>Name</span>
        <input type="text" name="name" value={textValue('name')} required />
      </label>
      <label class="search-field">
        <span>Kurzname</span>
        <input type="text" name="kurzname" value={textValue('kurzname')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Leitung</span>
        <input type="text" name="leitung" value={textValue('leitung')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Kurzbeschreibung</span>
        <textarea name="teaser" rows="4" required>{textValue('teaser')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Aufgaben</span>
        <textarea name="aufgabenText" rows="8" required>{textValue('aufgabenText')}</textarea>
      </label>
      <label class="search-field">
        <span>Ansprechstelle</span>
        <input type="text" name="contactName" value={textValue('contactName')} />
      </label>
      <label class="search-field">
        <span>E-Mail</span>
        <input type="email" name="contactEmail" value={textValue('contactEmail')} />
      </label>
      <label class="search-field">
        <span>Telefon</span>
        <input type="text" name="contactTelefon" value={textValue('contactTelefon')} />
      </label>
      <label class="search-field">
        <span>Referat</span>
        <input type="text" name="contactReferat" value={textValue('contactReferat')} />
      </label>
      <label class="search-field">
        <span>mediaKey</span>
        <input type="text" name="mediaKey" value={textValue('mediaKey')} />
      </label>
      <label class="search-field">
        <span>imageUrl</span>
        <input type="text" name="imageUrl" value={textValue('imageUrl')} />
      </label>
      <label class="search-field">
        <span>Bild-Alttext</span>
        <input type="text" name="imageAlt" value={textValue('imageAlt')} />
      </label>
      <label class="search-field">
        <span>Bildnachweis</span>
        <input type="text" name="imageCredit" value={textValue('imageCredit')} />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Themen</span>
        <textarea name="themenText" rows="6" required>{textValue('themenText')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Verknüpfte Links</span>
        <textarea
          name="verknuepfteLinksText"
          rows="6"
          placeholder="Label | /pfad/"
        >{textValue('verknuepfteLinksText')}</textarea>
      </label>
    </div>
  ) : null}

  {type === 'regierungsmitglied' ? (
    <div class="editorial-grid editorial-grid--two">
      <label class="search-field">
        <span>Name</span>
        <input type="text" name="name" value={textValue('name')} required />
      </label>
      <label class="search-field">
        <span>Amt</span>
        <input type="text" name="amt" value={textValue('amt')} required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Ressort</span>
        <input type="text" name="ressort" value={textValue('ressort')} required />
      </label>
      <label class="search-field">
        <span>Reihenfolge</span>
        <input type="number" name="reihenfolge" value={textValue('reihenfolge', '1')} min="1" required />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Kurzbiografie</span>
        <textarea name="kurzbiografie" rows="4" required>{textValue('kurzbiografie')}</textarea>
      </label>
      <label class="search-field editorial-grid__full">
        <span>Langbiografie</span>
        <textarea name="langbiografieText" rows="12" required>{textValue('langbiografieText')}</textarea>
      </label>
      <label class="search-field">
        <span>mediaKey</span>
        <input type="text" name="mediaKey" value={textValue('mediaKey')} />
      </label>
      <label class="search-field">
        <span>imageUrl</span>
        <input type="text" name="imageUrl" value={textValue('imageUrl')} />
      </label>
      <label class="search-field">
        <span>Bild-Alttext</span>
        <input type="text" name="imageAlt" value={textValue('imageAlt')} />
      </label>
      <label class="search-field">
        <span>Bildnachweis</span>
        <input type="text" name="imageCredit" value={textValue('imageCredit')} />
      </label>
      <label class="search-field">
        <span>Ansprechstelle</span>
        <input type="text" name="contactName" value={textValue('contactName')} />
      </label>
      <label class="search-field">
        <span>E-Mail</span>
        <input type="email" name="contactEmail" value={textValue('contactEmail')} />
      </label>
      <label class="search-field">
        <span>Telefon</span>
        <input type="text" name="contactTelefon" value={textValue('contactTelefon')} />
      </label>
      <label class="search-field">
        <span>Referat</span>
        <input type="text" name="contactReferat" value={textValue('contactReferat')} />
      </label>
      <label class="search-field editorial-grid__full">
        <span>Zitat</span>
        <textarea name="zitat" rows="3">{textValue('zitat')}</textarea>
      </label>
    </div>
  ) : null}

  <div class="editorial-actions">
    <button class="button-link" type="submit">Entwurf speichern</button>
    {isDirectPublish ? (
      <button class="button-link button-link--secondary" type="submit" formaction={publishAction}>
        {definition.directPublishLabel}
      </button>
    ) : (
      <button class="button-link button-link--secondary" type="submit" formaction={exportAction}>
        {definition.directPublishLabel}
      </button>
    )}
    {liveUrl ? (
      <a class="button-link button-link--ghost" href={liveUrl} target="_blank" rel="noreferrer">
        Live-Ziel öffnen
      </a>
    ) : null}
    {downloadAction ? (
      <a class="button-link button-link--ghost" href={downloadAction}>
        Export-JSON laden
      </a>
    ) : null}
    <a class="button-link button-link--ghost" href={withBase('/redaktion/medien/')}>
      Medienverwaltung
    </a>
  </div>
</form>
