---
interface Props {
  privacyUrl: string;
}

const { privacyUrl } = Astro.props;
---

<aside
  class="consent-banner"
  data-analytics-consent-banner
  hidden
  aria-label="Einwilligung in statistische Auswertung"
>
  <div class="container consent-banner__inner">
    <div class="consent-banner__copy">
      <p class="eyebrow">Statistik</p>
      <h2>Google Analytics 4 nur nach Einwilligung</h2>
      <p>
        Reichweitenmessung mit Google Analytics 4 wird auf dieser Website erst nach Ihrer
        Zustimmung aktiviert. Ihre Entscheidung wird nur lokal in diesem Browser gespeichert.
      </p>
    </div>

    <div class="consent-banner__actions">
      <button class="button-link" type="button" data-analytics-consent-accept>
        Analytik akzeptieren
      </button>
      <button class="button-link button-link--secondary" type="button" data-analytics-consent-reject>
        Analytik ablehnen
      </button>
      <a class="consent-banner__link" href={privacyUrl}>
        Datenschutz
      </a>
    </div>
  </div>
</aside>
