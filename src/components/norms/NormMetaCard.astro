---
import { getNormHistoryUrl, getNormUrl, getNormVersionUrl, getSubjectUrl } from '../../lib/norms/routes.ts';
import type { NormRecord, NormVersion } from '../../lib/norms/schema.ts';

interface Props {
  norm: NormRecord;
  version: NormVersion;
  historical?: boolean;
}

const { norm, version, historical = false } = Astro.props;
const historicalVersions = norm.versions.filter((entry) => !entry.isCurrent);
---

<aside class="section meta-panel">
  <div class="meta-list">
    <div>
      <dt>Kurztitel</dt>
      <dd>{norm.meta.shortTitle}</dd>
    </div>
    <div>
      <dt>Abkuerzung</dt>
      <dd>{norm.meta.abbr}</dd>
    </div>
    <div>
      <dt>Normtyp</dt>
      <dd>{norm.meta.type}</dd>
    </div>
    <div>
      <dt>Ressort</dt>
      <dd>{norm.meta.ministry}</dd>
    </div>
    <div>
      <dt>Zitat</dt>
      <dd>{version.citation}</dd>
    </div>
    <div>
      <dt>Gueltig ab</dt>
      <dd>{version.validFrom}</dd>
    </div>
    <div>
      <dt>Gueltig bis</dt>
      <dd>{version.validTo ?? 'aktuell'}</dd>
    </div>
  </div>

  <div class="tag-list">
    {norm.meta.subjects.map((subject) => (
      <a class="tag" href={getSubjectUrl(subject)}>{subject}</a>
    ))}
  </div>

  <nav class="link-list" aria-label="Weiterfuehrende Links">
    <a href={getNormHistoryUrl(norm.meta.slug)}>Zur Historie</a>
    {historical ? <a href={getNormUrl(norm.meta.slug)}>Zur aktuellen Fassung</a> : null}
    {historicalVersions.map((entry) => (
      <a href={getNormVersionUrl(norm.meta.slug, entry.versionId)}>
        Historische Fassung {entry.versionId}
      </a>
    ))}
  </nav>
</aside>
